                <span class="flex items-center justify-center flex-shrink-0 mt-0.5" style="width: 20px; height: 20px; border-radius: 9999px; background: var(--color-primary-50);">
                  <svg class="w-3 h-3" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span class="text-body-md" style="color: var(--color-foreground);">Crime &amp; Personal Safety Assessment</span>
              </li>
              <li class="flex items-start gap-3 py-2 animate-checklist" style="animation-delay: 180ms;">
                <span class="flex items-center justify-center flex-shrink-0 mt-0.5" style="width: 20px; height: 20px; border-radius: 9999px; background: var(--color-primary-50);">
                  <svg class="w-3 h-3" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span class="text-body-md" style="color: var(--color-foreground);">Natural Hazard &amp; Weather Risk</span>
              </li>
              <li class="flex items-start gap-3 py-2 animate-checklist" style="animation-delay: 240ms;">
                <span class="flex items-center justify-center flex-shrink-0 mt-0.5" style="width: 20px; height: 20px; border-radius: 9999px; background: var(--color-primary-50);">
                  <svg class="w-3 h-3" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span class="text-body-md" style="color: var(--color-foreground);">Infrastructure &amp; Transportation Safety</span>
              </li>
            </ol>
          </div>

          <!-- Category 2: Health & Medical -->
          <div class="animate-card-reveal" style="background: var(--color-card); border-radius: var(--radius-xl); border: 1px solid var(--color-border); padding: 24px; animation-delay: 100ms;">
            <h3 class="text-heading-sm" style="color: var(--color-foreground); font-family: var(--font-heading); font-weight: 600; margin-bottom: 16px;">Health &amp; Medical</h3>
            <ol style="list-style: none; display: flex; flex-direction: column; gap: 4px;">
              <li class="flex items-start gap-3 py-2 animate-checklist" style="animation-delay: 160ms;">
                <span class="flex items-center justify-center flex-shrink-0 mt-0.5" style="width: 20px; height: 20px; border-radius: 9999px; background: var(--color-primary-50);">
                  <svg class="w-3 h-3" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
