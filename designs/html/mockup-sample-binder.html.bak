  <!-- ================================================================
       LEAD CAPTURE MODAL
       ================================================================ -->
  <div id="lead-modal-overlay" class="fixed inset-0 z-40 hidden" style="background: rgba(0,0,0,0.5);" role="presentation" onclick="closeModal()">
  </div>
  <div id="lead-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="modal-headline">
    <div class="modal-surface relative w-full max-w-md mx-auto" style="background: var(--color-card); border-radius: var(--radius-2xl); box-shadow: var(--shadow-xl); padding: 32px;" onclick="event.stopPropagation()">

      <!-- Close Button -->
      <button onclick="closeModal()" class="absolute top-4 right-4 p-2 rounded-md transition-colors" style="color: var(--color-muted-foreground); background: none; border: none; cursor: pointer;" aria-label="Close dialog">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>

      <!-- Form State -->
      <div id="modal-form-state">
        <!-- Icon -->
        <div class="flex items-center justify-center mb-4" style="width: 40px; height: 40px;">
          <svg class="w-8 h-8" style="color: var(--color-primary-700);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
          </svg>
        </div>

        <!-- Headline -->
        <h3 id="modal-headline" class="text-heading-md" style="color: var(--color-foreground);">Download Your Sample Safety Binder</h3>
        <p class="text-body-md mt-2" style="color: var(--color-muted-foreground);">Enter your work email to receive the <span id="modal-binder-name" class="font-medium" style="color: var(--color-foreground);">Sample Safety Binder</span> instantly.</p>

        <!-- Form -->
        <form id="binder-form" class="mt-6" onsubmit="handleSubmit(event)">
          <input type="hidden" id="binder-slug" name="binder_slug" value="">
          <!-- Honeypot -->
          <div style="display: none;" aria-hidden="true">
            <input type="text" name="website" tabindex="-1" autocomplete="off">
          </div>

          <div class="input-group">
            <label for="work-email" class="input-label">Work Email</label>
            <input type="email" id="work-email" name="email" class="input" placeholder="you@organization.com" required autocomplete="email">
          </div>

          <div class="input-group mt-4">
            <label for="org-type" class="input-label">Organization Type</label>
            <select id="org-type" name="org_type" class="input" required style="appearance: auto;">
              <option value="" disabled selected>Select your organization type</option>
              <option value="k12">K-12 School/District</option>
              <option value="church">Church/Mission Org</option>
              <option value="higher-ed">Higher Education</option>
              <option value="corporate">Corporate/Sports</option>
              <option value="other">Other</option>
            </select>
          </div>

          <button type="submit" id="submit-btn" class="btn btn-md btn-primary w-full mt-6" style="font-family: var(--font-heading); font-size: 15px; font-weight: 600; padding: 12px 24px; border-radius: var(--radius-md); background: var(--color-primary-600); color: #fff; width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; border: none;">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Download Now
          </button>
        </form>

        <!-- Consent -->
        <p class="mt-4 text-center" style="font-size: 12px; color: var(--color-muted-foreground); line-height: 1.5;">
          We'll also send a brief email series on trip safety best practices. Unsubscribe anytime.
        </p>
        <div class="flex items-center justify-center gap-1.5 mt-2" style="font-size: 12px; color: var(--color-muted-foreground);">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Your data is encrypted and never shared.
        </div>
      </div>

      <!-- Success State (hidden by default) -->
      <div id="modal-success-state" class="hidden text-center">
        <div class="flex items-center justify-center mx-auto mb-4" style="width: 48px; height: 48px; border-radius: 9999px; background: var(--color-primary-50);">
          <svg class="w-6 h-6 status-pulse" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3 class="text-heading-md" style="color: var(--color-foreground);">Your Binder Is on Its Way</h3>
        <p class="text-body-md mt-2" style="color: var(--color-muted-foreground);">
          We've sent the <span id="success-binder-name" class="font-medium" style="color: var(--color-foreground);">Sample Safety Binder</span> to <span id="success-email" class="font-medium" style="color: var(--color-foreground);">your email</span>. Check your inbox -- it should arrive within 60 seconds.
        </p>
        <button class="btn btn-md btn-primary w-full mt-6" style="font-family: var(--font-heading); font-size: 15px; font-weight: 600; padding: 12px 24px; border-radius: var(--radius-md); background: var(--color-primary-600); color: #fff; width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; border: none;">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Download Directly
        </button>
        <a href="/demo" class="btn btn-md btn-secondary w-full mt-3" style="font-family: var(--font-heading); font-size: 15px; font-weight: 600; padding: 12px 24px; border-radius: var(--radius-md); width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none;">
          Request a Demo
        </a>
      </div>

    </div>
  </div>

  <!-- ================================================================
       JAVASCRIPT
       ================================================================ -->
  <script>
    // ---- Sticky header scroll behavior ----
    const header = document.getElementById('site-header');
    function onScroll() {
      const scrollY = window.scrollY;
      if (scrollY > 100) {
        header.classList.add('header-scrolled');
        header.style.height = '64px';
      } else {
        header.classList.remove('header-scrolled');
        header.style.height = '80px';
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // ---- Mobile menu ----
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-close-btn');
    const overlay = document.getElementById('mobile-overlay');
    const panel = document.getElementById('mobile-panel');

    function openMenu() {
      overlay.classList.add('active');
      panel.classList.add('active');
      overlay.setAttribute('aria-hidden', 'false');
      menuBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      overlay.classList.remove('active');
      panel.classList.remove('active');
      overlay.setAttribute('aria-hidden', 'true');
      menuBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    menuBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    overlay.addEventListener('click', closeMenu);

    // ---- Lead Capture Modal ----
    let triggerElement = null;

    function openModal(slug, binderName) {
      triggerElement = document.activeElement;
      document.getElementById('binder-slug').value = slug;
      document.getElementById('modal-binder-name').textContent = binderName;
      document.getElementById('success-binder-name').textContent = binderName;
      document.getElementById('lead-modal-overlay').classList.remove('hidden');
      document.getElementById('lead-modal').classList.remove('hidden');
      document.getElementById('lead-modal').classList.add('flex');
      document.getElementById('modal-form-state').classList.remove('hidden');
      document.getElementById('modal-success-state').classList.add('hidden');
      document.body.style.overflow = 'hidden';
      // Pre-select org type based on binder slug
      const orgSelect = document.getElementById('org-type');
      const slugToOrg = {
        'k12-field-trip': 'k12',
        'mission-trip': 'church',
        'corporate-travel': 'corporate',
        'study-abroad': 'higher-ed'
      };
      if (slugToOrg[slug]) {
        orgSelect.value = slugToOrg[slug];
      } else {
        orgSelect.selectedIndex = 0;
      }
      setTimeout(() => {
        document.getElementById('work-email').focus();
      }, 100);
    }

    function closeModal() {
      document.getElementById('lead-modal-overlay').classList.add('hidden');
      document.getElementById('lead-modal').classList.add('hidden');
      document.getElementById('lead-modal').classList.remove('flex');
      document.body.style.overflow = '';
      if (triggerElement) {
        triggerElement.focus();
        triggerElement = null;
      }
    }

    function handleSubmit(e) {
      e.preventDefault();
      const email = document.getElementById('work-email').value;
      document.getElementById('success-email').textContent = email;
      document.getElementById('modal-form-state').classList.add('hidden');
      document.getElementById('modal-success-state').classList.remove('hidden');
    }

    // Close modal on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeModal();
        closeMenu();
      }
    });

    // Close modal on overlay click
    document.getElementById('lead-modal-overlay').addEventListener('click', closeModal);

    // ---- Counter Animation for trust section ----
    function animateCounter(elementId, target, duration) {
      const el = document.getElementById(elementId);
      if (!el) return;
      let start = 0;
      const startTime = performance.now();
      function update(currentTime) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(eased * target);
        el.textContent = current;
        if (progress < 1) {
          requestAnimationFrame(update);
        }
      }
      requestAnimationFrame(update);
    }

    // Trigger counter when trust section enters viewport
    const trustSection = document.querySelector('[aria-label="Trust and security"]');
    if (trustSection) {
      const trustObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            animateCounter('counter-5', 5, 1500);
            trustObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      trustObserver.observe(trustSection);
    }
  </script>
</body>
</html>