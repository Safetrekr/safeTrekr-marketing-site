          <button onclick="openModal('', 'Sample Safety Binder')" class="btn btn-lg btn-primary mt-6" aria-label="Download a sample safety binder -- requires email" style="font-family: var(--font-heading); font-size: 16px; font-weight: 600; padding: 16px 32px; border-radius: var(--radius-md); background: var(--color-primary-600); color: #fff; cursor: pointer; border: none; display: inline-flex; align-items: center; gap: 8px;">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Download a Sample Binder
