              <div class="thumbnail-peek mt-3">
                <div style="background: white; border-radius: var(--radius-md) var(--radius-md) 0 0; border: 1px solid var(--color-border); border-bottom: none; box-shadow: var(--shadow-sm); padding: 12px; max-width: 50%;">
                  <div style="width: 70%; height: 5px; background: var(--color-primary-200); border-radius: 3px; margin-bottom: 8px;"></div>
                  <div style="width: 100%; height: 4px; background: var(--color-border); border-radius: 2px; margin-bottom: 6px;"></div>
                  <div style="width: 55%; height: 4px; background: var(--color-border); border-radius: 2px;"></div>
                </div>
              </div>
            </div>
            <div style="padding: 20px 24px 24px;">
              <div class="flex items-center justify-center" style="width: 40px; height: 40px; border-radius: var(--radius-lg); background: var(--color-primary-50);">
                <svg class="w-5 h-5" style="color: var(--color-primary-700);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342"/>
                </svg>
              </div>
              <h3 class="text-heading-md mt-3" style="color: var(--color-foreground);">University Study Abroad Safety Binder</h3>
              <p class="text-body-md mt-2" style="color: var(--color-muted-foreground); max-width: 45ch;">17-section safety review for university study abroad programs. Clery Act aware, parent/guardian accessible, and institutional compliance ready.</p>
              <div class="flex flex-wrap gap-2 mt-4">
                <span class="badge badge-brand">17 Sections</span>
                <span class="badge badge-brand">Clery Act</span>
