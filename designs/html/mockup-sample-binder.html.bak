                  <div style="width: 100%; height: 4px; background: var(--color-border); border-radius: 2px; margin-bottom: 6px;"></div>
                  <div style="width: 82%; height: 4px; background: var(--color-border); border-radius: 2px; margin-bottom: 6px;"></div>
