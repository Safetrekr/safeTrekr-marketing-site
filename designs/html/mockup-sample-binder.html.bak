    <!-- ================================================================
         SECTION 3: WHAT'S INSIDE (17-section breakdown)
         ================================================================ -->
    <section aria-label="What's inside the safety binder" style="background: var(--color-background);">
      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 py-16 sm:py-20 lg:py-24 xl:py-32">

        <!-- Section Header -->
        <div class="text-center max-w-2xl mx-auto">
