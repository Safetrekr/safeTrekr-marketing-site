    <!-- ================================================================
         SECTION 4: TRUST REINFORCEMENT (Dark)
         ================================================================ -->
    <section aria-label="Trust and security" data-theme="dark" style="background: var(--color-secondary);">
      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 py-12 sm:py-16 lg:py-24">

        <!-- Stat Row -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 lg:gap-8">
          <!-- Stat 1 -->
          <div class="text-center animate-counter" style="animation-delay: 0ms;">
            <div class="text-display-md" style="color: #f7f8f8; font-family: var(--font-heading); font-weight: 700;" aria-label="5 government intelligence sources">
              <span id="counter-5">5</span>
            </div>
            <div class="text-body-sm mt-1" style="color: #b8c3c7;">Government Intelligence Sources</div>
          </div>
          <!-- Stat 2 -->
          <div class="text-center animate-counter" style="animation-delay: 100ms;">
            <div class="text-display-md" style="color: #f7f8f8; font-family: var(--font-heading); font-weight: 700;" aria-label="AES-256 encryption standard">AES-256</div>
            <div class="text-body-sm mt-1" style="color: #b8c3c7;">Encryption Standard</div>
          </div>
          <!-- Stat 3 -->
          <div class="text-center animate-counter" style="animation-delay: 200ms;">
            <div class="text-display-md" style="color: #f7f8f8; font-family: var(--font-heading); font-weight: 700;" aria-label="SHA-256 evidence chain integrity">SHA-256</div>
            <div class="text-body-sm mt-1" style="color: #b8c3c7;">Evidence Chain Integrity</div>
          </div>
        </div>

        <!-- Source Logos -->
        <div class="flex items-center justify-center flex-wrap gap-x-10 gap-y-4 mt-10" style="opacity: 0.6;">
          <span class="text-body-sm" style="color: #b8c3c7; font-weight: 500;">Data sourced from:</span>
          <span class="font-semibold text-body-sm" style="color: #b8c3c7; font-family: var(--font-heading); letter-spacing: 0.03em;">NOAA</span>
          <span class="font-semibold text-body-sm" style="color: #b8c3c7; font-family: var(--font-heading); letter-spacing: 0.03em;">USGS</span>
          <span class="font-semibold text-body-sm" style="color: #b8c3c7; font-family: var(--font-heading); letter-spacing: 0.03em;">CDC</span>
          <span class="font-semibold text-body-sm" style="color: #b8c3c7; font-family: var(--font-heading); letter-spacing: 0.03em;">GDACS</span>
          <span class="font-semibold text-body-sm" style="color: #b8c3c7; font-family: var(--font-heading); letter-spacing: 0.03em;">ReliefWeb</span>
        </div>

        <!-- Quote -->
        <p class="text-body-lg text-center mx-auto mt-8 italic" style="color: #b8c3c7; max-width: 48ch;">
          "Every page of every binder is cryptographically signed. Any modification to any section is detectable."
        </p>

      </div>
