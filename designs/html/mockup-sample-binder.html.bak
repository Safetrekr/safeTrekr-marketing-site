<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sample Safety Binders | SafeTrekr -- Professional Trip Safety</title>
  <meta name="description" content="Download a sample SafeTrekr safety binder for your organization type. See exactly what a professionally reviewed trip produces -- 17 safety sections, risk scores, emergency protocols, and audit-ready documentation.">
  <link rel="canonical" href="https://www.safetrekr.com/resources/sample-binders">
  <link rel="stylesheet" href="design-tokens.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            background: 'var(--color-background)',
            foreground: 'var(--color-foreground)',
            card: 'var(--color-card)',
            'card-foreground': 'var(--color-card-foreground)',
            border: 'var(--color-border)',
            input: 'var(--color-input)',
            ring: 'var(--color-ring)',
            muted: 'var(--color-muted)',
            'muted-foreground': 'var(--color-muted-foreground)',
            accent: 'var(--color-accent)',
            'accent-foreground': 'var(--color-accent-foreground)',
            primary: {
              50: 'var(--color-primary-50)',
              100: 'var(--color-primary-100)',
              200: 'var(--color-primary-200)',
              300: 'var(--color-primary-300)',
              400: 'var(--color-primary-400)',
              500: 'var(--color-primary-500)',
              600: 'var(--color-primary-600)',
              700: 'var(--color-primary-700)',
              800: 'var(--color-primary-800)',
              900: 'var(--color-primary-900)',
              950: 'var(--color-primary-950)',
              DEFAULT: 'var(--color-primary)',
            },
            secondary: {
              DEFAULT: 'var(--color-secondary)',
              foreground: 'var(--color-secondary-foreground)',
              light: 'var(--color-secondary-light)',
              muted: 'var(--color-secondary-muted)',
            },
            destructive: {
              DEFAULT: 'var(--color-destructive)',
              foreground: 'var(--color-destructive-foreground)',
            },
            safety: {
              green: 'var(--color-safety-green)',
              yellow: 'var(--color-safety-yellow)',
              red: 'var(--color-safety-red)',
            },
          },
          fontFamily: {
            display: ['Plus Jakarta Sans', 'system-ui', '-apple-system', 'sans-serif'],
            body: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
            mono: ['JetBrains Mono', 'ui-monospace', 'monospace'],
          },
          borderRadius: {
            sm: 'var(--radius-sm)',
            md: 'var(--radius-md)',
            lg: 'var(--radius-lg)',
            xl: 'var(--radius-xl)',
            '2xl': 'var(--radius-2xl)',
          },
          boxShadow: {
            xs: 'var(--shadow-xs)',
            sm: 'var(--shadow-sm)',
            md: 'var(--shadow-md)',
            lg: 'var(--shadow-lg)',
            xl: 'var(--shadow-xl)',
          },
          maxWidth: {
            'container': '1280px',
          },
        },
      },
    }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Sample Safety Binders",
    "description": "Download sample SafeTrekr safety binders for K-12 field trips, international mission trips, corporate travel, and university study abroad programs.",
    "url": "https://www.safetrekr.com/resources/sample-binders",
    "publisher": {
      "@type": "Organization",
      "name": "SafeTrekr"
    },
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "K-12 Field Trip Safety Binder",
          "url": "https://www.safetrekr.com/resources/sample-binders/k12-field-trip"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "International Mission Trip Safety Binder",
          "url": "https://www.safetrekr.com/resources/sample-binders/mission-trip"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Corporate Travel Safety Binder",
          "url": "https://www.safetrekr.com/resources/sample-binders/corporate-travel"
        },
        {
          "@type": "ListItem",
          "position": 4,
          "name": "University Study Abroad Safety Binder",
          "url": "https://www.safetrekr.com/resources/sample-binders/study-abroad"
        }
      ]
    }
  }
  </script>
  <style>
    /* ---- Glassmorphic header ---- */
    .header-scrolled {
      background: rgba(231, 236, 238, 0.80);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-bottom: 1px solid rgba(184, 195, 199, 0.5);
      box-shadow: var(--shadow-sm);
    }

    /* ---- Smooth scroll offset for sticky header ---- */
    html {
      scroll-padding-top: 80px;
    }

    /* ---- Mobile menu overlay ---- */
    .mobile-menu-overlay {
      position: fixed;
      inset: 0;
      background: rgba(6, 26, 35, 0.5);
      z-index: 40;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }
    .mobile-menu-overlay.active {
      opacity: 1;
      pointer-events: all;
    }
    .mobile-menu-panel {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: 320px;
      max-width: 85vw;
      background: var(--color-card);
      z-index: 50;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      overflow-y: auto;
      padding: 24px;
    }
    .mobile-menu-panel.active {
      transform: translateX(0);
    }

    /* ---- Fade-up animation ---- */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-up {
      animation: fadeUp 0.5s ease-out forwards;
      opacity: 0;
    }

    /* ---- Document stack animation ---- */
    @keyframes documentStack {
      from { opacity: 0; transform: translateY(16px) rotateX(-5deg); }
      to { opacity: 1; transform: translateY(0) rotateX(0); }
    }
    .animate-document-stack {
      animation: documentStack 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      opacity: 0;
    }

    /* ---- Card reveal ---- */
    @keyframes cardReveal {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-card-reveal {
      animation: cardReveal 0.5s ease-out forwards;
      opacity: 0;
    }

    /* ---- Checklist item reveal ---- */
    @keyframes checklistReveal {
      from { opacity: 0; transform: translateX(-12px); }
      to { opacity: 1; transform: translateX(0); }
    }
    .animate-checklist {
      animation: checklistReveal 0.4s ease-out forwards;
      opacity: 0;
    }

    /* ---- Counter animation ---- */
    @keyframes counterAnimate {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-counter {
      animation: counterAnimate 0.6s ease-out forwards;
      opacity: 0;
    }

    /* ---- Document preview binder pages ---- */
    .binder-page {
      position: absolute;
      width: 220px;
      height: 300px;
      background: white;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-xl);
      padding: 24px;
      border: 1px solid rgba(184, 195, 199, 0.2);
      transition: transform 0.3s ease;
    }
    .binder-page:hover {
      transform: translateY(-4px) !important;
    }

    /* ---- Card hover ---- */
    .binder-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .binder-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-lg);
    }

    /* ---- Thumbnail peek gradient ---- */
    .thumbnail-peek {
      position: relative;
      overflow: hidden;
      max-height: 80px;
    }
    .thumbnail-peek::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 60%;
      background: linear-gradient(to bottom, transparent, var(--color-background));
      pointer-events: none;
    }

    /* ---- Modal ---- */
    @keyframes modalScaleIn {
      from { opacity: 0; transform: scale(0.95); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes backdropFade {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    .modal-backdrop {
      animation: backdropFade 0.2s ease forwards;
    }
    .modal-surface {
      animation: modalScaleIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    /* ---- Status pulse for success ---- */
    @keyframes statusPulse {
      0% { transform: scale(0); opacity: 0; }
      60% { transform: scale(1.4); opacity: 1; }
      100% { transform: scale(1); opacity: 1; }
    }
    .status-pulse {
      animation: statusPulse 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      transform: scale(0);
    }

    /* ---- Reduced motion ---- */
    @media (prefers-reduced-motion: reduce) {
      .animate-fade-up,
      .animate-document-stack,
      .animate-card-reveal,
      .animate-checklist,
      .animate-counter,
      .modal-surface,
      .modal-backdrop,
      .status-pulse,
      .binder-page {
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
      }
    }

    /* ---- Hero radial glow ---- */
    .hero-radial-glow {
      background: radial-gradient(600px circle at 70% 50%, rgba(241,249,244,0.2), transparent);
      position: absolute;
      inset: 0;
      pointer-events: none;
    }
  </style>
  <script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>
</head>
<body>
  <!-- Skip Navigation -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:bg-card focus:text-foreground focus:px-4 focus:py-2 focus:rounded-md focus:shadow-lg focus:ring-2 focus:ring-ring" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">
    Skip to main content
  </a>

  <!-- ================================================================
       SITE HEADER (Sticky Glassmorphic)
       ================================================================ -->
  <header id="site-header" class="fixed top-0 left-0 right-0 z-30 transition-all duration-300" style="height: 80px;">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 h-full flex items-center justify-between">
      <!-- Logo: Horizontal lockup -->
      <a href="/" aria-label="SafeTrekr home" class="flex-shrink-0">
        <svg height="32" viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="hidden lg:block" aria-hidden="true">
          <path d="M16 1L3 8v10c0 7.2 5.5 13.9 13 15.9 7.5-2 13-8.7 13-15.9V8L16 1z" fill="none" stroke="#123646" stroke-width="2" stroke-linejoin="round"/>
          <path d="M10 14l4 4 8-8" stroke="#3f885b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="40" y="22" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-weight="700" font-size="18" fill="#123646">SafeTrekr</text>
        </svg>
        <svg height="28" viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="lg:hidden" aria-hidden="true">
          <path d="M16 1L3 8v10c0 7.2 5.5 13.9 13 15.9 7.5-2 13-8.7 13-15.9V8L16 1z" fill="none" stroke="#123646" stroke-width="2" stroke-linejoin="round"/>
          <path d="M10 14l4 4 8-8" stroke="#3f885b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="40" y="22" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-weight="700" font-size="18" fill="#123646">SafeTrekr</text>
        </svg>
      </a>

      <!-- Desktop Nav -->
      <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-8">
        <a href="/platform" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Platform
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="/solutions" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Solutions
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="/how-it-works" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150" style="font-family: var(--font-body);">How It Works</a>
        <a href="/pricing" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150" style="font-family: var(--font-body);">Pricing</a>
        <a href="/resources" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Resources
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </nav>

      <!-- Desktop CTAs -->
      <div class="hidden lg:flex items-center gap-4">
        <a href="https://app.safetrekr.com" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold transition-colors duration-150 hover:text-foreground" style="font-family: var(--font-heading); color: var(--color-muted-foreground);">Sign In</a>
        <a href="/demo" class="inline-flex items-center justify-center font-semibold rounded-md transition-all duration-150 text-white" style="font-family: var(--font-heading); background: var(--color-primary-600); padding: 10px 20px; font-size: 15px; border-radius: var(--radius-md); text-decoration: none;">Get a Demo</a>
      </div>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-foreground" aria-label="Open navigation menu" aria-expanded="false">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-overlay" class="mobile-menu-overlay" aria-hidden="true"></div>
  <div id="mobile-panel" class="mobile-menu-panel" role="dialog" aria-modal="true" aria-label="Main navigation">
    <div class="flex justify-between items-center mb-8">
      <span class="font-display font-bold text-lg text-foreground">Menu</span>
      <button id="mobile-close-btn" class="p-2 text-foreground" aria-label="Close navigation menu">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <nav class="flex flex-col gap-2">
      <a href="/platform" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Platform</a>
      <a href="/solutions" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Solutions</a>
      <a href="/how-it-works" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">How It Works</a>
      <a href="/pricing" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Pricing</a>
      <a href="/resources" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors font-semibold" style="font-family: var(--font-body);">Resources</a>
      <div class="border-t mt-4 pt-4" style="border-color: var(--color-border);">
        <a href="/demo" class="block w-full text-center py-3 rounded-md text-base font-semibold text-white" style="background: var(--color-primary-600); font-family: var(--font-heading);">Get a Demo</a>
      </div>
    </nav>
  </div>

  <!-- ================================================================
       MAIN CONTENT
       ================================================================ -->
  <main id="main-content">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12" style="padding-top: 96px;">
      <ol class="flex items-center gap-2 text-body-sm" style="list-style: none; color: var(--color-muted-foreground);">
        <li><a href="/" style="color: var(--color-muted-foreground); text-decoration: none;" class="hover:text-foreground transition-colors">Home</a></li>
        <li aria-hidden="true">
          <svg class="w-4 h-4" style="color: var(--color-border);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </li>
        <li><a href="/resources" style="color: var(--color-muted-foreground); text-decoration: none;" class="hover:text-foreground transition-colors">Resources</a></li>
        <li aria-hidden="true">
          <svg class="w-4 h-4" style="color: var(--color-border);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </li>
        <li aria-current="page" style="color: var(--color-foreground); font-weight: 500;">Sample Binders</li>
      </ol>
    </nav>

    <!-- ================================================================
         SECTION 1: HERO
         ================================================================ -->
    <section aria-label="Sample safety binders" class="relative overflow-hidden" style="background: var(--color-background);">
      <div class="hero-radial-glow"></div>
      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 relative z-10 pt-8 pb-12 sm:pt-12 sm:pb-16 lg:pt-16 lg:pb-20 xl:pt-20 xl:pb-24">
        <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">

          <!-- Text Column -->
          <div class="lg:col-span-5 flex flex-col">
            <!-- Eyebrow -->
            <span class="text-eyebrow flex items-center gap-2 animate-fade-up" style="color: var(--color-primary-700); animation-delay: 0ms;">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--color-primary-700);">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke-linejoin="round"/>
                <path d="M14 2v6h6" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M16 13H8M16 17H8M10 9H8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              YOUR #1 RESOURCE
            </span>

            <!-- Headline -->
            <h1 id="hero-heading" class="text-display-lg mt-4 animate-fade-up" style="color: var(--color-foreground); max-width: 20ch; animation-delay: 80ms;">
              See Exactly What a Professional Trip Safety Review Produces
            </h1>

            <!-- Body -->
            <p class="text-body-lg mt-6 animate-fade-up" style="color: var(--color-muted-foreground); max-width: 50ch; animation-delay: 160ms;">
              Every trip reviewed by SafeTrekr produces a comprehensive safety binder -- 17 sections of risk analysis, emergency protocols, and audit-ready documentation. Download a sample binder and see exactly what your board, insurance carrier, and stakeholders receive.
            </p>

            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row gap-4 mt-8 animate-fade-up" style="animation-delay: 240ms;">
              <a href="#binders" class="inline-flex items-center justify-center gap-2 font-semibold rounded-md transition-all duration-150 text-white text-center sm:text-left" style="font-family: var(--font-heading); background: var(--color-primary-600); padding: 16px 32px; font-size: 16px; border-radius: var(--radius-md);">
                Choose Your Binder
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </a>
              <a href="/demo" class="inline-flex items-center justify-center gap-2 font-semibold rounded-md transition-all duration-150 text-center sm:text-left" style="font-family: var(--font-heading); background: transparent; border: 1.5px solid var(--color-border); color: var(--color-foreground); padding: 16px 32px; font-size: 16px; border-radius: var(--radius-md);">
                Get a Demo
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            </div>
          </div>

          <!-- Visual Column: DocumentPreview -->
          <div class="lg:col-span-7 hidden md:flex items-center justify-center animate-document-stack" aria-hidden="true" style="animation-delay: 300ms;">
            <div class="relative" style="width: 380px; height: 420px; perspective: 800px;">
              <!-- Back page (page 3) -->
              <div class="binder-page" style="top: 16px; left: 50%; transform: translateX(-50%) rotate(3deg); z-index: 1;">
                <div style="width: 100%; height: 8px; background: var(--color-primary-100); border-radius: 4px; margin-bottom: 12px;"></div>
                <div style="width: 80%; height: 6px; background: var(--color-border); border-radius: 3px; margin-bottom: 8px;"></div>
                <div style="width: 90%; height: 6px; background: var(--color-border); border-radius: 3px; margin-bottom: 8px;"></div>
                <div style="width: 70%; height: 6px; background: var(--color-border); border-radius: 3px; margin-bottom: 16px;"></div>
                <div style="width: 100%; height: 40px; background: var(--color-primary-50); border-radius: var(--radius-md); margin-bottom: 12px;"></div>
                <div style="width: 85%; height: 6px; background: var(--color-border); border-radius: 3px; margin-bottom: 8px;"></div>
                <div style="width: 95%; height: 6px; background: var(--color-border); border-radius: 3px;"></div>
              </div>

              <!-- Middle page (page 2) -->
              <div class="binder-page" style="top: 8px; left: 50%; transform: translateX(-50%) rotate(-1.5deg); z-index: 2;">
                <div style="width: 60%; height: 8px; background: var(--color-primary-200); border-radius: 4px; margin-bottom: 14px;"></div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 14px;">
                  <div style="height: 48px; background: var(--color-primary-50); border-radius: var(--radius-sm); border: 1px solid var(--color-primary-100);"></div>
                  <div style="height: 48px; background: var(--color-primary-50); border-radius: var(--radius-sm); border: 1px solid var(--color-primary-100);"></div>
                </div>
                <div style="width: 100%; height: 6px; background: var(--color-border); border-radius: 3px; margin-bottom: 8px;"></div>
                <div style="width: 85%; height: 6px; background: var(--color-border); border-radius: 3px; margin-bottom: 8px;"></div>
                <div style="width: 95%; height: 6px; background: var(--color-border); border-radius: 3px; margin-bottom: 16px;"></div>
                <div style="width: 100%; height: 32px; background: var(--color-muted); border-radius: var(--radius-sm);"></div>
              </div>

