                <span class="flex items-center justify-center flex-shrink-0 mt-0.5" style="width: 20px; height: 20px; border-radius: 9999px; background: var(--color-primary-50);">
                  <svg class="w-3 h-3" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span class="text-body-md" style="color: var(--color-foreground);">Medical Facility Access &amp; Quality</span>
              </li>
              <li class="flex items-start gap-3 py-2 animate-checklist" style="animation-delay: 280ms;">
                <span class="flex items-center justify-center flex-shrink-0 mt-0.5" style="width: 20px; height: 20px; border-radius: 9999px; background: var(--color-primary-50);">
                  <svg class="w-3 h-3" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span class="text-body-md" style="color: var(--color-foreground);">Food &amp; Water Safety Assessment</span>
