                <span style="color: var(--color-border);">--</span> $65/hr staff cost
              </li>
            </ul>
            <div class="mt-4">
              <span class="text-xs block" style="color: var(--color-muted-foreground);">Est. annual savings</span>
              <span class="text-heading-md tabular-nums font-semibold" style="color: var(--color-primary-700); font-family: var(--font-heading);" id="scenario-corporate-savings">$0</span>
            </div>
            <span class="btn btn-sm btn-secondary w-full mt-4 pointer-events-none" style="font-family: var(--font-heading); font-size: 13px; font-weight: 600; padding: 8px 16px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; gap: 6px;">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              Try This Scenario
            </span>
          </button>

        </div>
      </div>
    </section>

    <!-- ================================================================
         SECTION 4: DARK TRUST METRICS STRIP
         ================================================================ -->
    <section aria-label="SafeTrekr trust metrics" data-theme="dark" style="background: var(--color-secondary);">
      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 py-12 lg:py-16">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 lg:gap-6">

          <div class="text-center animate-counter" style="animation-delay: 0ms;">
            <div class="font-display text-3xl font-bold text-white tabular-nums" style="font-family: var(--font-heading);" aria-label="5 government intelligence sources">5</div>
            <div class="text-xs uppercase tracking-wider mt-1" style="color: var(--color-secondary-muted); letter-spacing: 0.1em;">Government Intel Sources</div>
          </div>

          <div class="text-center animate-counter" style="animation-delay: 100ms;">
            <div class="font-display text-3xl font-bold text-white tabular-nums" style="font-family: var(--font-heading);" aria-label="17 safety review sections">17</div>
            <div class="text-xs uppercase tracking-wider mt-1" style="color: var(--color-secondary-muted); letter-spacing: 0.1em;">Safety Review Sections</div>
          </div>

          <div class="text-center animate-counter" style="animation-delay: 200ms;">
            <div class="font-display text-3xl font-bold text-white" style="font-family: var(--font-heading);" aria-label="3 to 5 day turnaround">3-5</div>
            <div class="text-xs uppercase tracking-wider mt-1" style="color: var(--color-secondary-muted); letter-spacing: 0.1em;">Day Turnaround</div>
          </div>

          <div class="text-center animate-counter" style="animation-delay: 300ms;">
            <div class="font-display text-3xl font-bold text-white" style="font-family: var(--font-heading); font-size: 24px;" aria-label="AES-256 encryption standard">AES-256</div>
            <div class="text-xs uppercase tracking-wider mt-1" style="color: var(--color-secondary-muted); letter-spacing: 0.1em;">Encryption Standard</div>
          </div>

          <div class="text-center animate-counter col-span-2 md:col-span-1" style="animation-delay: 400ms;">
            <div class="font-display text-3xl font-bold text-white" style="font-family: var(--font-heading); font-size: 24px;" aria-label="SHA-256 evidence chain">SHA-256</div>
            <div class="text-xs uppercase tracking-wider mt-1" style="color: var(--color-secondary-muted); letter-spacing: 0.1em;">Evidence Chain</div>
          </div>

        </div>
