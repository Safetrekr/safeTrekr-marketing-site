              </li>
            </ul>
            <div class="mt-4">
              <span class="text-xs block" style="color: var(--color-muted-foreground);">Est. annual savings</span>
              <span class="text-heading-md tabular-nums font-semibold" style="color: var(--color-primary-700); font-family: var(--font-heading);" id="scenario-k12-savings">$0</span>
