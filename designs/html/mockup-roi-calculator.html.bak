              <span class="text-heading-md tabular-nums font-semibold" style="color: var(--color-primary-700); font-family: var(--font-heading);">$5,000/year</span>
              <span class="block text-xs mt-1" style="color: var(--color-muted-foreground);">$50 per participant. Includes liability documentation your insurance carrier requires.</span>
            </div>
            <span class="btn btn-sm btn-secondary w-full mt-4 pointer-events-none" style="font-family: var(--font-heading); font-size: 13px; font-weight: 600; padding: 8px 16px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; gap: 6px;">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              Try This Scenario
            </span>
          </button>

          <!-- Scenario 3: University -->
          <button type="button" class="scenario-card bg-white rounded-xl p-6 text-left animate-card-reveal" style="border: 1px solid var(--color-border); box-shadow: var(--shadow-sm); animation-delay: 400ms;" onclick="loadScenario('highered')" aria-label="Pre-fill calculator with University scenario: 8 trips per year, 20 students, estimated savings of $3,600">
            <div class="flex items-center justify-center rounded-lg" style="width: 40px; height: 40px; background: var(--color-primary-50);">
              <svg class="w-5 h-5" style="color: var(--color-primary-700);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>
              </svg>
            </div>
            <h3 class="text-heading-sm mt-3" style="color: var(--color-foreground); font-family: var(--font-heading);">University</h3>
            <ul class="mt-3 space-y-1.5" style="list-style: none;">
              <li class="flex items-center gap-2 text-sm" style="color: var(--color-muted-foreground);">
                <span style="color: var(--color-border);">--</span> 8 trips/year
              </li>
              <li class="flex items-center gap-2 text-sm" style="color: var(--color-muted-foreground);">
                <span style="color: var(--color-border);">--</span> 20 students
              </li>
              <li class="flex items-center gap-2 text-sm" style="color: var(--color-muted-foreground);">
                <span style="color: var(--color-border);">--</span> 15 hrs manual/trip
              </li>
