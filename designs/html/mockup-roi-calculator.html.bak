            <span class="btn btn-sm btn-secondary w-full mt-4 pointer-events-none" style="font-family: var(--font-heading); font-size: 13px; font-weight: 600; padding: 8px 16px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; gap: 6px;">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              Try This Scenario
            </span>
          </button>

          <!-- Scenario 4: Corporate / Sports -->
          <button type="button" class="scenario-card bg-white rounded-xl p-6 text-left animate-card-reveal" style="border: 1px solid var(--color-border); box-shadow: var(--shadow-sm); animation-delay: 500ms;" onclick="loadScenario('corporate')" aria-label="Pre-fill calculator with Corporate / Sports scenario: 15 trips per year, 25 participants, estimated savings of $8,500">
            <div class="flex items-center justify-center rounded-lg" style="width: 40px; height: 40px; background: var(--color-primary-50);">
              <svg class="w-5 h-5" style="color: var(--color-primary-700);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/>
              </svg>
            </div>
            <h3 class="text-heading-sm mt-3" style="color: var(--color-foreground); font-family: var(--font-heading);">Corporate / Sports</h3>
            <ul class="mt-3 space-y-1.5" style="list-style: none;">
              <li class="flex items-center gap-2 text-sm" style="color: var(--color-muted-foreground);">
                <span style="color: var(--color-border);">--</span> 15 trips/year
              </li>
              <li class="flex items-center gap-2 text-sm" style="color: var(--color-muted-foreground);">
