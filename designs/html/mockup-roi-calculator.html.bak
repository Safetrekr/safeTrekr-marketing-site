            <span class="btn btn-sm btn-secondary w-full mt-4 pointer-events-none" style="font-family: var(--font-heading); font-size: 13px; font-weight: 600; padding: 8px 16px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; gap: 6px;">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              Try This Scenario
            </span>
          </button>

          <!-- Scenario 2: Church / Mission Org -->
          <button type="button" class="scenario-card bg-white rounded-xl p-6 text-left animate-card-reveal" style="border: 1px solid var(--color-border); box-shadow: var(--shadow-sm); animation-delay: 300ms;" onclick="loadScenario('church')" aria-label="Pre-fill calculator with Church Mission Org scenario: 4 trips per year, 25 participants, investment of $5,000 per year">
            <div class="flex items-center justify-center rounded-lg" style="width: 40px; height: 40px; background: var(--color-primary-50);">
              <svg class="w-5 h-5" style="color: var(--color-primary-700);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z"/>
              </svg>
            </div>
            <h3 class="text-heading-sm mt-3" style="color: var(--color-foreground); font-family: var(--font-heading);">Church Mission Org</h3>
            <ul class="mt-3 space-y-1.5" style="list-style: none;">
              <li class="flex items-center gap-2 text-sm" style="color: var(--color-muted-foreground);">
                <span style="color: var(--color-border);">--</span> 4 trips/year
              </li>
              <li class="flex items-center gap-2 text-sm" style="color: var(--color-muted-foreground);">
                <span style="color: var(--color-border);">--</span> 25 participants
