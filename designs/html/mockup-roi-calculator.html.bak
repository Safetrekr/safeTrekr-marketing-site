  <div id="report-modal-overlay" class="fixed inset-0 z-40 hidden" style="background: rgba(0,0,0,0.5);" role="presentation" onclick="closeReportModal()"></div>
  <div id="report-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="report-modal-headline">
    <div class="modal-surface relative w-full max-w-md mx-auto" style="background: var(--color-card); border-radius: var(--radius-2xl); box-shadow: var(--shadow-xl); padding: 32px;" onclick="event.stopPropagation()">

      <!-- Close Button -->
      <button onclick="closeReportModal()" class="absolute top-4 right-4 p-2 rounded-md transition-colors" style="color: var(--color-muted-foreground); background: none; border: none; cursor: pointer;" aria-label="Close dialog">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>

      <!-- Form State -->
      <div id="report-form-state">
        <!-- Icon -->
        <div class="mb-4" style="width: 40px; height: 40px;">
          <svg class="w-8 h-8" style="color: var(--color-primary-700);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
          </svg>
        </div>

        <!-- Headline -->
        <h3 id="report-modal-headline" class="text-heading-md" style="color: var(--color-foreground);">Download Your Full ROI Report</h3>
        <p class="text-body-md mt-2" style="color: var(--color-muted-foreground);">Get a shareable PDF with your personalized ROI analysis, including liability comparisons and cost breakdowns for your <span id="report-org-name" class="font-medium" style="color: var(--color-foreground);">organization</span>.</p>

        <!-- Form -->
        <form id="report-form" class="mt-6" onsubmit="handleReportSubmit(event)">
          <!-- Honeypot -->
          <div style="display: none;" aria-hidden="true">
            <input type="text" name="website" tabindex="-1" autocomplete="off">
          </div>

          <div class="input-group">
            <label for="report-email" class="input-label">Work Email</label>
            <input type="email" id="report-email" name="email" class="input" placeholder="you@organization.com" required autocomplete="email">
          </div>

          <div class="input-group mt-4">
            <label for="report-name" class="input-label">Full Name</label>
            <input type="text" id="report-name" name="name" class="input" placeholder="Your full name" required minlength="2" autocomplete="name">
          </div>

          <div class="input-group mt-4">
            <label for="report-org" class="input-label">Organization Name</label>
            <input type="text" id="report-org" name="organization" class="input" placeholder="Your organization" required minlength="2" autocomplete="organization">
          </div>

          <button type="submit" class="btn btn-md btn-primary w-full mt-6" style="font-family: var(--font-heading); font-size: 15px; font-weight: 600; padding: 12px 24px; border-radius: var(--radius-md); background: var(--color-primary-600); color: #fff; width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; border: none;">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Download Report
          </button>
        </form>

        <!-- Consent -->
        <p class="mt-4 text-center" style="font-size: 12px; color: var(--color-muted-foreground); line-height: 1.5;">
          We'll also send a brief email series on maximizing your trip safety ROI. Unsubscribe anytime.
        </p>
        <div class="flex items-center justify-center gap-1.5 mt-2" style="font-size: 12px; color: var(--color-muted-foreground);">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Your data is encrypted and never shared.
        </div>
      </div>

      <!-- Success State -->
      <div id="report-success-state" class="hidden text-center">
        <div class="flex items-center justify-center mx-auto mb-4" style="width: 48px; height: 48px; border-radius: 9999px; background: var(--color-primary-50);">
          <svg class="w-6 h-6 status-pulse" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3 class="text-heading-md" style="color: var(--color-foreground);">Your Report Is on Its Way</h3>
        <p class="text-body-md mt-2" style="color: var(--color-muted-foreground);">
          We've sent your personalized ROI report to <span id="report-success-email" class="font-medium" style="color: var(--color-foreground);">your email</span>. Check your inbox -- it should arrive within 60 seconds.
        </p>
        <button class="btn btn-md btn-primary w-full mt-6" style="font-family: var(--font-heading); font-size: 15px; font-weight: 600; padding: 12px 24px; border-radius: var(--radius-md); background: var(--color-primary-600); color: #fff; width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; border: none;">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Download Directly
        </button>
        <a href="/demo" class="btn btn-md btn-secondary w-full mt-3" style="font-family: var(--font-heading); font-size: 15px; font-weight: 600; padding: 12px 24px; border-radius: var(--radius-md); width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none;">
          Request a Demo
        </a>
      </div>

    </div>
  </div>

  <!-- ================================================================
       SHARE TOAST
       ================================================================ -->
  <div id="share-toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-lg text-sm font-medium transition-all duration-300" style="background: var(--color-secondary); color: #fff; box-shadow: var(--shadow-xl); opacity: 0; transform: translate(-50%, 20px); pointer-events: none;">
    <div class="flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      Link copied to clipboard.
    </div>
  </div>

  <!-- ================================================================
       JAVASCRIPT
       ================================================================ -->
  <script>
    // ================================================================
    // STICKY HEADER
    // ================================================================
    const header = document.getElementById('site-header');
    function onScroll() {
      if (window.scrollY > 100) {
        header.classList.add('header-scrolled');
        header.style.height = '64px';
      } else {
        header.classList.remove('header-scrolled');
        header.style.height = '80px';
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // ================================================================
    // MOBILE MENU
    // ================================================================
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-close-btn');
    const mobileOverlay = document.getElementById('mobile-overlay');
    const mobilePanel = document.getElementById('mobile-panel');

    function openMenu() {
      mobileOverlay.classList.add('active');
      mobilePanel.classList.add('active');
      mobileOverlay.setAttribute('aria-hidden', 'false');
      menuBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      mobileOverlay.classList.remove('active');
      mobilePanel.classList.remove('active');
      mobileOverlay.setAttribute('aria-hidden', 'true');
      menuBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    menuBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    mobileOverlay.addEventListener('click', closeMenu);

    // ================================================================
    // CALCULATOR STATE & ELEMENTS
    // ================================================================
    const orgSelect = document.getElementById('org-type');
    const tripsSlider = document.getElementById('trips-slider');
    const tripsValue = document.getElementById('trips-value');
    const sizeSlider = document.getElementById('size-slider');
    const sizeValue = document.getElementById('size-value');
    const hoursSlider = document.getElementById('hours-slider');
    const hoursValue = document.getElementById('hours-value');
    const rateInput = document.getElementById('rate-input');

    // Result elements
    const resultManualCost = document.getElementById('result-manual-cost');
    const resultSafetrekrCost = document.getElementById('result-safetrekr-cost');
    const resultNetSavings = document.getElementById('result-net-savings');
    const resultPerStudent = document.getElementById('result-per-student');
    const savingsBox = document.getElementById('savings-box');
    const savingsLabel = document.getElementById('savings-label');
    const savingsNote = document.getElementById('savings-note');
    const liabilityLow = document.getElementById('liability-low');
    const liabilityHigh = document.getElementById('liability-high');
    const mobileSavingsValue = document.getElementById('mobile-savings-value');

    // Scenario savings elements
    const scenarioK12Savings = document.getElementById('scenario-k12-savings');
    const scenarioHigheredSavings = document.getElementById('scenario-highered-savings');
    const scenarioCorporateSavings = document.getElementById('scenario-corporate-savings');

    // ================================================================
    // SEGMENT PRE-FILL DEFAULTS
    // ================================================================
    const segmentDefaults = {
      k12:       { trips: 20, size: 30, hours: 8,  rate: 45 },
      church:    { trips: 4,  size: 25, hours: 12, rate: 35 },
      highered:  { trips: 8,  size: 20, hours: 15, rate: 55 },
      corporate: { trips: 15, size: 25, hours: 10, rate: 65 },
    };

    // ================================================================
    // PRICING LOGIC: getTripCost(orgType, groupSize)
    // ================================================================
    function getTripCost(orgType, groupSize) {
      switch (orgType) {
        case 'k12':
          return 450;
        case 'church':
          return 1250; // International default
        case 'highered':
          return 1250; // International
        case 'corporate':
          return 750;  // Extended
        default:
          return 450;
      }
    }

    // ================================================================
    // FORMAT CURRENCY
    // ================================================================
    function formatCurrency(value, decimals) {
      if (decimals === undefined) decimals = 0;
      const absVal = Math.abs(value);
      const formatted = absVal.toLocaleString('en-US', {
        minimumFractionDigits: decimals,
        maximumFractionDigits: decimals,
      });
      return (value < 0 ? '-$' : '$') + formatted;
    }

    // ================================================================
    // UPDATE SLIDER FILL VISUAL
    // ================================================================
    function updateSliderFill(slider) {
      const min = parseFloat(slider.min);
      const max = parseFloat(slider.max);
      const val = parseFloat(slider.value);
      const percent = ((val - min) / (max - min)) * 100;
      slider.style.setProperty('--fill-percent', percent + '%');
    }

    // ================================================================
    // CALCULATE & RENDER RESULTS
    // ================================================================
    function calculate() {
      const orgType = orgSelect.value;
      const trips = parseInt(tripsSlider.value) || 1;
      const groupSize = parseInt(sizeSlider.value) || 10;
      const hours = parseInt(hoursSlider.value) || 2;
      const rate = parseFloat(rateInput.value) || 15;

      // Core calculations
      const annualManualCost = trips * hours * rate;
      const tripCost = getTripCost(orgType, groupSize);
      const annualSafetrekrCost = trips * tripCost;
      const netSavings = annualManualCost - annualSafetrekrCost;
      const perStudentCost = tripCost / groupSize;
      const liabilityPctLow = (annualSafetrekrCost / 500000 * 100);
      const liabilityPctHigh = (annualSafetrekrCost / 2000000 * 100);

      // Update result displays
      resultManualCost.textContent = formatCurrency(annualManualCost);
      resultManualCost.setAttribute('aria-label', 'Annual manual cost: ' + formatCurrency(annualManualCost));

      resultSafetrekrCost.textContent = formatCurrency(annualSafetrekrCost);
      resultSafetrekrCost.setAttribute('aria-label', 'Annual SafeTrekr cost: ' + formatCurrency(annualSafetrekrCost));

      resultPerStudent.textContent = formatCurrency(perStudentCost, 2);
      resultPerStudent.setAttribute('aria-label', 'Cost per student per trip: ' + formatCurrency(perStudentCost, 2));

      // Liability
      liabilityLow.textContent = liabilityPctLow.toFixed(1) + '%';
      liabilityHigh.textContent = liabilityPctHigh.toFixed(1) + '%';

      // Net savings box -- positive vs negative state
      if (netSavings >= 0) {
        resultNetSavings.textContent = formatCurrency(netSavings);
        resultNetSavings.setAttribute('aria-label', 'Your net annual savings: ' + formatCurrency(netSavings));
        savingsBox.style.background = 'var(--color-primary-50)';
        savingsBox.style.borderColor = 'var(--color-primary-200)';
        savingsLabel.style.color = 'var(--color-primary-700)';
        savingsLabel.textContent = 'YOUR NET ANNUAL SAVINGS';
        resultNetSavings.style.color = 'var(--color-primary-700)';
        savingsNote.classList.add('hidden');
      } else {
        resultNetSavings.textContent = formatCurrency(Math.abs(netSavings));
        resultNetSavings.setAttribute('aria-label', 'SafeTrekr investment exceeds manual cost by ' + formatCurrency(Math.abs(netSavings)));
        savingsBox.style.background = '#fffbeb';
        savingsBox.style.borderColor = '#fde68a';
        savingsLabel.style.color = '#92400e';
        savingsLabel.textContent = 'SAFETREKR INVESTMENT EXCEEDS MANUAL COST';
        resultNetSavings.style.color = '#92400e';
        savingsNote.classList.remove('hidden');
      }

      // Subtle scale animation on savings box
      savingsBox.classList.remove('animate-scale-in');
      void savingsBox.offsetWidth; // force reflow
      savingsBox.classList.add('animate-scale-in');

      // Mobile sticky bar
      if (netSavings >= 0) {
        mobileSavingsValue.textContent = formatCurrency(netSavings) + '/year';
      } else {
        mobileSavingsValue.textContent = '+' + formatCurrency(Math.abs(netSavings)) + '/year';
      }

      // Update URL params silently
      updateURLParams();
    }

    // ================================================================
    // COMPUTE SCENARIO CARD SAVINGS
    // ================================================================
    function computeScenarioSavings(orgType) {
      const d = segmentDefaults[orgType];
      const manual = d.trips * d.hours * d.rate;
      const stCost = d.trips * getTripCost(orgType, d.size);
      return manual - stCost;
    }

    function updateScenarioCards() {
      // K-12
      const k12Savings = computeScenarioSavings('k12');
      if (k12Savings >= 0) {
        scenarioK12Savings.textContent = formatCurrency(k12Savings) + '/year';
      } else {
        scenarioK12Savings.textContent = formatCurrency(k12Savings) + '/year';
      }

      // Higher Ed
      const heSavings = computeScenarioSavings('highered');
      if (heSavings >= 0) {
        scenarioHigheredSavings.textContent = formatCurrency(heSavings) + '/year';
      } else {
        scenarioHigheredSavings.textContent = formatCurrency(heSavings) + '/year';
      }

      // Corporate
      const corpSavings = computeScenarioSavings('corporate');
      if (corpSavings >= 0) {
        scenarioCorporateSavings.textContent = formatCurrency(corpSavings) + '/year';
      } else {
        scenarioCorporateSavings.textContent = formatCurrency(corpSavings) + '/year';
      }
    }

    // ================================================================
    // SYNC SLIDER <-> NUMBER INPUT
    // ================================================================
    function syncSliderAndInput(slider, input) {
      slider.addEventListener('input', function() {
        input.value = slider.value;
        updateSliderFill(slider);
        slider.setAttribute('aria-valuenow', slider.value);
        calculate();
        showMobileBar();
      });
      input.addEventListener('input', function() {
        let val = parseInt(input.value);
        const min = parseInt(slider.min);
        const max = parseInt(slider.max);
        if (isNaN(val)) return;
        if (val < min) val = min;
        if (val > max) val = max;
        slider.value = val;
        input.value = val;
        updateSliderFill(slider);
        slider.setAttribute('aria-valuenow', val);
        calculate();
        showMobileBar();
      });
      input.addEventListener('blur', function() {
        let val = parseInt(input.value);
        const min = parseInt(slider.min);
        const max = parseInt(slider.max);
        if (isNaN(val) || val < min) val = min;
        if (val > max) val = max;
        input.value = val;
        slider.value = val;
        updateSliderFill(slider);
        calculate();
      });
    }

    syncSliderAndInput(tripsSlider, tripsValue);
    syncSliderAndInput(sizeSlider, sizeValue);
    syncSliderAndInput(hoursSlider, hoursValue);

    // Rate input
    rateInput.addEventListener('input', function() {
      calculate();
      showMobileBar();
    });
    rateInput.addEventListener('blur', function() {
      let val = parseFloat(rateInput.value);
      if (isNaN(val) || val < 15) val = 15;
      if (val > 200) val = 200;
      rateInput.value = val;
      calculate();
    });

    // Org type change -- apply defaults
    orgSelect.addEventListener('change', function() {
      const defaults = segmentDefaults[orgSelect.value];
      if (!defaults) return;

      tripsSlider.value = defaults.trips;
      tripsValue.value = defaults.trips;
      updateSliderFill(tripsSlider);
      tripsSlider.setAttribute('aria-valuenow', defaults.trips);

      sizeSlider.value = defaults.size;
      sizeValue.value = defaults.size;
      updateSliderFill(sizeSlider);
      sizeSlider.setAttribute('aria-valuenow', defaults.size);

      hoursSlider.value = defaults.hours;
      hoursValue.value = defaults.hours;
      updateSliderFill(hoursSlider);
      hoursSlider.setAttribute('aria-valuenow', defaults.hours);

      rateInput.value = defaults.rate;

      calculate();
      showMobileBar();
    });

    // ================================================================
    // SCENARIO CARD CLICK
    // ================================================================
    function loadScenario(orgType) {
      orgSelect.value = orgType;
      orgSelect.dispatchEvent(new Event('change'));
      document.getElementById('calculator').scrollIntoView({ behavior: 'smooth' });
    }

    // ================================================================
    // URL PARAMS (Shareable)
    // ================================================================
    let urlUpdateTimer;
    function updateURLParams() {
      clearTimeout(urlUpdateTimer);
      urlUpdateTimer = setTimeout(function() {
        const params = new URLSearchParams();
        params.set('org', orgSelect.value);
        params.set('trips', tripsSlider.value);
        params.set('size', sizeSlider.value);
        params.set('hours', hoursSlider.value);
        params.set('rate', rateInput.value);
        const newUrl = window.location.pathname + '?' + params.toString();
        window.history.replaceState(null, '', newUrl);
      }, 300);
    }

    function loadFromURLParams() {
      const params = new URLSearchParams(window.location.search);
      if (!params.has('org')) return false;

      const org = params.get('org');
      if (['k12', 'church', 'highered', 'corporate'].includes(org)) {
        orgSelect.value = org;
      }
      if (params.has('trips')) {
        const t = parseInt(params.get('trips'));
        if (t >= 1 && t <= 100) { tripsSlider.value = t; tripsValue.value = t; }
      }
      if (params.has('size')) {
        const s = parseInt(params.get('size'));
        if (s >= 10 && s <= 200) { sizeSlider.value = s; sizeValue.value = s; }
      }
      if (params.has('hours')) {
        const h = parseInt(params.get('hours'));
        if (h >= 2 && h <= 40) { hoursSlider.value = h; hoursValue.value = h; }
      }
      if (params.has('rate')) {
        const r = parseInt(params.get('rate'));
        if (r >= 15 && r <= 200) { rateInput.value = r; }
      }
      return true;
    }

    // ================================================================
    // SHARE RESULTS
    // ================================================================
    function shareResults() {
      const url = window.location.href;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(function() {
          showToast();
        });
      } else {
        // Fallback
        const ta = document.createElement('textarea');
        ta.value = url;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        showToast();
      }
    }

    function showToast() {
      const toast = document.getElementById('share-toast');
      toast.style.opacity = '1';
      toast.style.transform = 'translate(-50%, 0)';
      toast.style.pointerEvents = 'auto';
      setTimeout(function() {
        toast.style.opacity = '0';
        toast.style.transform = 'translate(-50%, 20px)';
        toast.style.pointerEvents = 'none';
      }, 3000);
    }

    // ================================================================
    // MOBILE STICKY RESULTS BAR
    // ================================================================
    const mobileBar = document.getElementById('mobile-results-bar');
    const resultsPanel = document.getElementById('results-panel');
    let hasInteracted = false;

    function showMobileBar() {
      hasInteracted = true;
      checkMobileBarVisibility();
    }

    function checkMobileBarVisibility() {
      if (window.innerWidth >= 1024 || !hasInteracted) {
        mobileBar.classList.remove('visible');
        mobileBar.setAttribute('aria-hidden', 'true');
        return;
      }
      // Check if results panel is in viewport
      const rect = resultsPanel.getBoundingClientRect();
      const inView = rect.top < window.innerHeight && rect.bottom > 0;
      if (inView) {
        mobileBar.classList.remove('visible');
        mobileBar.setAttribute('aria-hidden', 'true');
      } else {
        mobileBar.classList.add('visible');
        mobileBar.setAttribute('aria-hidden', 'false');
      }
    }

    window.addEventListener('scroll', checkMobileBarVisibility, { passive: true });
    window.addEventListener('resize', checkMobileBarVisibility, { passive: true });

    // ================================================================
    // ROI REPORT MODAL
    // ================================================================
    let reportTriggerElement = null;

    function openReportModal() {
      reportTriggerElement = document.activeElement;

      // Update org name in modal
      const orgNames = {
        k12: 'K-12 School / District',
        church: 'Church / Mission Org',
        highered: 'Higher Education',
        corporate: 'Corporate / Sports Team',
      };
      document.getElementById('report-org-name').textContent = orgNames[orgSelect.value] || 'organization';

      document.getElementById('report-modal-overlay').classList.remove('hidden');
      document.getElementById('report-modal').classList.remove('hidden');
      document.getElementById('report-modal').classList.add('flex');
      document.getElementById('report-form-state').classList.remove('hidden');
      document.getElementById('report-success-state').classList.add('hidden');
      document.body.style.overflow = 'hidden';

      setTimeout(function() {
        document.getElementById('report-email').focus();
      }, 100);
    }

    function closeReportModal() {
      document.getElementById('report-modal-overlay').classList.add('hidden');
      document.getElementById('report-modal').classList.add('hidden');
      document.getElementById('report-modal').classList.remove('flex');
      document.body.style.overflow = '';
      if (reportTriggerElement) {
        reportTriggerElement.focus();
        reportTriggerElement = null;
      }
    }

    function handleReportSubmit(e) {
      e.preventDefault();
      const email = document.getElementById('report-email').value;
      document.getElementById('report-success-email').textContent = email;
      document.getElementById('report-form-state').classList.add('hidden');
      document.getElementById('report-success-state').classList.remove('hidden');
    }

    // ================================================================
    // KEYBOARD SHORTCUTS
    // ================================================================
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeReportModal();
        closeMenu();
      }
    });

    // ================================================================
    // INITIALIZATION
    // ================================================================
    // Try to load from URL params first
    const hadParams = loadFromURLParams();

    // Initialize all slider fills
    updateSliderFill(tripsSlider);
    updateSliderFill(sizeSlider);
    updateSliderFill(hoursSlider);

    // Compute scenario card savings
    updateScenarioCards();

    // Initial calculation
    calculate();
  </script>
</body>
</html>
