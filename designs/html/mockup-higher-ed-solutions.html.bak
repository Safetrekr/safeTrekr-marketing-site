                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--color-safety-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
