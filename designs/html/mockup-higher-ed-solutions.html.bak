              <tr class="border-t" style="border-color: var(--color-border);">
                <td class="py-4 pr-4 align-top">
                  <div class="flex items-start gap-2">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-muted-foreground)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5 hidden sm:block" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    <span class="text-body-sm" style="color: var(--color-muted-foreground);">
                      <span class="sm:hidden font-semibold block mb-1" style="color: var(--color-foreground);">Without SafeTrekr:</span>
                      Average cost of a single student medical evacuation from Europe: $50,000-$100,000. Average litigation settlement for study abroad incidents: $500K-$2M.
                    </span>
                  </div>
                </td>
                <td class="py-4 pl-4 align-top border-l sm:border-l-0" style="border-color: var(--color-border);">
                  <div class="flex items-start gap-2">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5 hidden sm:block" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="text-body-sm" style="color: var(--color-muted-foreground);">
                      <span class="sm:hidden font-semibold block mb-1" style="color: var(--color-foreground);">With SafeTrekr:</span>
                      $1,250 per program for documented proof your institution conducted independent, professional safety verification.
                    </span>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>

          <div class="mt-6 pt-4 border-t" style="border-color: var(--color-border);">
            <a href="/pricing" class="text-body-sm font-medium inline-flex items-center gap-1" style="color: var(--color-primary-700);">
              View full pricing details
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
