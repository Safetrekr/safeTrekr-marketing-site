    <!-- ──────────────────────────────────────────
         SECTION 5: SAMPLE BINDER PREVIEW
         ────────────────────────────────────────── -->
    <section id="sample-binder" aria-labelledby="binder-preview-heading" style="background: var(--color-primary-50);" class="py-12 sm:py-16 md:py-20 lg:py-24 xl:py-32">
      <div class="max-w-container mx-auto px-5 sm:px-8 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

          <!-- Visual Column (shows first on mobile via order) -->
          <div class="lg:col-span-7 flex justify-center order-first lg:order-last" aria-hidden="true">
            <p class="sr-only">Preview of a Study Abroad Program safety binder showing cover page with destinations, review sections, and analyst verification status.</p>
            <div class="binder-stack" style="min-height: 420px;">
              <!-- Back page -->
              <div class="binder-page binder-page-back" style="top: 20px; left: 20px; right: 20px;">
                <div class="h-4 w-3/4 rounded" style="background: var(--color-border); opacity: 0.5;"></div>
                <div class="h-3 w-1/2 rounded mt-3" style="background: var(--color-border); opacity: 0.3;"></div>
              </div>
              <!-- Middle page -->
              <div class="binder-page binder-page-mid" style="top: 20px; left: 20px; right: 20px;">
                <div class="h-4 w-3/4 rounded" style="background: var(--color-border); opacity: 0.6;"></div>
                <div class="h-3 w-2/3 rounded mt-3" style="background: var(--color-border); opacity: 0.4;"></div>
                <div class="h-3 w-1/2 rounded mt-2" style="background: var(--color-border); opacity: 0.3;"></div>
              </div>
              <!-- Front page -->
              <div class="binder-page binder-page-front" style="top: 20px; left: 20px; right: 20px;">
                <!-- Header -->
                <div class="flex items-center gap-2 mb-3">
                  <svg width="20" height="20" viewBox="0 0 32 32" fill="none"><rect width="32" height="32" rx="6" fill="#3f885b"/><path d="M16 6l8 4v6c0 5.33-3.33 10.33-8 12-4.67-1.67-8-6.67-8-12v-6l8-4z" fill="white" fill-opacity="0.9"/></svg>
                  <span class="text-xs font-medium uppercase tracking-wider" style="color: var(--color-primary-700);">Study Abroad Program</span>
                </div>
                <div class="font-heading text-xl font-bold" style="color: var(--color-foreground);">Safety Binder</div>
                <div class="mt-1 text-sm" style="color: var(--color-muted-foreground);">Barcelona -- Madrid -- Seville</div>
                <div class="mt-1 text-xs" style="color: var(--color-muted-foreground);">September 1 -- December 15, 2026</div>
                <div class="mt-3">
                  <span class="badge badge-brand text-xs">17 Sections Reviewed</span>
                </div>
                <!-- Decorative map thumbnail -->
                <div class="mt-4 rounded-md overflow-hidden" style="height: 60px; background: linear-gradient(135deg, #d4dce0, #bcc8ce); opacity: 0.8;">
                  <svg viewBox="0 0 300 60" fill="none" style="width:100%;height:100%;">
                    <path d="M0 40 Q50 20 100 35 Q150 50 200 30 Q250 10 300 25" stroke="var(--color-primary-400)" stroke-width="2" fill="none" opacity="0.6"/>
