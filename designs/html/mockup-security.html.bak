                <line x1="12" y1="3" x2="12" y2="21"/><polyline points="1 14 12 3 23 14"/><path d="M1 14c0 2.5 4.5 5 5.5 5s5.5-2.5 5.5-5"/><path d="M12 14c0 2.5 4.5 5 5.5 5s5.5-2.5 5.5-5"/>
              </svg>
            </div>
            <p class="text-body-sm font-medium" style="color: var(--color-foreground);">FERPA Alignment</p>
