    <!-- ================================================================ -->
    <!-- SECTION 7: INCIDENT RESPONSE -->
    <!-- ================================================================ -->
    <section style="background: var(--color-card);" aria-labelledby="incident-response-heading">
      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 py-16 sm:py-20 md:py-24 lg:py-32">

        <!-- Centered heading -->
        <div class="max-w-3xl mx-auto text-center">
          <p class="eyebrow mb-4 fade-up">Incident Response</p>
          <h2 id="incident-response-heading" class="text-heading-lg mb-4 lg:mb-6 fade-up" style="color: var(--color-foreground); transition-delay: 80ms;">
            If Something Goes Wrong, We Act Fast.
          </h2>
          <p class="text-body-lg max-w-prose mx-auto mb-10 lg:mb-12 fade-up" style="color: var(--color-muted-foreground); transition-delay: 160ms;">
            We maintain a documented incident response plan that is reviewed quarterly. Here is our commitment to you if a security event occurs.
          </p>
        </div>

        <!-- Vertical timeline -->
        <div class="text-left max-w-2xl mx-auto">
          <ol aria-label="Incident response steps">

            <!-- Step 1 -->
            <li class="flex gap-4 pb-8 card-reveal" style="transition-delay: 240ms;">
              <div class="flex flex-col items-center">
                <div class="h-8 w-8 rounded-full flex items-center justify-center flex-shrink-0 font-heading font-bold text-body-sm" style="background: var(--color-primary-100); color: var(--color-primary-700);" aria-hidden="true">1</div>
                <div class="flex-1 mt-2 ir-connector" style="background: var(--color-border);"></div>
              </div>
              <div class="pt-1">
                <h3 class="text-heading-sm" style="color: var(--color-foreground);">Detection and Assessment</h3>
                <p class="text-body-md mt-1" style="color: var(--color-muted-foreground);">Within 1 hour of becoming aware of a potential security incident, our response team assesses scope and severity.</p>
              </div>
            </li>

            <!-- Step 2 -->
            <li class="flex gap-4 pb-8 card-reveal" style="transition-delay: 360ms;">
              <div class="flex flex-col items-center">
                <div class="h-8 w-8 rounded-full flex items-center justify-center flex-shrink-0 font-heading font-bold text-body-sm" style="background: var(--color-primary-100); color: var(--color-primary-700);" aria-hidden="true">2</div>
                <div class="flex-1 mt-2 ir-connector" style="background: var(--color-border);"></div>
              </div>
              <div class="pt-1">
                <h3 class="text-heading-sm" style="color: var(--color-foreground);">Notification</h3>
                <p class="text-body-md mt-1" style="color: var(--color-muted-foreground);">Affected organizations notified within 72 hours of confirming a data breach, in compliance with applicable regulations including FERPA breach notification requirements.</p>
              </div>
            </li>

            <!-- Step 3 -->
            <li class="flex gap-4 pb-8 card-reveal" style="transition-delay: 480ms;">
              <div class="flex flex-col items-center">
                <div class="h-8 w-8 rounded-full flex items-center justify-center flex-shrink-0 font-heading font-bold text-body-sm" style="background: var(--color-primary-100); color: var(--color-primary-700);" aria-hidden="true">3</div>
                <div class="flex-1 mt-2 ir-connector" style="background: var(--color-border);"></div>
              </div>
              <div class="pt-1">
                <h3 class="text-heading-sm" style="color: var(--color-foreground);">Containment and Remediation</h3>
                <p class="text-body-md mt-1" style="color: var(--color-muted-foreground);">Immediate steps to contain the incident, followed by root cause analysis and system hardening to prevent recurrence.</p>
              </div>
            </li>

            <!-- Step 4 -->
            <li class="flex gap-4 card-reveal" style="transition-delay: 600ms;">
              <div class="flex flex-col items-center">
                <div class="h-8 w-8 rounded-full flex items-center justify-center flex-shrink-0 font-heading font-bold text-body-sm" style="background: var(--color-primary-100); color: var(--color-primary-700);" aria-hidden="true">4</div>
              </div>
              <div class="pt-1">
                <h3 class="text-heading-sm" style="color: var(--color-foreground);">Post-Incident Report</h3>
                <p class="text-body-md mt-1" style="color: var(--color-muted-foreground);">Written report provided to all affected organizations detailing what happened, what data was involved, what actions we took, and what changes we implemented.</p>
              </div>
            </li>

          </ol>

          <!-- Contact -->
          <div class="text-center mt-10 pt-8 fade-up" style="border-top: 1px solid var(--color-border); transition-delay: 700ms;">
            <p class="text-body-sm" style="color: var(--color-muted-foreground);">Report a security concern:</p>
            <a href="mailto:security@safetrekr.com" class="text-body-md font-medium hover:underline" style="color: var(--color-primary-700);">security@safetrekr.com</a>
          </div>
        </div>

      </div>
    </section>


