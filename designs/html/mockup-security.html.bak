          <!-- Milestone 1 -->
          <li class="flex gap-4 card-reveal" style="transition-delay: 280ms;">
            <div class="flex-shrink-0 h-10 w-10 rounded-full flex items-center justify-center" style="background: var(--color-primary-400); color: var(--color-secondary);" aria-label="Status: Complete">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
