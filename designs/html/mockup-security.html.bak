        <!-- Centered heading -->
        <div class="text-center">
          <p class="eyebrow mb-4 fade-up">Infrastructure</p>
          <h2 id="infrastructure-heading" class="text-heading-lg mb-4 lg:mb-6 fade-up" style="color: var(--color-foreground); transition-delay: 80ms;">
            Built on Trusted Platforms
          </h2>
          <p class="text-body-lg max-w-prose mx-auto mb-10 lg:mb-12 fade-up" style="color: var(--color-muted-foreground); transition-delay: 160ms;">
            We chose infrastructure partners with proven security track records, not the cheapest option.
          </p>
        </div>

        <!-- 3-column card grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

          <!-- DigitalOcean -->
          <div class="rounded-xl border p-6 lg:p-8 text-center transition-all duration-200 hover:-translate-y-0.5 card-reveal" style="background: var(--color-card); border-color: var(--color-border); box-shadow: var(--shadow-sm); transition-delay: 240ms;">
            <div class="mx-auto h-12 w-12 rounded-lg flex items-center justify-center mb-4" style="background: var(--color-primary-50);">
              <!-- Cloud icon for DigitalOcean -->
              <svg class="h-6 w-6" style="color: var(--color-primary-700);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>
              </svg>
            </div>
            <h3 class="text-heading-sm mb-3" style="color: var(--color-foreground);">DigitalOcean</h3>
            <p class="text-body-sm mb-4" style="color: var(--color-muted-foreground);">
              Application hosting and file storage. Docker containers orchestrated via DOKS (managed Kubernetes). US-East region. SOC 2 Type II certified.
            </p>
            <span class="badge badge-brand" aria-label="SOC 2 Type II certified">SOC 2 Type II</span>
          </div>

          <!-- Supabase -->
          <div class="rounded-xl border p-6 lg:p-8 text-center transition-all duration-200 hover:-translate-y-0.5 card-reveal" style="background: var(--color-card); border-color: var(--color-border); box-shadow: var(--shadow-sm); transition-delay: 320ms;">
            <div class="mx-auto h-12 w-12 rounded-lg flex items-center justify-center mb-4" style="background: var(--color-primary-50);">
              <!-- Database icon for Supabase -->
              <svg class="h-6 w-6" style="color: var(--color-primary-700);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
              </svg>
            </div>
            <h3 class="text-heading-sm mb-3" style="color: var(--color-foreground);">Supabase</h3>
            <p class="text-body-sm mb-4" style="color: var(--color-muted-foreground);">
              Database and authentication. PostgreSQL with row-level security policies. Real-time subscriptions for monitoring. US-hosted instances. SOC 2 Type II certified.
            </p>
            <span class="badge badge-brand" aria-label="SOC 2 Type II certified">SOC 2 Type II</span>
          </div>

          <!-- Cloudflare -->
          <div class="rounded-xl border p-6 lg:p-8 text-center transition-all duration-200 hover:-translate-y-0.5 card-reveal" style="background: var(--color-card); border-color: var(--color-border); box-shadow: var(--shadow-sm); transition-delay: 400ms;">
            <div class="mx-auto h-12 w-12 rounded-lg flex items-center justify-center mb-4" style="background: var(--color-primary-50);">
              <!-- Globe icon for Cloudflare -->
              <svg class="h-6 w-6" style="color: var(--color-primary-700);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
            </div>
            <h3 class="text-heading-sm mb-3" style="color: var(--color-foreground);">Cloudflare</h3>
            <p class="text-body-sm mb-4" style="color: var(--color-muted-foreground);">
              CDN, DDoS protection, SSL/TLS termination, and Web Application Firewall. Global edge network. No PII cached at edge nodes. SOC 2 Type II certified.
