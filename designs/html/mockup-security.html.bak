            <!-- Milestone 2: FERPA / COPPA Alignment - Complete -->
            <li class="text-center relative card-reveal" style="transition-delay: 400ms;">
              <div class="mx-auto h-10 w-10 rounded-full flex items-center justify-center mb-4 relative z-10" style="background: var(--color-primary-400); color: var(--color-secondary);" aria-label="Status: Complete">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h3 class="text-heading-sm mb-2" style="color: #f7f8f8;">FERPA / COPPA Alignment</h3>
              <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium mb-3" style="background: rgba(76,164,110,0.15); color: var(--color-primary-400);">
                <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Designed for compliance
              </span>
              <p class="text-body-sm" style="color: #b8c3c7;">Platform designed with FERPA and COPPA requirements in mind. Architecture review complete. Formal certification pending.</p>
            </li>

            <!-- Milestone 3: SOC 2 Type I - In Progress -->
            <li class="text-center relative card-reveal" style="transition-delay: 520ms;">
              <div class="mx-auto h-10 w-10 rounded-full flex items-center justify-center mb-4 relative z-10" style="border: 2px solid var(--color-primary-400); background: transparent;" aria-label="Status: In Progress">
                <span class="h-2.5 w-2.5 rounded-full pulse-dot" style="background: var(--color-primary-400);"></span>
              </div>
              <h3 class="text-heading-sm mb-2" style="color: #f7f8f8;">SOC 2 Type I</h3>
              <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium mb-3" style="background: rgba(76,164,110,0.1); color: var(--color-primary-400);">
                Audit began Q1 2026
              </span>
              <p class="text-body-sm" style="color: #b8c3c7;">SOC 2 Type I audit covering Security, Availability, and Confidentiality trust service criteria. Report expected Q2 2026.</p>
            </li>

            <!-- Milestone 4: SOC 2 Type II - Planned -->
            <li class="text-center relative card-reveal" style="transition-delay: 640ms;">
              <div class="mx-auto h-10 w-10 rounded-full flex items-center justify-center mb-4 relative z-10" style="border: 2px solid rgba(255,255,255,0.15); background: transparent;" aria-label="Status: Planned">
              </div>
              <h3 class="text-heading-sm mb-2" style="color: #f7f8f8;">SOC 2 Type II</h3>
              <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium mb-3" style="background: rgba(255,255,255,0.08); color: #b8c3c7;">
                Target: Q4 2026
              </span>
