            <p class="text-xs mt-1" style="color: var(--color-muted-foreground);">In transit</p>
          </div>

          <!-- 3. SHA-256 Hash Chain -->
          <div class="rounded-xl border p-5 text-center transition-all duration-150 hover:-translate-y-px card-reveal" style="background: var(--color-card); border-color: var(--color-border); box-shadow: var(--shadow-sm); transition-delay: 280ms;">
            <div class="mx-auto h-10 w-10 rounded-full flex items-center justify-center mb-3" style="background: var(--color-primary-50);">
              <svg class="h-5 w-5" style="color: var(--color-primary-700);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/>
              </svg>
            </div>
            <p class="text-body-sm font-medium" style="color: var(--color-foreground);">SHA-256 Hash Chain</p>
            <p class="text-xs mt-1" style="color: var(--color-muted-foreground);">Evidence integrity</p>
          </div>

          <!-- 4. Student Privacy Pledge -->
          <div class="rounded-xl border p-5 text-center transition-all duration-150 hover:-translate-y-px card-reveal" style="background: var(--color-card); border-color: var(--color-border); box-shadow: var(--shadow-sm); transition-delay: 340ms;">
            <div class="mx-auto h-10 w-10 rounded-full flex items-center justify-center mb-3" style="background: var(--color-primary-50);">
              <!-- GraduationCap icon -->
              <svg class="h-5 w-5" style="color: var(--color-primary-700);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </div>
            <p class="text-body-sm font-medium" style="color: var(--color-foreground);">Student Privacy Pledge</p>
            <p class="text-xs mt-1" style="color: var(--color-muted-foreground);">Signed 2024</p>
          </div>

          <!-- 5. SOC 2 Type I -->
          <div class="rounded-xl border p-5 text-center transition-all duration-150 hover:-translate-y-px card-reveal" style="background: var(--color-card); border-color: var(--color-border); box-shadow: var(--shadow-sm); transition-delay: 400ms;" aria-label="SOC 2 Type I: Audit in progress">
            <div class="mx-auto h-10 w-10 rounded-full flex items-center justify-center mb-3" style="background: var(--color-primary-50);">
              <svg class="h-5 w-5" style="color: var(--color-primary-700);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15l2 2 4-4"/>
              </svg>
            </div>
            <p class="text-body-sm font-medium" style="color: var(--color-foreground);">SOC 2 Type I</p>
            <p class="text-xs mt-1" style="color: var(--color-muted-foreground);">In progress</p>
          </div>

          <!-- 6. FERPA Alignment -->
          <div class="rounded-xl border p-5 text-center transition-all duration-150 hover:-translate-y-px card-reveal" style="background: var(--color-card); border-color: var(--color-border); box-shadow: var(--shadow-sm); transition-delay: 460ms;">
            <div class="mx-auto h-10 w-10 rounded-full flex items-center justify-center mb-3" style="background: var(--color-primary-50);">
              <!-- Scale icon -->
