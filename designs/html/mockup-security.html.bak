            <div class="mx-auto h-10 w-10 rounded-full flex items-center justify-center mb-3" style="background: var(--color-primary-50);">
              <svg class="h-5 w-5" style="color: var(--color-primary-700);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>
              </svg>
            </div>
            <p class="text-body-sm font-medium" style="color: var(--color-foreground);">US Data Centers</p>
            <p class="text-xs mt-1" style="color: var(--color-muted-foreground);">All data US-hosted</p>
          </div>

          <!-- 8. COPPA Alignment -->
          <div class="rounded-xl border p-5 text-center transition-all duration-150 hover:-translate-y-px card-reveal" style="background: var(--color-card); border-color: var(--color-border); box-shadow: var(--shadow-sm); transition-delay: 580ms;">
            <div class="mx-auto h-10 w-10 rounded-full flex items-center justify-center mb-3" style="background: var(--color-primary-50);">
              <!-- Baby/child icon -->
              <svg class="h-5 w-5" style="color: var(--color-primary-700);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
