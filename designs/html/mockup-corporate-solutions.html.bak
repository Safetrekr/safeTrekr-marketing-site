    <!-- ──────────────────────────────────────────
         SECTION 5: SAMPLE BINDER PREVIEW
         ────────────────────────────────────────── -->
    <section id="sample-binder" aria-labelledby="binder-preview-heading" style="background: var(--color-primary-50);" class="py-12 sm:py-16 md:py-20 lg:py-24 xl:py-32">
      <div class="max-w-container mx-auto px-5 sm:px-8 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

          <!-- Visual Column (shown first on mobile, second on desktop) -->
          <div class="lg:col-span-7 flex justify-center lg:order-2">
            <div class="binder-stack" style="height: 400px;" aria-hidden="true">
