  </footer>

  <!-- Responsive adjustments via inline style (supplement to design-tokens.css) -->
  <style>
    /* Hover states for nav items */
    .nav-item:hover { color: var(--color-foreground) !important; }

    /* Hover states for filter pills */
    .filter-bar-sticky a:not([aria-current]):hover {
      background: var(--color-card) !important;
      color: var(--color-foreground) !important;
    }

    /* Hover states for pagination */
    nav[aria-label="Blog pagination"] a:not([aria-current]):hover {
      background: var(--color-card);
    }

    /* Footer link hover */
    footer a:hover { color: #ffffff !important; }

    /* Card hover shadow upgrade */
    .group:hover > div:first-child {
      box-shadow: var(--shadow-md);
    }

    /* Featured post card hover */
    section[aria-labelledby="featured-post-heading"] .group:hover > div {
      box-shadow: var(--shadow-md);
    }

    /* Responsive hero padding */
    @media (max-width: 639px) {
      section[aria-labelledby="blog-hero-heading"] { padding-top: 48px !important; padding-bottom: 32px !important; }
      section[aria-labelledby="featured-post-heading"] { padding-bottom: 32px !important; }
      section[aria-labelledby="posts-heading"] { padding-top: 32px !important; padding-bottom: 48px !important; }
      section[aria-labelledby="newsletter-heading"] { padding: 48px 0 !important; }
      section[aria-labelledby="cta-binder-heading"] { padding: 32px 0 !important; }
    }
    @media (min-width: 640px) and (max-width: 767px) {
      section[aria-labelledby="blog-hero-heading"] { padding-top: 64px !important; padding-bottom: 40px !important; }
      section[aria-labelledby="featured-post-heading"] { padding-bottom: 40px !important; }
      section[aria-labelledby="posts-heading"] { padding-top: 40px !important; padding-bottom: 64px !important; }
      section[aria-labelledby="newsletter-heading"] { padding: 64px 0 !important; }
      section[aria-labelledby="cta-binder-heading"] { padding: 40px 0 !important; }
    }
    @media (min-width: 768px) and (max-width: 1023px) {
      section[aria-labelledby="blog-hero-heading"] { padding-top: 80px !important; padding-bottom: 48px !important; }
      section[aria-labelledby="featured-post-heading"] { padding-bottom: 48px !important; }
      section[aria-labelledby="posts-heading"] { padding-top: 48px !important; padding-bottom: 80px !important; }
      section[aria-labelledby="newsletter-heading"] { padding: 80px 0 !important; }
      section[aria-labelledby="cta-binder-heading"] { padding: 48px 0 !important; }
    }

    /* Mobile container padding */
    @media (max-width: 639px) {
      .container { padding-left: 20px !important; padding-right: 20px !important; }
    }
    @media (min-width: 640px) and (max-width: 1023px) {
      .container { padding-left: 32px !important; padding-right: 32px !important; }
    }
    @media (min-width: 1024px) {
      .container { padding-left: 48px !important; padding-right: 48px !important; }
    }

    /* Mobile header height */
    @media (max-width: 1023px) {
      header > div { height: 56px !important; }
      .filter-bar-sticky { top: 56px !important; }
    }

    /* Sample Binder CTA responsive padding */
    @media (min-width: 640px) {
      section[aria-labelledby="cta-binder-heading"] .flex > div:last-of-type ~ a,
      section[aria-labelledby="cta-binder-heading"] > div > div {
        padding: 32px;
      }
    }

    /* Newsletter Privacy link hover */
    section[aria-labelledby="newsletter-heading"] a:hover { text-decoration: underline; }
  </style>

</body>
</html>