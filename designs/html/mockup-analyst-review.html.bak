              <svg class="w-7 h-7" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15l2 2 4-4"/></svg>
            </div>
            <h3 class="text-heading-md mb-2" style="color: var(--color-foreground); font-weight: 600;">Receive Your Binder</h3>
