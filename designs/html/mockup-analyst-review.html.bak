              <span class="text-body-sm hidden lg:block" style="color: var(--color-muted-foreground);">Sections 5-7</span>
            </div>
            <div>
              <!-- Section 5: Air Travel -->
              <div class="border-b" style="border-color: var(--color-border);">
                <button class="accordion-trigger w-full px-6 lg:px-8 py-4 flex items-center gap-4 cursor-pointer transition-colors" aria-expanded="false" aria-controls="section-5-content" id="section-5-trigger" onclick="toggleSection(5)">
                  <span class="h-7 w-7 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-semibold" style="background: var(--color-primary-50); color: var(--color-primary-700); font-family: var(--font-heading);">5</span>
                  <svg class="w-5 h-5 flex-shrink-0" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
                  <span class="flex-1 text-left text-body-lg font-medium" style="color: var(--color-foreground);">Air Travel</span>
                  <svg class="accordion-chevron w-5 h-5 flex-shrink-0" style="color: var(--color-muted-foreground);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" id="chevron-5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="accordion-content" id="section-5-content" role="region" aria-labelledby="section-5-trigger">
