          <div role="listitem" class="flex gap-4 items-start">
            <div class="h-12 w-12 rounded-xl flex-shrink-0 flex items-center justify-center" style="background: var(--color-primary-50); border: 2px solid var(--color-primary-200);">
              <svg class="w-6 h-6" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
