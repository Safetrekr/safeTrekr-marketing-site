    <!-- ================================================================
         SECTION 7: COMPARISON TABLE
         ================================================================ -->
    <section id="comparison" aria-labelledby="comparison-heading" style="background: var(--color-background); padding: 96px 0;">
      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12">

        <div class="text-center mb-16">
          <span class="text-eyebrow block mb-4" style="color: var(--color-primary-700);">WHY AN ANALYST</span>
          <h2 id="comparison-heading" class="text-display-md mb-4" style="color: var(--color-foreground); max-width: 28ch; margin: 0 auto;">
            Professional Review vs. DIY Checklists.
          </h2>
          <p class="text-body-lg mx-auto" style="color: var(--color-muted-foreground); max-width: 65ch;">
            See what you gain when a trained analyst reviews your trip instead of relying on a self-serve checklist.
          </p>
        </div>

        <!-- Desktop Table -->
        <div class="hidden lg:block max-w-4xl mx-auto rounded-xl overflow-hidden comparison-table" style="background: var(--color-card); border: 1px solid var(--color-border); box-shadow: var(--shadow-sm);" role="region" aria-label="Feature comparison table">
          <table class="w-full">
            <thead>
              <tr style="background: var(--color-primary-50); border-bottom: 1px solid var(--color-border);">
