                <th scope="col" class="text-left px-6 py-4 text-heading-sm" style="color: var(--color-primary-700); font-weight: 600;">SafeTrekr Analyst Review</th>
                <th scope="col" class="text-left px-6 py-4 text-heading-sm" style="color: var(--color-muted-foreground); font-weight: 600;">DIY Checklist</th>
              </tr>
            </thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--color-border);" class="hover:bg-primary-50/30 transition-colors">
