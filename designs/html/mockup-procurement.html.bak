  <!-- ================================================================== -->
  <!-- SCRIPTS                                                             -->
  <!-- ================================================================== -->
  <script>
    // ── Intersection Observer for fade-up and card-reveal animations ──
    (function() {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReducedMotion) {
        document.querySelectorAll('.fade-up, .card-reveal').forEach(el => el.classList.add('visible'));
        document.querySelectorAll('.route-path').forEach(el => el.classList.add('drawn'));
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const targets = entry.target.classList.contains('fade-up') || entry.target.classList.contains('card-reveal')
              ? [entry.target]
              : entry.target.querySelectorAll('.fade-up, .card-reveal');

            targets.forEach(el => {
              el.classList.add('visible');
            });

            // Handle route path drawing
            const paths = entry.target.querySelectorAll('.route-path');
            paths.forEach(p => p.classList.add('drawn'));

            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.2,
        rootMargin: '0px 0px -50px 0px'
      });

      document.querySelectorAll('.fade-up, .card-reveal').forEach(el => observer.observe(el));

      // Observe the route divider container
      const routeContainer = document.querySelector('.route-path');
      if (routeContainer) {
        observer.observe(routeContainer.closest('div'));
      }
    })();

    // ── Header scroll behavior ──
    (function() {
      const header = document.querySelector('.site-header');

      function onScroll() {
        const scrollY = window.scrollY;
        if (scrollY > 100) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();

    // ── Mobile menu toggle ──
    function toggleMobileMenu() {
      const menu = document.getElementById('mobile-menu');
      const overlay = document.getElementById('mobile-overlay');
      const toggle = document.getElementById('menu-toggle');
      const hamburger = toggle.querySelector('.hamburger-icon');
      const closeIcon = toggle.querySelector('.close-icon');

      const isOpen = menu.classList.contains('open');

      if (isOpen) {
        menu.classList.remove('open');
        overlay.classList.remove('open');
        hamburger.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      } else {
        menu.classList.add('open');
        overlay.classList.add('open');
        hamburger.classList.add('hidden');
        closeIcon.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }
    }

    // ── FAQ Accordion toggle ──
    function toggleFaq(trigger) {
      const answer = trigger.nextElementSibling;
      const chevron = trigger.querySelector('.faq-chevron');
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

      // Close all other FAQ items (single-expand behavior)
      document.querySelectorAll('.faq-trigger').forEach(t => {
        if (t !== trigger) {
          t.setAttribute('aria-expanded', 'false');
          t.nextElementSibling.classList.remove('open');
          t.querySelector('.faq-chevron').classList.remove('rotated');
        }
      });

      // Toggle current item
      if (isExpanded) {
        trigger.setAttribute('aria-expanded', 'false');
        answer.classList.remove('open');
        chevron.classList.remove('rotated');
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        answer.classList.add('open');
        chevron.classList.add('rotated');
      }
    }

    // ── Procurement form submission ──
    (function() {
      const form = document.getElementById('procurement-form');
      const successEl = document.getElementById('form-success');

      if (!form) return;

      form.addEventListener('submit', function(e) {
        e.preventDefault();

        // Check honeypot
        const honeypot = form.querySelector('[name="website"]');
        if (honeypot && honeypot.value) return;

        // Basic validation
        const name = form.querySelector('[name="fullName"]');
        const email = form.querySelector('[name="workEmail"]');
        const org = form.querySelector('[name="organization"]');
        const subject = form.querySelector('[name="subject"]');

        let valid = true;

        // Clear previous errors
        form.querySelectorAll('.field-error').forEach(el => el.remove());
        form.querySelectorAll('.input').forEach(el => {
          el.style.borderColor = '';
        });

        function showError(field, message) {
          field.style.borderColor = 'var(--color-destructive)';
          const err = document.createElement('p');
          err.className = 'field-error text-body-sm mt-1';
          err.style.color = 'var(--color-destructive)';
          err.style.fontSize = '12px';
          err.textContent = message;
          err.setAttribute('role', 'alert');
          field.parentNode.appendChild(err);
          valid = false;
        }

        if (!name.value || name.value.length < 2) {
          showError(name, 'Please enter your full name.');
        }

        if (!email.value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
          showError(email, 'Please enter a valid email address.');
        }

        if (!org.value || org.value.length < 2) {
          showError(org, 'Please enter your organization name.');
        }

        if (!subject.value) {
          showError(subject, 'Please select a topic.');
        }

        if (!valid) return;

        // Show success state
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
      });
    })();
  </script>

</body>
</html>
