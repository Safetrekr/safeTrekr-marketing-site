  <!-- ===== JAVASCRIPT ===== -->
  <script>
    // Initialize Lucide icons
    lucide.createIcons();

    // ── DOM References ──
    const step1 = document.getElementById('step-1');
    const step2 = document.getElementById('step-2');
    const form = document.getElementById('demo-form');
    const formCard = document.getElementById('form-card');
    const successState = document.getElementById('success-state');
    const continueBtn = document.getElementById('continue-btn');
    const backBtn = document.getElementById('back-btn');
    const submitBtn = document.getElementById('submit-btn');
    const submitLabel = document.getElementById('submit-label');
    const submitIcon = document.getElementById('submit-icon');
    const submitSpinner = document.getElementById('submit-spinner');
    const charCounter = document.getElementById('char-counter');
    const messageField = document.getElementById('message');
    const errorBanner = document.getElementById('error-banner');
    const stepAnnouncer = document.getElementById('step-announcer');

    // Sidebar elements
    const sidebarExpect = document.getElementById('sidebar-expect');
    const sidebarThankYou = document.getElementById('sidebar-thank-you');
    const sidebarHeading = document.getElementById('sidebar-heading');
    const sidebarList = document.getElementById('sidebar-list');

    // Success state elements
    const successEmail = document.getElementById('success-email');
    const successOrgType = document.getElementById('success-org-type');
    const successFormat = document.getElementById('success-format');

    // Mobile nav
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');

    // Header
    const siteHeader = document.getElementById('site-header');

    // ── Field validation rules ──
    const validationRules = {
      email: {
        required: true,
        validate: (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v),
        message: 'Please enter a valid work email.',
      },
      organizationName: {
        required: true,
        validate: (v) => v.trim().length >= 2,
        message: 'Organization name is required.',
      },
      fullName: {
        required: true,
        validate: (v) => v.trim().length >= 2,
        message: 'Please enter your full name.',
      },
      organizationType: {
        required: true,
        validate: (v) => v !== '',
        message: 'Please select an organization type.',
      },
      estimatedTrips: {
        required: true,
        validate: (v) => v !== '',
        message: 'Please select an estimated trip range.',
      },
      demoFormat: {
        required: true,
        validate: (v) => v !== '',
        message: 'Please select a demo format.',
      },
      message: {
        required: false,
        validate: (v) => v.length <= 500,
        message: 'Message must be under 500 characters.',
      },
    };

    // Track which fields have been touched
    const touchedFields = new Set();

    // ── Validation helpers ──
    function showFieldError(fieldId, message) {
      const field = document.getElementById(fieldId);
      const errorEl = document.getElementById(fieldId + '-error');
      if (field) field.classList.add('field-error');
      if (field) field.setAttribute('aria-describedby', fieldId + '-error');
      if (errorEl) {
        errorEl.classList.remove('hidden');
        errorEl.classList.add('flex');
        const span = errorEl.querySelector('span');
        if (span) span.textContent = message;
      }
    }

    function clearFieldError(fieldId) {
      const field = document.getElementById(fieldId);
      const errorEl = document.getElementById(fieldId + '-error');
      if (field) field.classList.remove('field-error');
      if (field) field.removeAttribute('aria-describedby');
      if (errorEl) {
        errorEl.classList.add('hidden');
        errorEl.classList.remove('flex');
      }
    }

    function validateField(fieldId) {
      const field = document.getElementById(fieldId);
      const rule = validationRules[fieldId];
      if (!field || !rule) return true;
      const value = field.value;
      if (rule.required && (!value || !rule.validate(value))) {
        showFieldError(fieldId, rule.message);
        return false;
      }
      if (!rule.required && value && !rule.validate(value)) {
        showFieldError(fieldId, rule.message);
        return false;
      }
      clearFieldError(fieldId);
      return true;
    }

    // ── Field event listeners for validation ──
    const allFields = ['email', 'organizationName', 'fullName', 'organizationType', 'estimatedTrips', 'demoFormat', 'message'];
    allFields.forEach((fieldId) => {
      const field = document.getElementById(fieldId);
      if (!field) return;

      // On blur: mark as touched, validate
      field.addEventListener('blur', () => {
        touchedFields.add(fieldId);
        validateField(fieldId);
      });

      // On change/input: validate if already touched
      const eventType = field.tagName === 'SELECT' ? 'change' : 'input';
      field.addEventListener(eventType, () => {
        if (touchedFields.has(fieldId)) {
          validateField(fieldId);
        }
      });
    });

    // ── Character counter ──
    messageField.addEventListener('input', () => {
      const len = messageField.value.length;
      charCounter.textContent = len + ' / 500';
      if (len >= 500) {
        charCounter.style.color = 'var(--color-destructive)';
      } else if (len > 450) {
        charCounter.style.color = '#ca8a04';
      } else {
        charCounter.style.color = 'var(--color-muted-foreground)';
      }
    });

    // ── Step 1 -> Step 2 transition ──
    continueBtn.addEventListener('click', () => {
      // Mark step 1 fields as touched
      touchedFields.add('email');
      touchedFields.add('organizationName');

      const emailValid = validateField('email');
      const orgValid = validateField('organizationName');

      if (!emailValid || !orgValid) {
        const firstError = !emailValid ? 'email' : 'organizationName';
        document.getElementById(firstError).focus();
        return;
      }

      // Hide step 1, show step 2
      step1.style.opacity = '0';
      step1.style.transition = 'opacity 200ms ease';
      setTimeout(() => {
        step1.classList.add('hidden');
        step2.classList.remove('hidden');
        step2.style.opacity = '0';
        step2.style.transform = 'translateY(16px)';
        requestAnimationFrame(() => {
          step2.style.transition = 'opacity 300ms ease, transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1)';
          step2.style.opacity = '1';
          step2.style.transform = 'translateY(0)';
        });
        // Focus the first field in step 2
        setTimeout(() => {
          document.getElementById('fullName').focus();
        }, 100);
        // Announce step change
        stepAnnouncer.textContent = 'Step 2 of 2: Tell Us More. Please provide additional details.';
      }, 200);
    });

    // ── Step 2 -> Step 1 (back) ──
    backBtn.addEventListener('click', () => {
      step2.style.opacity = '0';
      step2.style.transition = 'opacity 200ms ease';
      setTimeout(() => {
        step2.classList.add('hidden');
        step1.classList.remove('hidden');
        step1.style.opacity = '0';
        step1.style.transform = 'translateY(16px)';
        requestAnimationFrame(() => {
          step1.style.transition = 'opacity 300ms ease, transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1)';
          step1.style.opacity = '1';
          step1.style.transform = 'translateY(0)';
        });
        // Focus email field
        setTimeout(() => {
          document.getElementById('email').focus();
        }, 100);
        stepAnnouncer.textContent = 'Step 1 of 2: Basic Info.';
      }, 200);
    });

    // ── Form submission ──
    form.addEventListener('submit', (e) => {
      e.preventDefault();

      // Mark all fields as touched
      allFields.forEach((f) => touchedFields.add(f));

      // Validate all fields
      const step1Fields = ['email', 'organizationName'];
      const step2Fields = ['fullName', 'organizationType', 'estimatedTrips', 'demoFormat', 'message'];
      let allValid = true;
      let firstErrorField = null;

      [...step1Fields, ...step2Fields].forEach((fieldId) => {
        const isValid = validateField(fieldId);
        if (!isValid && !firstErrorField) {
          firstErrorField = fieldId;
        }
        if (!isValid) allValid = false;
      });

      if (!allValid) {
        if (firstErrorField) {
          document.getElementById(firstErrorField).focus();
        }
        return;
      }

      // Check honeypot
      const honeypot = document.getElementById('website');
      if (honeypot && honeypot.value) {
        // Silently show success (bot trap)
        showSuccessState();
        return;
      }

      // Set loading state
      submitBtn.setAttribute('aria-busy', 'true');
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.7';
      submitBtn.style.pointerEvents = 'none';
      submitLabel.textContent = 'Submitting...';
      submitIcon.classList.add('hidden');
      submitSpinner.classList.remove('hidden');

      // Simulate submission (in a real app this would be a Server Action)
      setTimeout(() => {
        showSuccessState();
      }, 1500);
    });

    // ── Success state ──
    function showSuccessState() {
      // Populate dynamic content
      const emailVal = document.getElementById('email').value;
      const orgTypeSelect = document.getElementById('organizationType');
      const orgTypeText = orgTypeSelect.options[orgTypeSelect.selectedIndex]?.text || 'your organization';
      const demoFormatSelect = document.getElementById('demoFormat');
      const demoFormatText = demoFormatSelect.options[demoFormatSelect.selectedIndex]?.text || 'demo';

      successEmail.textContent = emailVal;
      successOrgType.textContent = orgTypeText;
      successFormat.textContent = demoFormatText;

      // Transition form out
      form.style.opacity = '0';
      form.style.transition = 'opacity 200ms ease';
      setTimeout(() => {
        form.classList.add('hidden');
        successState.classList.remove('hidden');
        successState.style.opacity = '0';
        successState.style.transform = 'translateY(20px)';
        requestAnimationFrame(() => {
          successState.style.transition = 'opacity 400ms cubic-bezier(0.34, 1.56, 0.64, 1), transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1)';
          successState.style.opacity = '1';
          successState.style.transform = 'translateY(0)';
        });
      }, 200);

      // Update sidebar
      sidebarExpect.classList.add('hidden');
      sidebarThankYou.classList.remove('hidden');

      // Scroll to top of form card
      formCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // ── Error banner ──
    function showErrorBanner(headline, detail) {
      const bannerHeadline = document.getElementById('error-banner-headline');
      const bannerDetail = document.getElementById('error-banner-detail');
      bannerHeadline.textContent = headline;
      bannerDetail.textContent = detail;
      errorBanner.classList.remove('hidden');
      errorBanner.classList.add('flex');
      errorBanner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function hideErrorBanner() {
      errorBanner.classList.add('hidden');
      errorBanner.classList.remove('flex');
    }

    // ── Header scroll behavior ──
    let lastScrollY = 0;
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      if (scrollY > 100) {
        siteHeader.classList.add('header-scrolled');
      } else {
        siteHeader.classList.remove('header-scrolled');
      }
      lastScrollY = scrollY;
    }, { passive: true });

    // ── Mobile menu ──
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.remove('hidden');
      mobileMenuBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      // Focus close button
      setTimeout(() => mobileMenuClose.focus(), 100);
    });

    function closeMobileMenu() {
      mobileMenu.classList.add('hidden');
      mobileMenuBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      mobileMenuBtn.focus();
    }

    mobileMenuClose.addEventListener('click', closeMobileMenu);
    mobileMenuOverlay.addEventListener('click', closeMobileMenu);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
        closeMobileMenu();
      }
    });
  </script>
</body>
</html>