                                style="background: var(--color-primary-100); color: var(--color-primary-700);">3</span>
                          <p class="text-body-md pt-1" style="color: var(--color-muted-foreground);">
                            Your <strong id="success-format" class="font-medium" style="color: var(--color-foreground);">demo</strong> will take about 30 minutes.
                          </p>
                        </li>
                      </ol>
                    </div>

                    <!-- CTAs -->
