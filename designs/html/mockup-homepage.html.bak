              </a>
              <a href="/how-it-works#safety-binder" class="inline-flex items-center justify-center gap-2 font-semibold rounded-md transition-all duration-150 text-center" style="font-family: var(--font-heading); background: transparent; border: 1.5px solid rgba(255,255,255,0.2); color: #f7f8f8; padding: 16px 32px; font-size: 18px; border-radius: var(--radius-md); text-decoration: none;">
                See What's Inside
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            </div>
          </div>

