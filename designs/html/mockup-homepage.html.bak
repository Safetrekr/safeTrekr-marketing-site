<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SafeTrekr - Every Trip Professionally Reviewed</title>
  <meta name="description" content="Professional trip safety review and evidence documentation platform. SafeTrekr combines government intelligence, analyst review, and tamper-evident documentation to protect your travelers.">
  <link rel="stylesheet" href="design-tokens.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            background: 'var(--color-background)',
            foreground: 'var(--color-foreground)',
            card: 'var(--color-card)',
            'card-foreground': 'var(--color-card-foreground)',
            border: 'var(--color-border)',
            input: 'var(--color-input)',
            ring: 'var(--color-ring)',
            muted: 'var(--color-muted)',
            'muted-foreground': 'var(--color-muted-foreground)',
            accent: 'var(--color-accent)',
            'accent-foreground': 'var(--color-accent-foreground)',
            primary: {
              50: 'var(--color-primary-50)',
              100: 'var(--color-primary-100)',
              200: 'var(--color-primary-200)',
              300: 'var(--color-primary-300)',
              400: 'var(--color-primary-400)',
              500: 'var(--color-primary-500)',
              600: 'var(--color-primary-600)',
              700: 'var(--color-primary-700)',
              800: 'var(--color-primary-800)',
              900: 'var(--color-primary-900)',
              950: 'var(--color-primary-950)',
              DEFAULT: 'var(--color-primary)',
            },
            secondary: {
              DEFAULT: 'var(--color-secondary)',
              foreground: 'var(--color-secondary-foreground)',
              light: 'var(--color-secondary-light)',
              muted: 'var(--color-secondary-muted)',
            },
            destructive: {
              DEFAULT: 'var(--color-destructive)',
              foreground: 'var(--color-destructive-foreground)',
            },
            safety: {
              green: 'var(--color-safety-green)',
              yellow: 'var(--color-safety-yellow)',
              red: 'var(--color-safety-red)',
            },
          },
          fontFamily: {
            display: ['Plus Jakarta Sans', 'system-ui', '-apple-system', 'sans-serif'],
            body: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
            mono: ['JetBrains Mono', 'ui-monospace', 'monospace'],
          },
          borderRadius: {
            sm: 'var(--radius-sm)',
            md: 'var(--radius-md)',
            lg: 'var(--radius-lg)',
            xl: 'var(--radius-xl)',
            '2xl': 'var(--radius-2xl)',
          },
          boxShadow: {
            xs: 'var(--shadow-xs)',
            sm: 'var(--shadow-sm)',
            md: 'var(--shadow-md)',
            lg: 'var(--shadow-lg)',
            xl: 'var(--shadow-xl)',
          },
          maxWidth: {
            'container': '1280px',
          },
        },
      },
    }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "name": "SafeTrekr",
        "url": "https://safetrekr.com",
        "description": "Professional trip safety review and evidence documentation platform."
      },
      {
        "@type": "SoftwareApplication",
        "name": "SafeTrekr",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web"
      },
      {
        "@type": "AggregateOffer",
        "lowPrice": "450",
        "highPrice": "1250",
        "priceCurrency": "USD",
        "offerCount": "3"
      }
    ]
  }
  </script>
  <style>
    /* ---- Dot grid pattern for Hero ---- */
    .hero-dot-grid {
      background-image: radial-gradient(circle, var(--color-primary-300) 1px, transparent 1px);
      background-size: 24px 24px;
      opacity: 0.04;
      position: absolute;
      inset: 0;
      pointer-events: none;
    }
    .hero-radial-glow {
      background: radial-gradient(600px circle at 70% 50%, rgba(241,249,244,0.2), transparent);
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    /* ---- Glassmorphic header ---- */
    .header-scrolled {
      background: rgba(231, 236, 238, 0.80);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-bottom: 1px solid rgba(184, 195, 199, 0.5);
      box-shadow: var(--shadow-sm);
    }

    /* ---- Gauge animation ---- */
    @keyframes gaugeFill {
      from { stroke-dashoffset: 226.2; }
      to { stroke-dashoffset: 33.93; }
    }
    .gauge-arc {
      animation: gaugeFill 1.2s ease-out forwards;
      animation-delay: 1.2s;
      stroke-dasharray: 226.2;
      stroke-dashoffset: 226.2;
    }

    /* ---- Status dot pulse ---- */
    @keyframes statusPulse {
      0% { transform: scale(0); opacity: 0; }
      60% { transform: scale(1.4); opacity: 1; }
      100% { transform: scale(1); opacity: 1; }
    }
    .status-pulse {
      animation: statusPulse 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      animation-delay: 1.4s;
      transform: scale(0);
    }

    /* ---- Progress bar fill ---- */
    @keyframes progressFill {
      from { width: 0; }
      to { width: 100%; }
    }
    .progress-fill {
      animation: progressFill 1s ease-out forwards;
      animation-delay: 1s;
      width: 0;
    }

    /* ---- Fade-up animation for sections ---- */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-up {
      animation: fadeUp 0.5s ease-out forwards;
      opacity: 0;
    }

    /* ---- Binder fan pages ---- */
    .binder-page {
      position: absolute;
      width: 200px;
      height: 280px;
      background: white;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-xl);
      padding: 20px;
      border: 1px solid rgba(184, 195, 199, 0.2);
      transition: transform 0.3s ease;
    }
    .binder-page:hover {
      transform: translateY(-4px) !important;
    }

    /* ---- Comparison table SafeTrekr column highlight ---- */
    .safetrekr-col {
      background: var(--color-primary-50);
    }

    /* ---- Card group hover ---- */
    .card-interactive {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .card-interactive:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }
    .card-interactive:hover .card-link-arrow {
      transform: translateX(4px);
    }
    .card-link-arrow {
      transition: transform 0.2s ease;
    }

    /* ---- Pricing featured scale ---- */
    @media (min-width: 1024px) {
      .pricing-featured {
        transform: scale(1.03);
        z-index: 1;
        position: relative;
      }
    }

    /* ---- Smooth scroll offset for sticky header ---- */
    html {
      scroll-padding-top: 80px;
    }

    /* ---- Mobile menu overlay ---- */
    .mobile-menu-overlay {
      position: fixed;
      inset: 0;
      background: rgba(6, 26, 35, 0.5);
      z-index: 40;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }
    .mobile-menu-overlay.active {
      opacity: 1;
      pointer-events: all;
    }
    .mobile-menu-panel {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: 320px;
      max-width: 85vw;
      background: var(--color-card);
      z-index: 50;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      overflow-y: auto;
      padding: 24px;
    }
    .mobile-menu-panel.active {
      transform: translateX(0);
    }
  </style>
<script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>
</head>
<body>
  <!-- Skip Navigation -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:bg-card focus:text-foreground focus:px-4 focus:py-2 focus:rounded-md focus:shadow-lg focus:ring-2 focus:ring-ring" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">
    Skip to main content
  </a>

  <!-- ================================================================
       SECTION 1: SITE HEADER (Sticky Glassmorphic)
       ================================================================ -->
  <header id="site-header" class="fixed top-0 left-0 right-0 z-30 transition-all duration-300" style="height: 80px;">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 h-full flex items-center justify-between">
      <!-- Logo -->
      <a href="/" aria-label="SafeTrekr home" class="flex-shrink-0">
        <svg height="32" viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="hidden lg:block">
          <path d="M16 1L3 8v10c0 7.2 5.5 13.9 13 15.9 7.5-2 13-8.7 13-15.9V8L16 1z" fill="none" stroke="#123646" stroke-width="2" stroke-linejoin="round"/>
          <path d="M10 14l4 4 8-8" stroke="#3f885b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="40" y="22" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-weight="700" font-size="18" fill="#123646">SafeTrekr</text>
        </svg>
        <svg height="28" viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="lg:hidden">
          <path d="M16 1L3 8v10c0 7.2 5.5 13.9 13 15.9 7.5-2 13-8.7 13-15.9V8L16 1z" fill="none" stroke="#123646" stroke-width="2" stroke-linejoin="round"/>
          <path d="M10 14l4 4 8-8" stroke="#3f885b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="40" y="22" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-weight="700" font-size="18" fill="#123646">SafeTrekr</text>
        </svg>
      </a>

      <!-- Desktop Nav -->
      <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-8">
        <a href="/platform" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Platform
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="/solutions" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Solutions
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="/how-it-works" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150" style="font-family: var(--font-body);">How It Works</a>
        <a href="/pricing" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150" style="font-family: var(--font-body);">Pricing</a>
        <a href="/resources" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Resources
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </nav>

      <!-- Desktop CTAs -->
      <div class="hidden lg:flex items-center gap-4">
        <a href="https://app.safetrekr.com" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-ghost" style="font-family: var(--font-heading); font-size: 14px; font-weight: 600; padding: 8px 16px; border-radius: var(--radius-md);">Sign In</a>
        <a href="/demo" class="btn btn-md btn-primary" style="font-family: var(--font-heading); font-size: 15px; font-weight: 600; padding: 10px 20px; border-radius: var(--radius-md); background: var(--color-primary-600); color: #fff; text-decoration: none;">Get a Demo</a>
      </div>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-foreground" aria-label="Open navigation menu" aria-expanded="false">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-overlay" class="mobile-menu-overlay" aria-hidden="true"></div>
  <div id="mobile-panel" class="mobile-menu-panel" role="dialog" aria-modal="true" aria-label="Main navigation">
    <div class="flex justify-between items-center mb-8">
      <span class="font-display font-bold text-lg text-foreground">Menu</span>
      <button id="mobile-close-btn" class="p-2 text-foreground" aria-label="Close navigation menu">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <nav class="flex flex-col gap-2">
      <a href="/platform" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Platform</a>
      <a href="/solutions" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Solutions</a>
      <a href="/how-it-works" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">How It Works</a>
      <a href="/pricing" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Pricing</a>
      <a href="/resources" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Resources</a>
      <div class="border-t mt-4 pt-4" style="border-color: var(--color-border);">
        <a href="/demo" class="block w-full text-center py-3 rounded-md text-base font-semibold text-white" style="background: var(--color-primary-600); font-family: var(--font-heading);">Get a Demo</a>
      </div>
    </nav>
  </div>

  <!-- ================================================================
       MAIN CONTENT
       ================================================================ -->
  <main id="main-content">

    <!-- ================================================================
         SECTION 2: HERO
         ================================================================ -->
    <section aria-labelledby="hero-heading" class="relative overflow-hidden" style="background: var(--color-background); padding-top: 160px; padding-bottom: 128px;">
      <!-- Dot grid -->
      <div class="hero-dot-grid"></div>
      <!-- Radial glow -->
      <div class="hero-radial-glow"></div>

      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 relative z-10">
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-20 items-center">
          <!-- Text Column -->
          <div class="lg:col-span-5 flex flex-col">
            <!-- Eyebrow -->
            <span class="text-eyebrow flex items-center gap-2" style="color: var(--color-primary-700);">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--color-primary-700);">
                <path d="M12 2L4 7v6c0 5.5 3.4 10.7 8 12 4.6-1.3 8-6.5 8-12V7l-8-5z" stroke-linejoin="round"/>
                <path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              TRIP SAFETY MANAGEMENT PLATFORM
            </span>

            <!-- Headline -->
            <h1 id="hero-heading" class="text-display-xl mt-4" style="color: var(--color-foreground); max-width: 20ch;">
              Every trip professionally reviewed.
            </h1>

            <!-- Subtext -->
            <p class="text-body-lg mt-6" style="color: var(--color-muted-foreground); max-width: 50ch;">
              SafeTrekr combines intelligence from 5 government data sources, 17-section analyst review, and SHA-256 evidence documentation to protect your travelers and your organization.
            </p>

            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row flex-wrap gap-4 mt-8">
              <a href="/resources/sample-binders" class="inline-flex items-center justify-center gap-2 font-semibold rounded-md transition-all duration-150 text-white text-center sm:text-left" style="font-family: var(--font-heading); background: var(--color-primary-600); padding: 16px 32px; font-size: 18px; border-radius: var(--radius-md);">
                See Sample Binder
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              </a>
              <a href="/demo" class="inline-flex items-center justify-center gap-2 font-semibold rounded-md transition-all duration-150 text-center sm:text-left" style="font-family: var(--font-heading); background: transparent; border: 1.5px solid var(--color-border); color: var(--color-foreground); padding: 16px 32px; font-size: 18px; border-radius: var(--radius-md);">
                Schedule a Demo
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            </div>
          </div>

          <!-- Visual Column: Product Composition -->
          <div class="lg:col-span-7 relative hidden md:block" style="min-height: 440px;">
            <!-- Layer 1: Map Base -->
            <div class="relative rounded-xl overflow-hidden border" style="width: 100%; max-width: 560px; aspect-ratio: 14/10; box-shadow: var(--shadow-lg); border-color: var(--color-border); background: #dce3e6;">
              <!-- Desaturated map placeholder -->
              <div style="width:100%;height:100%;background: linear-gradient(135deg, #d4dce0 0%, #c8d2d6 25%, #d0d9dd 50%, #c5cfd4 75%, #d3dbdf 100%); position: relative; filter: saturate(0.15) contrast(0.85);">
                <!-- Terrain features -->
                <div style="position:absolute;top:15%;left:10%;width:35%;height:25%;background:linear-gradient(180deg, rgba(160,175,165,0.4), transparent);border-radius:60% 40% 50% 50%;"></div>
                <div style="position:absolute;top:35%;left:50%;width:25%;height:20%;background:linear-gradient(180deg, rgba(170,185,175,0.3), transparent);border-radius:50%;"></div>
                <div style="position:absolute;bottom:10%;right:10%;width:30%;height:30%;background:rgba(155,175,195,0.25);border-radius:40% 60% 50% 40%;"></div>
              </div>
              <!-- Route SVG overlay -->
              <svg class="absolute inset-0 w-full h-full" viewBox="0 0 560 400" fill="none" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
                <!-- Route line -->
                <path d="M 100 320 C 150 280, 200 200, 280 180 S 400 160, 460 100" stroke="#4ca46e" stroke-width="3" stroke-linecap="round" fill="none" stroke-dasharray="8 4" opacity="0.8"/>
                <!-- Waypoint halos -->
                <circle cx="100" cy="320" r="16" fill="#e0f1e6" opacity="0.5"/>
                <circle cx="280" cy="180" r="16" fill="#e0f1e6" opacity="0.5"/>
                <circle cx="460" cy="100" r="16" fill="#e0f1e6" opacity="0.5"/>
                <!-- Waypoint dots -->
                <circle cx="100" cy="320" r="6" fill="#3f885b"/>
                <circle cx="280" cy="180" r="6" fill="#3f885b"/>
                <circle cx="460" cy="100" r="6" fill="#3f885b"/>
                <!-- Direction triangles -->
                <polygon points="190,228 198,224 194,234" fill="#4ca46e" opacity="0.7"/>
                <polygon points="370,148 378,144 374,154" fill="#4ca46e" opacity="0.7"/>
              </svg>
              <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="Map showing a trip route with safety waypoints" class="absolute inset-0 w-full h-full" style="opacity:0;">
            </div>

            <!-- Layer 2: Trip Review Panel -->
            <div class="absolute rounded-xl bg-white shadow-xl border p-5 hidden lg:block" style="width: 260px; top: -20px; right: -10px; z-index: 10; border-color: var(--color-border);">
              <div class="flex items-center justify-between mb-4">
                <span class="text-heading-sm" style="color: var(--color-foreground); font-size: 18px;">Trip Safety Review</span>
                <span class="badge badge-brand" style="font-size: 11px;">Reviewed</span>
              </div>
              <div class="flex flex-col gap-3 mb-4">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="#4ca46e"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-body-sm" style="color: var(--color-foreground);">Venue Safety</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="#4ca46e"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-body-sm" style="color: var(--color-foreground);">Transportation</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="#4ca46e"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-body-sm" style="color: var(--color-foreground);">Emergency Plan</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="#4ca46e"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-body-sm" style="color: var(--color-foreground);">Health Advisory</span>
                </div>
              </div>
              <!-- Progress bar -->
              <div class="w-full h-2 rounded-full" style="background: var(--color-primary-100);">
                <div class="h-full rounded-full progress-fill" style="background: var(--color-primary-500);"></div>
              </div>
              <!-- Analyst -->
              <div class="flex items-center gap-2 mt-4">
                <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-semibold" style="background: var(--color-primary-200); color: var(--color-primary-800);">MR</div>
                <span class="text-body-sm" style="color: var(--color-muted-foreground);">Analyst M.R.</span>
              </div>
            </div>

            <!-- Layer 3: Document Preview -->
            <div class="absolute hidden lg:block" style="right: -10px; top: 290px; z-index: 20;">
              <!-- Stacked paper offset layers -->
              <div class="absolute rounded-lg bg-white/80 border" style="width: 220px; height: 160px; top: 4px; left: 4px; border-color: rgba(184,195,199,0.3); box-shadow: var(--shadow-sm);"></div>
              <div class="absolute rounded-lg bg-white/90 border" style="width: 220px; height: 160px; top: 2px; left: 2px; border-color: rgba(184,195,199,0.3); box-shadow: var(--shadow-sm);"></div>
              <!-- Front sheet -->
              <div class="relative rounded-lg bg-white border p-4" style="width: 220px; height: 160px; border-color: var(--color-border); box-shadow: var(--shadow-lg);">
                <span class="text-eyebrow block" style="color: var(--color-muted-foreground); font-size: 10px;">EVIDENCE BINDER</span>
                <div class="flex items-center gap-1.5 mt-1.5">
                  <span class="badge badge-brand" style="font-size: 10px; padding: 1px 6px;">Verified</span>
                  <span class="w-1.5 h-1.5 rounded-full" style="background: var(--color-safety-green);"></span>
                </div>
                <div class="mt-3 space-y-2">
                  <div class="flex items-start gap-2">
                    <div class="w-1.5 h-1.5 rounded-full mt-1.5 flex-shrink-0" style="background: var(--color-primary-500);"></div>
                    <span style="font-size: 11px; color: var(--color-foreground); line-height: 1.3;">Risk assessment completed</span>
                  </div>
                  <div class="flex items-start gap-2">
                    <div class="w-1.5 h-1.5 rounded-full mt-1.5 flex-shrink-0" style="background: var(--color-primary-500);"></div>
                    <span style="font-size: 11px; color: var(--color-foreground); line-height: 1.3;">Documentation finalized</span>
                  </div>
                </div>
                <div class="mt-3 pt-2" style="border-top: 1px solid var(--color-border);">
                  <code style="font-family: var(--font-mono); font-size: 10px; color: var(--color-muted-foreground); letter-spacing: 0.03em;">a3f2...c891</code>
                </div>
              </div>
            </div>

            <!-- Layer 4: Readiness Gauge -->
            <div class="absolute hidden lg:block rounded-xl bg-white border p-4 text-center" style="bottom: -16px; left: 24px; z-index: 15; width: 120px; border-color: var(--color-border); box-shadow: var(--shadow-lg);">
              <svg viewBox="0 0 72 72" width="72" height="72" class="mx-auto">
                <!-- Background track -->
                <circle cx="36" cy="36" r="32" fill="none" stroke="#e0f1e6" stroke-width="4" transform="rotate(-90 36 36)"/>
                <!-- Filled arc to ~85% -->
                <circle cx="36" cy="36" r="32" fill="none" stroke="#4ca46e" stroke-width="4" stroke-linecap="round" transform="rotate(-90 36 36)" class="gauge-arc"/>
                <!-- Center text -->
                <text x="36" y="34" text-anchor="middle" font-family="Plus Jakarta Sans, sans-serif" font-weight="600" font-size="16" fill="#061a23">85%</text>
                <text x="36" y="48" text-anchor="middle" font-family="Inter, sans-serif" font-size="8" fill="#4d5153">Trip Ready</text>
              </svg>
              <!-- Status dot -->
              <div class="flex items-center justify-center gap-1 mt-1">
                <span class="w-2 h-2 rounded-full status-pulse" style="background: var(--color-safety-green);"></span>
                <span style="font-size: 10px; color: var(--color-muted-foreground);">Active</span>
              </div>
            </div>
          </div>

          <!-- Mobile simplified composition -->
          <div class="md:hidden relative rounded-xl overflow-hidden border" style="aspect-ratio: 16/10; background: linear-gradient(135deg, #d4dce0 0%, #c8d2d6 25%, #d0d9dd 50%, #c5cfd4 75%, #d3dbdf 100%); border-color: var(--color-border); box-shadow: var(--shadow-lg);">
            <svg class="absolute inset-0 w-full h-full" viewBox="0 0 560 350" fill="none" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
              <path d="M 80 280 C 150 220, 250 180, 350 150 S 450 120, 500 80" stroke="#4ca46e" stroke-width="3" stroke-linecap="round" fill="none" stroke-dasharray="8 4" opacity="0.8"/>
              <circle cx="80" cy="280" r="14" fill="#e0f1e6" opacity="0.5"/>
              <circle cx="350" cy="150" r="14" fill="#e0f1e6" opacity="0.5"/>
              <circle cx="80" cy="280" r="6" fill="#3f885b"/>
              <circle cx="350" cy="150" r="6" fill="#3f885b"/>
            </svg>
          </div>
        </div>
      </div>

