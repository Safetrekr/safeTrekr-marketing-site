              <div class="binder-page hidden sm:block" style="z-index: 1; transform: rotate(-8deg); left: 0; top: 40px;">
                <div style="font-size: 11px; font-weight: 600; color: var(--color-muted-foreground); letter-spacing: 0.05em; text-transform: uppercase;">SafeTrekr</div>
                <div style="font-family: var(--font-heading); font-size: 14px; font-weight: 700; color: var(--color-foreground); margin-top: 12px;">Safety Binder</div>
                <div style="font-size: 11px; color: var(--color-muted-foreground); margin-top: 8px;">Acme Schools District</div>
                <div style="font-size: 11px; color: var(--color-muted-foreground); margin-top: 4px;">March 15 - March 22, 2026</div>
                <div style="height: 1px; background: var(--color-border); margin: 16px 0;"></div>
                <div style="width: 50px; height: 50px; border-radius: 8px; background: var(--color-primary-50); margin: 0 auto; display: flex; align-items: center; justify-content: center;">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3f885b" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linejoin="round"/></svg>
                </div>
              </div>

              <!-- Page 2 -->
              <div class="binder-page hidden sm:block" style="z-index: 2; transform: rotate(-4deg); left: 60px; top: 30px;">
                <div style="font-size: 10px; font-weight: 600; color: var(--color-muted-foreground); letter-spacing: 0.05em; text-transform: uppercase;">Risk Assessment</div>
                <div style="margin-top: 12px;">
