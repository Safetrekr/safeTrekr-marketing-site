    <!-- SECTION 3: INTELLIGENCE SOURCES (DARK SECTION 1)            -->
    <!-- ========================================================== -->
    <section id="intelligence" aria-labelledby="intelligence-heading" class="py-24 lg:py-32" data-theme="dark" style="background:#123646;">
      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12">

        <!-- Section Header -->
        <div class="text-center mb-16">
          <p class="text-eyebrow text-[#6cbc8b] uppercase tracking-[0.08em] mb-4 fade-up">Intelligence Engine</p>
          <h2 id="intelligence-heading" class="text-display-md text-[#f7f8f8] max-w-[28ch] mx-auto text-center mb-6 fade-up">
            We Analyze Data You Can't Get from a Google Search.
          </h2>
          <p class="text-body-lg text-[#b8c3c7] max-w-[65ch] mx-auto text-center fade-up">
            SafeTrekr's Risk Intelligence Engine pulls from 5 authoritative government data sources and runs Monte Carlo simulations to produce probability-weighted risk scores.
          </p>
        </div>

        <!-- Intelligence Source Cards (5) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 lg:gap-6 mb-16">

          <!-- NOAA -->
          <article class="rounded-xl border p-6 text-center lg:text-left fade-up" style="background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.1);">
            <div class="h-10 w-10 mx-auto lg:mx-0 mb-4 rounded-lg flex items-center justify-center" style="background:rgba(255,255,255,0.08);">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6cbc8b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:0.8"><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32l1.41-1.41"/><circle cx="12" cy="12" r="4"/></svg>
            </div>
            <h3 class="text-heading-sm text-[#f7f8f8] font-semibold mb-2">NOAA</h3>
            <p class="text-xs text-[#b8c3c7] mb-3">National Oceanic and Atmospheric Administration</p>
            <p class="text-body-sm text-[#b8c3c7]">Weather forecasts, severe storm alerts, historical climate patterns for travel dates and destination</p>
          </article>

          <!-- USGS -->
          <article class="rounded-xl border p-6 text-center lg:text-left fade-up" style="background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.1);transition-delay:80ms;">
            <div class="h-10 w-10 mx-auto lg:mx-0 mb-4 rounded-lg flex items-center justify-center" style="background:rgba(255,255,255,0.08);">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6cbc8b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:0.8"><path d="M2 22 L6 14 L10 18 L14 8 L18 12 L22 2"/></svg>
            </div>
            <h3 class="text-heading-sm text-[#f7f8f8] font-semibold mb-2">USGS</h3>
            <p class="text-xs text-[#b8c3c7] mb-3">United States Geological Survey</p>
            <p class="text-body-sm text-[#b8c3c7]">Seismic activity, earthquake risk, volcanic alerts, geological hazards for destination region</p>
          </article>

          <!-- CDC -->
          <article class="rounded-xl border p-6 text-center lg:text-left fade-up" style="background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.1);transition-delay:160ms;">
            <div class="h-10 w-10 mx-auto lg:mx-0 mb-4 rounded-lg flex items-center justify-center" style="background:rgba(255,255,255,0.08);">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6cbc8b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:0.8"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <h3 class="text-heading-sm text-[#f7f8f8] font-semibold mb-2">CDC</h3>
            <p class="text-xs text-[#b8c3c7] mb-3">Centers for Disease Control and Prevention</p>
            <p class="text-body-sm text-[#b8c3c7]">Health advisories, disease outbreaks, vaccination requirements, travel health notices</p>
          </article>

          <!-- GDACS -->
          <article class="rounded-xl border p-6 text-center lg:text-left fade-up" style="background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.1);transition-delay:240ms;">
            <div class="h-10 w-10 mx-auto lg:mx-0 mb-4 rounded-lg flex items-center justify-center" style="background:rgba(255,255,255,0.08);">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6cbc8b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:0.8"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <h3 class="text-heading-sm text-[#f7f8f8] font-semibold mb-2">GDACS</h3>
            <p class="text-xs text-[#b8c3c7] mb-3">Global Disaster Alerting Coordination System</p>
            <p class="text-body-sm text-[#b8c3c7]">Real-time disaster alerts, earthquake/flood/cyclone monitoring, humanitarian impact assessments</p>
          </article>

          <!-- ReliefWeb -->
          <article class="rounded-xl border p-6 text-center lg:text-left fade-up" style="background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.1);transition-delay:320ms;">
            <div class="h-10 w-10 mx-auto lg:mx-0 mb-4 rounded-lg flex items-center justify-center" style="background:rgba(255,255,255,0.08);">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6cbc8b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:0.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </div>
            <h3 class="text-heading-sm text-[#f7f8f8] font-semibold mb-2">ReliefWeb</h3>
            <p class="text-xs text-[#b8c3c7] mb-3">UN Office for Coordination of Humanitarian Affairs</p>
            <p class="text-body-sm text-[#b8c3c7]">Humanitarian situation reports, conflict updates, country-level safety assessments</p>
          </article>

        </div>

        <!-- Monte Carlo Explanation Card -->
        <div class="rounded-xl border p-8 lg:p-12 grid lg:grid-cols-[1fr_1.2fr] gap-8 lg:gap-12 items-center fade-up" style="background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.1);">

          <!-- Left: Text -->
          <div>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-semibold mb-4" style="background:rgba(108,188,139,0.15);color:#6cbc8b;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 20h.01M7 20v-4M12 20v-8M17 20V8M22 4v16"/></svg>
              RISK SCORING
            </span>
            <h3 class="text-heading-lg text-[#f7f8f8] mb-4">Probability-Weighted Risk Scores</h3>
            <p class="text-body-md text-[#b8c3c7] max-w-[65ch] mb-6">
              Our Risk Intelligence Engine runs Monte Carlo simulations across all data sources to produce probability-weighted risk scores -- not simple averages, but statistically modeled projections of what could affect your trip.
            </p>
            <ul class="space-y-3">
              <li class="flex gap-3">
                <svg class="w-4 h-4 text-[#6cbc8b] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-body-sm text-[#b8c3c7]">Thousands of simulations per trip</span>
              </li>
              <li class="flex gap-3">
                <svg class="w-4 h-4 text-[#6cbc8b] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-body-sm text-[#b8c3c7]">Weather, seismic, health, conflict data cross-referenced</span>
              </li>
              <li class="flex gap-3">
                <svg class="w-4 h-4 text-[#6cbc8b] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-body-sm text-[#b8c3c7]">Scores update until departure date</span>
              </li>
            </ul>
          </div>

          <!-- Right: Bell Curve Visualization (decorative) -->
          <div class="max-w-[400px] mx-auto w-full" aria-hidden="true">
            <svg viewBox="0 0 400 240" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
              <!-- Axes -->
              <line x1="40" y1="200" x2="380" y2="200" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
              <line x1="40" y1="200" x2="40" y2="20" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>

              <!-- Shaded area under curve -->
              <path d="M60 200 Q100 195 140 170 Q180 100 210 50 Q240 100 280 170 Q320 195 360 200 Z" fill="#6cbc8b" fill-opacity="0.1"/>

              <!-- Bell curve -->
              <path d="M60 200 Q100 195 140 170 Q180 100 210 50 Q240 100 280 170 Q320 195 360 200" stroke="#6cbc8b" stroke-width="2" fill="none" class="bell-curve-path"/>

              <!-- Data points -->
              <g>
                <circle cx="120" cy="185" r="5" fill="#96cfac" class="data-dot"/>
                <circle cx="165" cy="145" r="5" fill="#6cbc8b" class="data-dot"/>
                <circle cx="210" cy="50" r="6" fill="#4ca46e" class="data-dot"/>
                <circle cx="255" cy="145" r="5" fill="#6cbc8b" class="data-dot"/>
                <circle cx="310" cy="188" r="5" fill="#96cfac" class="data-dot"/>
              </g>

              <!-- X-axis labels -->
              <text x="80" y="225" fill="#b8c3c7" font-family="JetBrains Mono, monospace" font-size="11">Low</text>
              <text x="190" y="225" fill="#b8c3c7" font-family="JetBrains Mono, monospace" font-size="11">Medium</text>
              <text x="330" y="225" fill="#b8c3c7" font-family="JetBrains Mono, monospace" font-size="11">High</text>

              <!-- Y-axis label -->
              <text x="10" y="110" fill="#b8c3c7" font-family="JetBrains Mono, monospace" font-size="10" transform="rotate(-90, 15, 110)">Probability</text>
