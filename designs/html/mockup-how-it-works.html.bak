<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>How It Works -- SafeTrekr</title>
  <meta name="description" content="From trip submission to safety binder in 3-5 days. See how SafeTrekr's analyst review, government intelligence, and tamper-evident documentation protect every trip.">
  <meta property="og:title" content="How SafeTrekr Works: Intelligence, Review, Documentation">
  <meta property="og:description" content="Every trip goes through the same rigorous 3-step process. 5 government data sources. 17-section analyst review. SHA-256 tamper-evident safety binder.">
  <meta property="og:image" content="/og/how-it-works.png">
  <link rel="canonical" href="https://safetrekr.com/how-it-works">
  <link rel="stylesheet" href="design-tokens.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'st-bg': '#e7ecee',
            'st-fg': '#061a23',
            'st-card': '#f7f8f8',
            'st-border': '#b8c3c7',
            'st-muted': '#4d5153',
            'st-primary': {
              50: '#f1f9f4', 100: '#e0f1e6', 200: '#c0e2cd', 300: '#96cfac',
              400: '#6cbc8b', 500: '#4ca46e', 600: '#3f885b', 700: '#33704b',
              800: '#2a5b3d', 900: '#20462f', 950: '#132a1c',
              DEFAULT: '#3f885b'
            },
            'st-secondary': { DEFAULT: '#123646', light: '#1a4a5e', muted: '#b8c3c7', fg: '#f7f8f8' },
            'st-dark-surface': 'rgba(255,255,255,0.06)',
            'st-dark-border': 'rgba(255,255,255,0.1)',
            'st-dark-accent': '#6cbc8b',
          },
          fontFamily: {
            display: ['Plus Jakarta Sans', 'system-ui', 'sans-serif'],
            body: ['Inter', 'system-ui', 'sans-serif'],
            mono: ['JetBrains Mono', 'ui-monospace', 'monospace'],
          },
          maxWidth: {
            'container': '1280px',
          },
        }
      }
    }
  </script>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How SafeTrekr Works",
    "description": "From trip submission to safety binder in 3-5 days. Every trip goes through the same rigorous process.",
    "totalTime": "P5D",
    "step": [
      {
        "@type": "HowToStep",
        "position": 1,
        "name": "Submit Your Trip",
        "text": "Your organization submits trip details through a guided form: destination, dates, participants, activities, and logistics. Takes approximately 15 minutes.",
        "url": "https://safetrekr.com/how-it-works#process"
      },
      {
        "@type": "HowToStep",
        "position": 2,
        "name": "Analyst Reviews Everything",
        "text": "A trained safety analyst conducts a comprehensive 17-section review. The Risk Intelligence Engine scores every destination using NOAA, USGS, CDC, GDACS, and ReliefWeb data with Monte Carlo simulations.",
        "url": "https://safetrekr.com/how-it-works#review"
      },
      {
        "@type": "HowToStep",
        "position": 3,
        "name": "Receive Your Safety Binder",
        "text": "Audit-ready documentation delivered with SHA-256 hash-chain integrity. Every finding, every recommendation, every emergency contact, every risk score.",
        "url": "https://safetrekr.com/how-it-works#binder"
      }
    ]
  }
  </script>

  <style>
    /* ---- Scroll margin for anchors ---- */
    [id] { scroll-margin-top: 8rem; }

    /* ---- Sticky Anchor Nav ---- */
    .anchor-nav { transition: opacity 0.2s ease, transform 0.2s ease; }
    .anchor-nav.hidden-nav { opacity: 0; pointer-events: none; transform: translateY(-100%); }
    .anchor-nav.visible-nav { opacity: 1; pointer-events: auto; transform: translateY(0); }
    .anchor-link { white-space: nowrap; padding: 0.75rem 0; font-size: 0.875rem; color: var(--color-muted-foreground); border-bottom: 2px solid transparent; transition: color 0.15s ease, border-color 0.15s ease; }
    .anchor-link:hover { color: var(--color-foreground); }
    .anchor-link.active { color: var(--color-foreground); font-weight: 600; border-bottom-color: var(--color-primary); }

    /* ---- Scrollbar hide ---- */
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

    /* ---- Card hover ---- */
    .review-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .review-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }

    /* ---- Segment card hover ---- */
    .segment-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .segment-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .segment-card:hover .segment-title { color: var(--color-primary-700); }
    .segment-card:hover .segment-arrow { transform: translateX(4px); }
    .segment-arrow { transition: transform 0.15s ease; }

    /* ---- Proof card hover ---- */
    .proof-card { transition: box-shadow 0.2s ease; }
    .proof-card:hover { box-shadow: var(--shadow-md); }

    /* ---- Monte Carlo SVG ---- */
    .bell-curve-path { stroke-dasharray: 600; stroke-dashoffset: 600; animation: drawCurve 1.2s ease-out forwards; }
    @keyframes drawCurve { to { stroke-dashoffset: 0; } }
    .data-dot { opacity: 0; animation: popDot 0.3s ease-out forwards; }
    .data-dot:nth-child(1) { animation-delay: 1.2s; }
    .data-dot:nth-child(2) { animation-delay: 1.3s; }
    .data-dot:nth-child(3) { animation-delay: 1.4s; }
    .data-dot:nth-child(4) { animation-delay: 1.5s; }
    .data-dot:nth-child(5) { animation-delay: 1.6s; }
    @keyframes popDot { to { opacity: 1; } }

    /* ---- Timeline connector (desktop) ---- */
    .timeline-connector { stroke-dasharray: 6 4; }

    /* ---- Mobile vertical timeline ---- */
    .mobile-timeline-line { width: 2px; background: var(--color-border); }
    .mobile-timeline-dot { width: 12px; height: 12px; border-radius: 50%; background: var(--color-primary-500); box-shadow: 0 0 0 4px var(--color-primary-100); flex-shrink: 0; }

    /* ---- Fade-up animation ---- */
    .fade-up { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }

    /* ---- Reduced motion ---- */
    @media (prefers-reduced-motion: reduce) {
      .fade-up { opacity: 1; transform: none; transition: none; }
      .bell-curve-path { stroke-dashoffset: 0; animation: none; }
      .data-dot { opacity: 1; animation: none; }
    }

    /* ---- Status pulse ---- */
    @keyframes statusPulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }
    .status-pulse { animation: statusPulse 2s ease-in-out infinite; }
  </style>
<script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>
</head>

<body class="bg-[#e7ecee] text-[#061a23] font-body">

  <!-- Skip Nav -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded-md focus:shadow-lg focus:text-[#33704b] focus:outline-2 focus:outline-[#365462]">Skip to main content</a>

  <!-- ============================================================ -->
  <!-- SITE HEADER (sticky)                                         -->
  <!-- ============================================================ -->
  <header id="site-header" class="fixed top-0 left-0 right-0 z-30 transition-all duration-300" style="height: 80px;">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 h-full flex items-center justify-between">
      <!-- Logo: Horizontal lockup -->
      <a href="/" aria-label="SafeTrekr home" class="flex-shrink-0">
        <svg height="32" viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="hidden lg:block" aria-hidden="true">
          <path d="M16 1L3 8v10c0 7.2 5.5 13.9 13 15.9 7.5-2 13-8.7 13-15.9V8L16 1z" fill="none" stroke="#123646" stroke-width="2" stroke-linejoin="round"/>
          <path d="M10 14l4 4 8-8" stroke="#3f885b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="40" y="22" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-weight="700" font-size="18" fill="#123646">SafeTrekr</text>
        </svg>
        <svg height="28" viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="lg:hidden" aria-hidden="true">
          <path d="M16 1L3 8v10c0 7.2 5.5 13.9 13 15.9 7.5-2 13-8.7 13-15.9V8L16 1z" fill="none" stroke="#123646" stroke-width="2" stroke-linejoin="round"/>
          <path d="M10 14l4 4 8-8" stroke="#3f885b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="40" y="22" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-weight="700" font-size="18" fill="#123646">SafeTrekr</text>
        </svg>
      </a>

      <!-- Desktop Nav -->
      <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-8">
        <a href="/platform" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Platform
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="/solutions" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Solutions
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="/how-it-works" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150" style="font-family: var(--font-body);">How It Works</a>
        <a href="/pricing" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150" style="font-family: var(--font-body);">Pricing</a>
        <a href="/resources" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Resources
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </nav>

      <!-- Desktop CTAs -->
      <div class="hidden lg:flex items-center gap-4">
        <a href="https://app.safetrekr.com" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold transition-colors duration-150 hover:text-foreground" style="font-family: var(--font-heading); color: var(--color-muted-foreground);">Sign In</a>
        <a href="/demo" class="inline-flex items-center justify-center font-semibold rounded-md transition-all duration-150 text-white" style="font-family: var(--font-heading); background: var(--color-primary-600); padding: 10px 20px; font-size: 15px; border-radius: var(--radius-md); text-decoration: none;">Get a Demo</a>
      </div>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-foreground" aria-label="Open navigation menu" aria-expanded="false">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- ============================================================ -->
  <!-- STICKY ANCHOR NAV (appears after hero scroll)                -->
  <!-- ============================================================ -->
  <div id="anchor-nav" class="anchor-nav hidden-nav sticky top-16 z-30 bg-[#f7f8f8]/95 backdrop-blur-sm border-b border-[#b8c3c7] h-12">
    <nav class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 h-full flex items-center gap-6 overflow-x-auto scrollbar-hide" aria-label="Page sections">
      <a href="#process" class="anchor-link active" data-anchor="process">The Process</a>
      <a href="#intelligence" class="anchor-link" data-anchor="intelligence">Intelligence</a>
      <a href="#review" class="anchor-link" data-anchor="review">17 Sections</a>
      <a href="#binder" class="anchor-link" data-anchor="binder">Binder</a>
      <a href="#field-ops" class="anchor-link" data-anchor="field-ops">Field Ops</a>
      <a href="#after-trip" class="anchor-link" data-anchor="after-trip">After Trip</a>
    </nav>
  </div>

  <!-- ============================================================ -->
  <!-- MAIN CONTENT                                                  -->
  <!-- ============================================================ -->
  <main id="main-content">

    <!-- ========================================================== -->
    <!-- SECTION 1: HERO                                             -->
    <!-- ========================================================== -->
    <section id="hero" aria-labelledby="hero-heading" class="pt-16 pb-20 lg:pt-24 lg:pb-32 bg-[#e7ecee]">
      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12">
        <div class="max-w-3xl mx-auto text-center">

          <!-- Eyebrow -->
          <div class="flex items-center justify-center gap-2 mb-4 fade-up">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#33704b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L4 7v6c0 5.55 3.41 10.74 8 12 4.59-1.26 8-6.45 8-12V7l-8-5z"/><path d="M9 12l2 2 4-4"/></svg>
            <span class="text-eyebrow text-[#33704b]">How It Works</span>
          </div>

          <!-- Headline -->
          <h1 id="hero-heading" class="text-display-lg text-[#061a23] font-display font-bold max-w-[20ch] mx-auto mb-6 fade-up">
            From Trip Submission to Safety Binder in 3&#8209;5&nbsp;Days.
          </h1>

          <!-- Subheadline -->
          <p class="text-body-lg text-[#4d5153] font-body max-w-[65ch] mx-auto mb-10 fade-up">
            Every trip goes through the same rigorous process. Here's exactly how.
          </p>

          <!-- CTA Group -->
          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center fade-up">
            <a href="/demo" class="btn btn-primary btn-lg w-full sm:w-auto">Get a Demo</a>
            <a href="/resources/sample-binders" class="btn btn-secondary btn-lg w-full sm:w-auto">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download a Sample Binder
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ========================================================== -->
    <!-- SECTION 2: PROCESS TIMELINE (Three-Act Structure)           -->
    <!-- ========================================================== -->
    <section id="process" aria-labelledby="process-heading" class="py-24 lg:py-32 bg-[#e7ecee]">
      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12">

        <!-- Section Header -->
        <div class="text-center mb-16 lg:mb-20">
          <p class="text-eyebrow text-[#33704b] uppercase mb-4 fade-up">The Process</p>
          <h2 id="process-heading" class="text-display-md text-[#061a23] max-w-[28ch] mx-auto text-center fade-up">
            Three Steps. One Standard.
          </h2>
        </div>

        <!-- Desktop Timeline (lg+) -->
        <div class="hidden lg:block" role="list">
          <div class="grid grid-cols-3 gap-8 relative">

            <!-- Connecting SVG lines (decorative) -->
            <svg class="absolute top-6 left-0 w-full h-12 pointer-events-none" aria-hidden="true" style="z-index:0;">
              <!-- Line 1->2 -->
              <line x1="18.5%" y1="24" x2="48.5%" y2="24" stroke="#c0e2cd" stroke-width="2" class="timeline-connector" />
              <!-- Line 2->3 -->
              <line x1="51.5%" y1="24" x2="81.5%" y2="24" stroke="#c0e2cd" stroke-width="2" class="timeline-connector" />
            </svg>

            <!-- Step 1 -->
            <article class="relative z-10 fade-up" role="listitem">
              <div class="h-12 w-12 rounded-full bg-[#e0f1e6] border-2 border-[#96cfac] flex items-center justify-center mb-6">
                <span class="text-heading-sm text-[#33704b] font-bold">1</span>
              </div>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-[#f1f9f4] text-[#33704b] mb-3">ACT 1: INTELLIGENCE</span>
              <h3 class="text-heading-md text-[#061a23] font-semibold mb-3">Submit Your Trip</h3>
              <p class="text-body-md text-[#4d5153] max-w-[45ch] mb-6">
                Your organization submits trip details through a guided form. Destination, dates, participants, activities, and logistics.
              </p>
              <ul class="space-y-2 mb-6">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-[#4ca46e] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-body-sm text-[#061a23]">Destination and travel dates</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-[#4ca46e] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-body-sm text-[#061a23]">Participant count and demographics</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-[#4ca46e] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-body-sm text-[#061a23]">Planned activities and venues</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-[#4ca46e] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-body-sm text-[#061a23]">Transportation and lodging details</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-[#4ca46e] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-body-sm text-[#061a23]">Special requirements or concerns</span>
                </li>
              </ul>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-[#e7ecee] border border-[#b8c3c7] text-[#4d5153]" aria-label="Estimated time: 15 minutes">Takes ~15 minutes</span>
            </article>

            <!-- Step 2 -->
            <article class="relative z-10 fade-up" role="listitem" style="transition-delay:400ms;">
              <div class="h-12 w-12 rounded-full bg-[#e0f1e6] border-2 border-[#96cfac] flex items-center justify-center mb-6">
                <span class="text-heading-sm text-[#33704b] font-bold">2</span>
              </div>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-[#f1f9f4] text-[#33704b] mb-3">ACT 2: REVIEW</span>
              <h3 class="text-heading-md text-[#061a23] font-semibold mb-3">Analyst Reviews Everything</h3>
              <p class="text-body-md text-[#4d5153] max-w-[45ch] mb-6">
                A trained safety analyst conducts a comprehensive 17-section review. The Risk Intelligence Engine scores every destination using 5 government data sources.
              </p>
              <ul class="space-y-2 mb-6">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-[#4ca46e] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-body-sm text-[#061a23]">17-section professional safety review</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-[#4ca46e] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-body-sm text-[#061a23]">Monte Carlo risk scoring simulation</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-[#4ca46e] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-body-sm text-[#061a23]">5 government intelligence sources analyzed</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-[#4ca46e] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-body-sm text-[#061a23]">Every venue, route, and provider evaluated</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-[#4ca46e] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="text-body-sm text-[#061a23]">Recommendations written for each finding</span>
                </li>
              </ul>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-[#e7ecee] border border-[#b8c3c7] text-[#4d5153]" aria-label="Estimated time: 3 to 5 business days">3-5 business days</span>
            </article>

            <!-- Step 3 -->
            <article class="relative z-10 fade-up" role="listitem" style="transition-delay:800ms;">
              <div class="h-12 w-12 rounded-full bg-[#e0f1e6] border-2 border-[#96cfac] flex items-center justify-center mb-6">
                <span class="text-heading-sm text-[#33704b] font-bold">3</span>
              </div>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-[#f1f9f4] text-[#33704b] mb-3">ACT 3: DOCUMENTATION</span>
              <h3 class="text-heading-md text-[#061a23] font-semibold mb-3">Receive Your Safety Binder</h3>
              <p class="text-body-md text-[#4d5153] max-w-[45ch] mb-6">
                Audit-ready documentation delivered with SHA-256 hash-chain integrity. Every finding, every recommendation, every emergency contact, every risk score.
              </p>
              <ul class="space-y-2 mb-6">
