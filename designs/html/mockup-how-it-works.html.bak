    <!-- SECTION 4: 17-SECTION REVIEW GRID                           -->
    <!-- ========================================================== -->
    <section id="review" aria-labelledby="review-heading" class="py-24 lg:py-32 bg-[#e7ecee]">
      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12">

        <!-- Section Header -->
        <div class="text-center mb-16">
          <div class="flex items-center justify-center gap-2 mb-4 fade-up">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#33704b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg>
            <span class="text-eyebrow text-[#33704b]">The Review</span>
          </div>
          <h2 id="review-heading" class="text-display-md text-[#061a23] max-w-[28ch] mx-auto text-center mb-4 fade-up">
            17 Sections. Nothing Missed.
