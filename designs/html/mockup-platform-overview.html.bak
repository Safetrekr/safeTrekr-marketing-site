<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trip Safety Platform | SafeTrekr - Intelligence, Review, Documentation</title>
  <meta name="description" content="SafeTrekr combines government intelligence from 5 data sources, 17-section analyst review, and SHA-256 evidence documentation into a complete trip safety platform. Explore all capabilities.">
  <meta property="og:title" content="The SafeTrekr Platform | Intelligence. Review. Documentation.">
  <meta property="og:description" content="Professional trip safety review powered by government intelligence, analyst expertise, and tamper-evident documentation.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://www.safetrekr.com/platform">
  <link rel="canonical" href="https://www.safetrekr.com/platform">
  <link rel="stylesheet" href="design-tokens.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            background: 'var(--color-background)',
            foreground: 'var(--color-foreground)',
            card: 'var(--color-card)',
            'card-foreground': 'var(--color-card-foreground)',
            border: 'var(--color-border)',
            input: 'var(--color-input)',
            ring: 'var(--color-ring)',
            muted: 'var(--color-muted)',
            'muted-foreground': 'var(--color-muted-foreground)',
            accent: 'var(--color-accent)',
            'accent-foreground': 'var(--color-accent-foreground)',
            primary: {
              50: 'var(--color-primary-50)',
              100: 'var(--color-primary-100)',
              200: 'var(--color-primary-200)',
              300: 'var(--color-primary-300)',
              400: 'var(--color-primary-400)',
              500: 'var(--color-primary-500)',
              600: 'var(--color-primary-600)',
              700: 'var(--color-primary-700)',
              800: 'var(--color-primary-800)',
              900: 'var(--color-primary-900)',
              950: 'var(--color-primary-950)',
              DEFAULT: 'var(--color-primary)',
            },
            secondary: {
              DEFAULT: 'var(--color-secondary)',
              foreground: 'var(--color-secondary-foreground)',
              light: 'var(--color-secondary-light)',
              muted: 'var(--color-secondary-muted)',
            },
            destructive: {
              DEFAULT: 'var(--color-destructive)',
              foreground: 'var(--color-destructive-foreground)',
            },
            safety: {
              green: 'var(--color-safety-green)',
              yellow: 'var(--color-safety-yellow)',
              red: 'var(--color-safety-red)',
            },
          },
          fontFamily: {
            display: ['Plus Jakarta Sans', 'system-ui', '-apple-system', 'sans-serif'],
            body: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
            mono: ['JetBrains Mono', 'ui-monospace', 'monospace'],
          },
          borderRadius: {
            sm: 'var(--radius-sm)',
            md: 'var(--radius-md)',
            lg: 'var(--radius-lg)',
            xl: 'var(--radius-xl)',
            '2xl': 'var(--radius-2xl)',
          },
          boxShadow: {
            xs: 'var(--shadow-xs)',
            sm: 'var(--shadow-sm)',
            md: 'var(--shadow-md)',
            lg: 'var(--shadow-lg)',
            xl: 'var(--shadow-xl)',
          },
          maxWidth: {
            'container': '1280px',
          },
        },
      },
    }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "SoftwareApplication",
        "name": "SafeTrekr",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web",
        "description": "Professional trip safety review platform combining government intelligence data, analyst review, and tamper-evident documentation.",
        "url": "https://www.safetrekr.com/platform",
        "featureList": [
          "Analyst Safety Review",
          "Risk Intelligence Engine",
          "Trip Safety Binder",
          "Mobile Field Operations",
          "Real-Time Monitoring",
          "Compliance & Evidence"
        ],
        "offers": {
          "@type": "AggregateOffer",
          "lowPrice": "450",
          "highPrice": "1250",
          "priceCurrency": "USD",
          "offerCount": "3"
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://www.safetrekr.com"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Platform",
            "item": "https://www.safetrekr.com/platform"
          }
        ]
      }
    ]
  }
  </script>
  <style>
    /* ---- Dot grid pattern for Hero ---- */
    .hero-dot-grid {
      background-image: radial-gradient(circle, var(--color-primary-300) 1px, transparent 1px);
      background-size: 24px 24px;
      opacity: 0.04;
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    /* ---- Glassmorphic header ---- */
    .header-scrolled {
      background: rgba(231, 236, 238, 0.80);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-bottom: 1px solid rgba(184, 195, 199, 0.5);
      box-shadow: var(--shadow-sm);
    }

    /* ---- Fade-up animation for sections ---- */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes cardReveal {
      from { opacity: 0; transform: translateY(24px) scale(0.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .animate-fade-up {
      opacity: 0;
    }
    .animate-fade-up.visible {
      animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .animate-fade-in {
      opacity: 0;
    }
    .animate-fade-in.visible {
      animation: fadeIn 0.3s ease forwards;
    }
    .animate-card-reveal {
      opacity: 0;
    }
    .animate-card-reveal.visible {
      animation: cardReveal 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    /* ---- Card interactive hover ---- */
    .card-interactive {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .card-interactive:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }
    .card-interactive:hover .card-link-arrow {
      transform: translateX(4px);
    }
    .card-link-arrow {
      transition: transform 0.2s ease;
    }

    /* ---- Mechanism card connectors ---- */
    .mechanism-card-connector::after {
      content: '';
      position: absolute;
      right: -17px;
      top: 20px;
      width: 34px;
      border-top: 2px dashed var(--color-primary-200);
    }
    @media (max-width: 1023px) {
      .mechanism-card-connector::after {
        display: none;
      }
    }

    /* ---- Smooth scroll offset for sticky header ---- */
    html {
      scroll-padding-top: 80px;
    }

    /* ---- Mobile menu overlay ---- */
    .mobile-menu-overlay {
      position: fixed;
      inset: 0;
      background: rgba(6, 26, 35, 0.5);
      z-index: 40;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }
    .mobile-menu-overlay.active {
      opacity: 1;
      pointer-events: all;
    }
    .mobile-menu-panel {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: 320px;
      max-width: 85vw;
      background: var(--color-card);
      z-index: 50;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      overflow-y: auto;
      padding: 24px;
    }
    .mobile-menu-panel.active {
      transform: translateX(0);
    }

    /* ---- Counter animation ---- */
    @keyframes countUp {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .stat-animate {
      opacity: 0;
    }
    .stat-animate.visible {
      animation: countUp 0.4s ease-out forwards;
    }

    /* ---- Active nav indicator ---- */
    .nav-active-indicator {
      position: relative;
    }
    .nav-active-indicator::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--color-primary-500);
      border-radius: 1px;
    }

    /* ---- Reduced motion ---- */
    @media (prefers-reduced-motion: reduce) {
      .animate-fade-up,
      .animate-fade-in,
      .animate-card-reveal,
      .stat-animate {
        opacity: 1 !important;
        transform: none !important;
        animation: none !important;
      }
      .card-interactive:hover {
        transform: none;
      }
    }
  </style>
  <script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>
</head>
<body>
  <!-- Skip Navigation -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:bg-card focus:text-foreground focus:px-4 focus:py-2 focus:rounded-md focus:shadow-lg focus:ring-2 focus:ring-ring" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">
    Skip to main content
  </a>

  <!-- ================================================================
       SECTION 1: SITE HEADER (Sticky Glassmorphic)
       ================================================================ -->
  <header id="site-header" class="fixed top-0 left-0 right-0 z-30 transition-all duration-300" style="height: 80px;">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 h-full flex items-center justify-between">
      <!-- Logo: Horizontal lockup -->
      <a href="/" aria-label="SafeTrekr home" class="flex-shrink-0">
        <svg height="32" viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="hidden lg:block" aria-hidden="true">
          <path d="M16 1L3 8v10c0 7.2 5.5 13.9 13 15.9 7.5-2 13-8.7 13-15.9V8L16 1z" fill="none" stroke="#123646" stroke-width="2" stroke-linejoin="round"/>
          <path d="M10 14l4 4 8-8" stroke="#3f885b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="40" y="22" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-weight="700" font-size="18" fill="#123646">SafeTrekr</text>
        </svg>
        <svg height="28" viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="lg:hidden" aria-hidden="true">
          <path d="M16 1L3 8v10c0 7.2 5.5 13.9 13 15.9 7.5-2 13-8.7 13-15.9V8L16 1z" fill="none" stroke="#123646" stroke-width="2" stroke-linejoin="round"/>
          <path d="M10 14l4 4 8-8" stroke="#3f885b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="40" y="22" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-weight="700" font-size="18" fill="#123646">SafeTrekr</text>
        </svg>
      </a>

      <!-- Desktop Nav -->
      <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-8">
        <a href="/platform" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Platform
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="/solutions" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Solutions
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="/how-it-works" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150" style="font-family: var(--font-body);">How It Works</a>
        <a href="/pricing" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150" style="font-family: var(--font-body);">Pricing</a>
        <a href="/resources" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Resources
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </nav>

      <!-- Desktop CTAs -->
      <div class="hidden lg:flex items-center gap-4">
        <a href="https://app.safetrekr.com" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold transition-colors duration-150 hover:text-foreground" style="font-family: var(--font-heading); color: var(--color-muted-foreground);">Sign In</a>
        <a href="/demo" class="inline-flex items-center justify-center font-semibold rounded-md transition-all duration-150 text-white" style="font-family: var(--font-heading); background: var(--color-primary-600); padding: 10px 20px; font-size: 15px; border-radius: var(--radius-md); text-decoration: none;">Get a Demo</a>
      </div>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-foreground" aria-label="Open navigation menu" aria-expanded="false">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-overlay" class="mobile-menu-overlay" aria-hidden="true"></div>
  <div id="mobile-panel" class="mobile-menu-panel" role="dialog" aria-modal="true" aria-label="Main navigation">
    <div class="flex justify-between items-center mb-8">
      <span class="font-display font-bold text-lg text-foreground">Menu</span>
      <button id="mobile-close-btn" class="p-2 text-foreground" aria-label="Close navigation menu">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <nav class="flex flex-col gap-2">
      <a href="/platform" class="py-3 px-4 rounded-md text-base font-semibold text-foreground bg-primary-50 transition-colors" style="font-family: var(--font-body);">Platform</a>
      <a href="/solutions" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Solutions</a>
      <a href="/how-it-works" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">How It Works</a>
      <a href="/pricing" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Pricing</a>
      <a href="/resources" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Resources</a>
      <div class="border-t mt-4 pt-4" style="border-color: var(--color-border);">
        <a href="/demo" class="block w-full text-center py-3 rounded-md text-base font-semibold text-white" style="background: var(--color-primary-600); font-family: var(--font-heading);">Get a Demo</a>
      </div>
    </nav>
  </div>

  <!-- ================================================================
       MAIN CONTENT
       ================================================================ -->
  <main id="main-content">

    <!-- ================================================================
         SECTION 2: HERO
         Surface: background (#e7ecee)
         ================================================================ -->
    <section aria-label="Platform overview" class="relative overflow-hidden" style="background: var(--color-background); padding-top: 176px; padding-bottom: 80px;">
      <!-- Dot grid background -->
      <div class="hero-dot-grid" aria-hidden="true"></div>

      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 relative z-10">
        <div class="text-center max-w-[800px] mx-auto">
          <!-- Eyebrow -->
          <div class="animate-fade-in flex items-center justify-center gap-2 mb-6" style="animation-delay: 0ms;">
            <!-- Shield path icon -->
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary-700);">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span class="text-eyebrow" style="color: var(--color-primary-700);">THE SAFETREKR PLATFORM</span>
          </div>

          <!-- Headline -->
          <h1 class="animate-fade-up text-display-lg text-foreground" style="max-width: 28ch; margin: 0 auto; animation-delay: 100ms;">
            Intelligence. Review.<br class="hidden sm:inline"> Documentation.
          </h1>

          <!-- Subheadline -->
          <p class="animate-fade-up text-body-lg text-muted mt-6" style="max-width: 60ch; margin-left: auto; margin-right: auto; color: var(--color-muted-foreground); animation-delay: 250ms;">
            Every trip goes through the same rigorous process: government intelligence analysis, professional safety review, and tamper-evident documentation. Here is every capability that protects your travelers and your organization.
          </p>

          <!-- CTA Buttons -->
          <div class="animate-fade-up flex flex-col sm:flex-row flex-wrap justify-center gap-3 sm:gap-4 mt-8" style="animation-delay: 400ms;">
            <a href="/demo" class="btn btn-lg btn-primary w-full sm:w-auto" style="font-family: var(--font-heading); font-size: 16px; font-weight: 600; padding: 16px 32px; border-radius: var(--radius-md); background: var(--color-primary-600); color: #fff; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; gap: 8px;">
              Get a Demo
              <!-- ArrowRight icon -->
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href="/resources/sample-binders" class="btn btn-lg btn-secondary w-full sm:w-auto" style="font-family: var(--font-heading); font-size: 16px; font-weight: 600; padding: 16px 32px; border-radius: var(--radius-md); border: 1.5px solid var(--color-border); background: transparent; color: var(--color-foreground); text-decoration: none; display: inline-flex; align-items: center; justify-content: center; gap: 8px;">
              See Sample Binder
              <!-- Download icon -->
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================
         SECTION 3: 3-ACT MECHANISM PREVIEW
         Surface: primary-50 (#f1f9f4) -- accent wash
         ================================================================ -->
    <section aria-label="How SafeTrekr works" data-theme="brand" style="background: var(--color-primary-50); padding: 96px 0;" class="section-observer">
      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12">
        <!-- Section Header -->
        <div class="text-center">
          <span class="animate-fade-up text-eyebrow" style="color: var(--color-primary-700);">HOW SAFETREKR WORKS</span>
          <h2 class="animate-fade-up text-heading-lg text-foreground mt-3" style="animation-delay: 80ms;">Three acts. One rigorous process.</h2>
        </div>

        <!-- 3-Act Card Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8 mt-12">

          <!-- Card 1: Intelligence -->
          <a href="/platform/risk-intelligence" class="animate-card-reveal card-interactive relative group block rounded-xl p-6 lg:p-8 mechanism-card-connector" style="background: var(--color-card); border: 1px solid var(--color-border); box-shadow: var(--shadow-sm); text-decoration: none; animation-delay: 200ms;" aria-label="Intelligence: Explore risk intelligence capabilities">
            <!-- Step Number -->
            <div class="h-10 w-10 rounded-full flex items-center justify-center flex-shrink-0" style="background: var(--color-primary-100);" aria-hidden="true">
              <span class="text-heading-sm font-semibold" style="color: var(--color-primary-700); font-family: var(--font-heading);">1</span>
            </div>
            <!-- Icon Container -->
            <div class="h-14 w-14 rounded-lg flex items-center justify-center mt-4" style="background: var(--color-primary-50);">
              <!-- Route icon -->
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary-500);">
                <circle cx="6" cy="19" r="3"/><path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"/><circle cx="18" cy="5" r="3"/>
              </svg>
            </div>
            <!-- Title -->
            <h3 class="text-heading-md mt-4" style="color: var(--color-foreground); font-family: var(--font-heading);">Intelligence</h3>
            <!-- Description -->
            <p class="text-body-md mt-2" style="color: var(--color-muted-foreground); max-width: 45ch;">
              Government data from 5 sources -- NOAA, USGS, CDC, GDACS, and ReliefWeb -- scored by Monte Carlo simulation for every destination on your itinerary.
            </p>
            <!-- Link -->
            <span class="inline-flex items-center gap-1 mt-4 text-body-sm font-medium" style="color: var(--color-primary-700);">
              Explore Risk Intelligence
              <svg class="w-4 h-4 card-link-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>

          <!-- Card 2: Review -->
          <a href="/platform/analyst-review" class="animate-card-reveal card-interactive relative group block rounded-xl p-6 lg:p-8 mechanism-card-connector" style="background: var(--color-card); border: 1px solid var(--color-border); box-shadow: var(--shadow-sm); text-decoration: none; animation-delay: 280ms;" aria-label="Review: See the analyst review capabilities">
            <!-- Step Number -->
            <div class="h-10 w-10 rounded-full flex items-center justify-center flex-shrink-0" style="background: var(--color-primary-100);" aria-hidden="true">
              <span class="text-heading-sm font-semibold" style="color: var(--color-primary-700); font-family: var(--font-heading);">2</span>
            </div>
            <!-- Icon Container -->
            <div class="h-14 w-14 rounded-lg flex items-center justify-center mt-4" style="background: var(--color-primary-50);">
              <!-- ClipboardCheck icon -->
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary-500);">
                <rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/>
              </svg>
            </div>
            <!-- Title -->
            <h3 class="text-heading-md mt-4" style="color: var(--color-foreground); font-family: var(--font-heading);">Review</h3>
            <!-- Description -->
