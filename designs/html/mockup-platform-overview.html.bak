          </ul>
          <h3 class="text-body-sm font-semibold uppercase tracking-wide mb-4 mt-6" style="color: #f7f8f8;">How It Works</h3>
          <ul class="space-y-1" style="list-style: none;">
            <li><a href="/how-it-works" class="block py-1 text-body-sm footer-link">How It Works</a></li>
            <li><a href="/pricing" class="block py-1 text-body-sm footer-link">Pricing</a></li>
          </ul>
        </nav>

        <!-- Column 3: Resources -->
        <nav aria-label="Resources links">
          <h3 class="text-body-sm font-semibold uppercase tracking-wide mb-4" style="color: #f7f8f8;">Resources</h3>
          <ul class="space-y-1" style="list-style: none;">
            <li><a href="/resources/case-studies" class="block py-1 text-body-sm footer-link">Case Studies</a></li>
            <li><a href="/resources/guides" class="block py-1 text-body-sm footer-link">Guides</a></li>
            <li><a href="/resources/sample-binders" class="block py-1 text-body-sm footer-link">Sample Binders</a></li>
            <li><a href="/resources/faq" class="block py-1 text-body-sm footer-link">FAQ</a></li>
          </ul>
        </nav>

        <!-- Column 4: Company -->
        <nav aria-label="Company links">
          <h3 class="text-body-sm font-semibold uppercase tracking-wide mb-4" style="color: #f7f8f8;">Company</h3>
          <ul class="space-y-1" style="list-style: none;">
            <li><a href="/about" class="block py-1 text-body-sm footer-link">About SafeTrekr</a></li>
            <li><a href="/about/analysts" class="block py-1 text-body-sm footer-link">Our Analysts</a></li>
            <li><a href="/security" class="block py-1 text-body-sm footer-link">Security and Trust</a></li>
            <li><a href="/contact" class="block py-1 text-body-sm footer-link">Contact</a></li>
          </ul>
        </nav>
      </div>

      <!-- Bottom Bar -->
      <div class="mt-12 pt-8" style="border-top: 1px solid rgba(255,255,255,0.12);">
        <!-- Brand description -->
        <p class="text-body-sm" style="color: #b8c3c7; max-width: 65ch; line-height: 1.6;">
          Professional trip safety review and evidence documentation for organizations that protect travelers.
        </p>

        <!-- Copyright + Legal -->
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mt-4" style="font-size: 12px; color: #b8c3c7;">
          <span>&copy; 2026 SafeTrekr, Inc. All rights reserved.</span>
          <span style="color: rgba(255,255,255,0.2);" aria-hidden="true">|</span>
          <a href="/legal/terms" class="footer-link" style="font-size: 12px;">Terms of Service</a>
          <span style="color: rgba(255,255,255,0.2);" aria-hidden="true">|</span>
          <a href="/legal/privacy" class="footer-link" style="font-size: 12px;">Privacy Policy</a>
          <span style="color: rgba(255,255,255,0.2);" aria-hidden="true">|</span>
          <a href="/legal/dpa" class="footer-link" style="font-size: 12px;">DPA</a>
        </div>

        <!-- Data source attribution -->
        <div class="mt-4" style="font-size: 12px; color: #b8c3c7;">
          Data sourced from: NOAA | USGS | CDC | GDACS | ReliefWeb
        </div>
      </div>
    </div>
  </footer>

  <!-- ================================================================
       JAVASCRIPT: Header scroll, Mobile menu, Intersection Observer, Counters
       ================================================================ -->
  <script>
    // ---- Sticky header scroll behavior ----
    const header = document.getElementById('site-header');
    let lastScroll = 0;
    function onScroll() {
      const scrollY = window.scrollY;
      if (scrollY > 100) {
        header.classList.add('header-scrolled');
        header.style.height = '64px';
      } else {
        header.classList.remove('header-scrolled');
        header.style.height = '80px';
      }
      lastScroll = scrollY;
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // ---- Mobile menu ----
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-close-btn');
    const overlay = document.getElementById('mobile-overlay');
    const panel = document.getElementById('mobile-panel');

    function openMenu() {
      overlay.classList.add('active');
      panel.classList.add('active');
      overlay.setAttribute('aria-hidden', 'false');
      menuBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      overlay.classList.remove('active');
      panel.classList.remove('active');
      overlay.setAttribute('aria-hidden', 'true');
      menuBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    menuBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    overlay.addEventListener('click', closeMenu);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeMenu();
    });

    // ---- Intersection Observer for scroll-triggered animations ----
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReducedMotion) {
      const animatedElements = document.querySelectorAll('.animate-fade-up, .animate-fade-in, .animate-card-reveal, .stat-animate');

      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            const el = entry.target;
            const delay = el.style.animationDelay || '0ms';
            const delayMs = parseInt(delay);

            setTimeout(function() {
              el.classList.add('visible');
            }, delayMs);

            observer.unobserve(el);
          }
        });
      }, {
        threshold: 0.2,
        rootMargin: '0px 0px -50px 0px'
      });

      animatedElements.forEach(function(el) {
        observer.observe(el);
      });
    } else {
      // Reduced motion: show everything immediately
      document.querySelectorAll('.animate-fade-up, .animate-fade-in, .animate-card-reveal, .stat-animate').forEach(function(el) {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    }

    // ---- Animated counters for stat values ----
    if (!prefersReducedMotion) {
      const counters = document.querySelectorAll('[data-count-to]');
      const counterObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            const el = entry.target;
            const target = parseInt(el.getAttribute('data-count-to'));
            const duration = 800;
            const startTime = performance.now();

            function updateCounter(currentTime) {
              const elapsed = currentTime - startTime;
              const progress = Math.min(elapsed / duration, 1);
              // Ease out cubic
              const eased = 1 - Math.pow(1 - progress, 3);
              const current = Math.round(eased * target);
              el.textContent = current;

              if (progress < 1) {
                requestAnimationFrame(updateCounter);
              } else {
                el.textContent = target;
              }
            }

            requestAnimationFrame(updateCounter);
            counterObserver.unobserve(el);
          }
        });
      }, {
        threshold: 0.5
      });

      counters.forEach(function(counter) {
        counterObserver.observe(counter);
      });
    }

    // ---- CTA Band button hover states ----
    const ctaDarkPrimary = document.querySelector('[data-theme="dark"] a[href="/demo"]');
    const ctaDarkSecondary = document.querySelector('[data-theme="dark"] a[href="/resources/sample-binders"]');

    if (ctaDarkPrimary) {
      ctaDarkPrimary.addEventListener('mouseenter', function() {
        this.style.background = 'var(--color-primary-50)';
      });
      ctaDarkPrimary.addEventListener('mouseleave', function() {
        this.style.background = '#ffffff';
      });
    }
    if (ctaDarkSecondary) {
      ctaDarkSecondary.addEventListener('mouseenter', function() {
        this.style.background = 'rgba(255,255,255,0.1)';
      });
      ctaDarkSecondary.addEventListener('mouseleave', function() {
        this.style.background = 'transparent';
      });
    }

    // ---- Responsive section padding adjustments ----
    function adjustResponsivePadding() {
      const w = window.innerWidth;
      const heroSection = document.querySelector('[aria-label="Platform overview"]');
      const mechanismSection = document.querySelector('[aria-label="How SafeTrekr works"]');
      const featureSection = document.querySelector('[aria-label="Platform capabilities"]');
      const trustSection = document.querySelector('[aria-label="Platform credentials"]');
      const ctaSection = document.querySelector('[aria-label="Request a demo"]');

      if (w <= 767) {
        // Mobile
        if (heroSection) { heroSection.style.paddingTop = '144px'; heroSection.style.paddingBottom = '48px'; }
        if (mechanismSection) { mechanismSection.style.padding = '48px 0'; }
        if (featureSection) { featureSection.style.padding = '48px 0'; }
        if (trustSection) { trustSection.style.padding = '32px 0'; }
        if (ctaSection) { ctaSection.style.padding = '64px 0'; }
      } else if (w <= 1023) {
        // Tablet
        if (heroSection) { heroSection.style.paddingTop = '160px'; heroSection.style.paddingBottom = '64px'; }
        if (mechanismSection) { mechanismSection.style.padding = '64px 0'; }
        if (featureSection) { featureSection.style.padding = '64px 0'; }
        if (trustSection) { trustSection.style.padding = '40px 0'; }
        if (ctaSection) { ctaSection.style.padding = '80px 0'; }
      } else {
        // Desktop
        if (heroSection) { heroSection.style.paddingTop = '176px'; heroSection.style.paddingBottom = '80px'; }
        if (mechanismSection) { mechanismSection.style.padding = '96px 0'; }
        if (featureSection) { featureSection.style.padding = '96px 0'; }
        if (trustSection) { trustSection.style.padding = '48px 0'; }
        if (ctaSection) { ctaSection.style.padding = '112px 0'; }
      }
    }

    adjustResponsivePadding();
    window.addEventListener('resize', adjustResponsivePadding, { passive: true });
  </script>
</body>
</html>