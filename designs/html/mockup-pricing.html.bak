        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8">
          <a href="/demo" class="btn btn-primary-on-dark btn-lg w-full sm:w-auto">Get a Demo</a>
          <a href="/contact" class="btn btn-ghost-on-dark btn-lg w-full sm:w-auto">Contact Sales</a>
        </div>
      </div>
    </section>

  </main>

