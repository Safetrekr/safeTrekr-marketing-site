        <p class="text-body-md" style="color: var(--color-secondary-muted); max-width: 50ch; margin: 0 auto 32px;">Our team is here to help. Get answers about SafeTrekr for your organization.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/contact" class="btn btn-md" style="background: transparent; border: 1.5px solid rgba(255,255,255,0.2); color: #f7f8f8; text-decoration: none;">Contact Us</a>
          <a href="/demo" class="btn btn-md" style="background: #ffffff; color: var(--color-secondary); text-decoration: none; font-weight: 600;">Get a Demo</a>
        </div>
      </div>
    </section>

  </main>

