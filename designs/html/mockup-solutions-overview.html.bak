<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Solutions by Organization Type | SafeTrekr</title>
  <meta name="description" content="SafeTrekr provides professional trip safety review and evidence documentation for K-12 schools, higher education, churches, and corporate organizations. Find the right solution for your organization.">
  <meta property="og:title" content="Solutions by Organization Type | SafeTrekr">
  <meta property="og:description" content="Professional trip safety review for schools, universities, churches, and businesses. Every trip reviewed. Every risk scored. Every document audit-ready.">
  <meta property="og:url" content="https://safetrekr.com/solutions">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://safetrekr.com/og/solutions.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <link rel="stylesheet" href="design-tokens.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            background: 'var(--color-background)',
            foreground: 'var(--color-foreground)',
            card: 'var(--color-card)',
            'card-foreground': 'var(--color-card-foreground)',
            border: 'var(--color-border)',
            input: 'var(--color-input)',
            ring: 'var(--color-ring)',
            muted: 'var(--color-muted)',
            'muted-foreground': 'var(--color-muted-foreground)',
            accent: 'var(--color-accent)',
            'accent-foreground': 'var(--color-accent-foreground)',
            primary: {
              50: 'var(--color-primary-50)',
              100: 'var(--color-primary-100)',
              200: 'var(--color-primary-200)',
              300: 'var(--color-primary-300)',
              400: 'var(--color-primary-400)',
              500: 'var(--color-primary-500)',
              600: 'var(--color-primary-600)',
              700: 'var(--color-primary-700)',
              800: 'var(--color-primary-800)',
              900: 'var(--color-primary-900)',
              950: 'var(--color-primary-950)',
              DEFAULT: 'var(--color-primary)',
            },
            secondary: {
              DEFAULT: 'var(--color-secondary)',
              foreground: 'var(--color-secondary-foreground)',
              light: 'var(--color-secondary-light)',
              muted: 'var(--color-secondary-muted)',
            },
            destructive: {
              DEFAULT: 'var(--color-destructive)',
              foreground: 'var(--color-destructive-foreground)',
            },
            safety: {
              green: 'var(--color-safety-green)',
              yellow: 'var(--color-safety-yellow)',
              red: 'var(--color-safety-red)',
            },
          },
          fontFamily: {
            display: ['Plus Jakarta Sans', 'system-ui', '-apple-system', 'sans-serif'],
            body: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
            mono: ['JetBrains Mono', 'ui-monospace', 'monospace'],
          },
          borderRadius: {
            sm: 'var(--radius-sm)',
            md: 'var(--radius-md)',
            lg: 'var(--radius-lg)',
            xl: 'var(--radius-xl)',
            '2xl': 'var(--radius-2xl)',
          },
          boxShadow: {
            xs: 'var(--shadow-xs)',
            sm: 'var(--shadow-sm)',
            md: 'var(--shadow-md)',
            lg: 'var(--shadow-lg)',
            xl: 'var(--shadow-xl)',
          },
          maxWidth: {
            'container': '1280px',
          },
        },
      },
    }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebPage",
        "name": "Solutions - SafeTrekr",
        "description": "SafeTrekr provides professional trip safety review and evidence documentation for K-12 schools, higher education, churches, and corporate organizations.",
        "url": "https://safetrekr.com/solutions",
        "isPartOf": {
          "@type": "WebSite",
          "name": "SafeTrekr",
          "url": "https://safetrekr.com"
        }
      },
      {
        "@type": "ItemList",
        "name": "SafeTrekr Solutions by Organization Type",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "K-12 Schools and Districts",
            "url": "https://safetrekr.com/solutions/k12"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Higher Education",
            "url": "https://safetrekr.com/solutions/higher-education"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "Churches and Mission Organizations",
            "url": "https://safetrekr.com/solutions/churches"
          },
          {
            "@type": "ListItem",
            "position": 4,
            "name": "Corporate and Sports Teams",
            "url": "https://safetrekr.com/solutions/corporate"
          }
        ]
      }
    ]
  }
  </script>
  <style>
    /* ---- Dot grid pattern for Hero ---- */
    .hero-dot-grid {
      background-image: radial-gradient(circle, var(--color-primary-300) 1px, transparent 1px);
      background-size: 24px 24px;
      opacity: 0.04;
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    /* ---- Glassmorphic header ---- */
    .header-scrolled {
      background: rgba(231, 236, 238, 0.80);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-bottom: 1px solid rgba(184, 195, 199, 0.5);
      box-shadow: var(--shadow-sm);
    }

    /* ---- Mobile menu overlay ---- */
    .mobile-menu-overlay {
      position: fixed;
      inset: 0;
      background: rgba(6, 26, 35, 0.5);
      z-index: 40;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }
    .mobile-menu-overlay.active {
      opacity: 1;
      pointer-events: all;
    }
    .mobile-menu-panel {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: 320px;
      max-width: 85vw;
      background: var(--color-card);
      z-index: 50;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      overflow-y: auto;
      padding: 24px;
    }
    .mobile-menu-panel.active {
      transform: translateX(0);
    }

    /* ---- Fade-up animation for sections ---- */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes cardReveal {
      from { opacity: 0; transform: translateY(24px) scale(0.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .animate-fade-up {
      animation: fadeUp 0.5s ease-out forwards;
      opacity: 0;
    }
    .animate-fade-in {
      animation: fadeIn 0.3s ease-out forwards;
      opacity: 0;
    }
    .animate-card-reveal {
      animation: cardReveal 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      opacity: 0;
    }

    /* ---- Segment card hover ---- */
    .segment-card {
      transition: all 0.2s ease;
    }
    .segment-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-xl);
    }
    .segment-card:hover .segment-card-title {
      color: var(--color-primary-700);
    }
    .segment-card:hover .segment-card-arrow {
      transform: translateX(4px);
    }
    .segment-card-arrow {
      transition: transform 0.15s ease;
    }

    /* ---- Feature card hover ---- */
    .feature-card {
      transition: all 0.2s ease;
    }
    .feature-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-xl);
    }
    .feature-card:hover .feature-card-arrow {
      transform: translateX(4px);
    }
    .feature-card-arrow {
      transition: transform 0.15s ease;
    }

    /* ---- Counter animation ---- */
    @keyframes countUp {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .stat-animate {
      animation: countUp 0.6s ease-out forwards;
      opacity: 0;
    }

    /* ---- Reduced motion ---- */
    @media (prefers-reduced-motion: reduce) {
      .animate-fade-up,
      .animate-fade-in,
      .animate-card-reveal,
      .stat-animate {
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
      }
      .segment-card:hover,
      .feature-card:hover {
        transform: none;
      }
      .segment-card:hover .segment-card-arrow,
      .feature-card:hover .feature-card-arrow {
        transform: none;
      }
    }
  </style>
</head>
<body>
  <!-- Skip Navigation -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:bg-card focus:text-foreground focus:px-4 focus:py-2 focus:rounded-md focus:shadow-lg focus:ring-2 focus:ring-ring">
    Skip to main content
  </a>

  <!-- ================================================================
       SECTION 1: SITE HEADER
       ================================================================ -->
  <header id="site-header" class="fixed top-0 left-0 right-0 z-30 transition-all duration-300" style="height: 80px;">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 h-full flex items-center justify-between">
      <!-- Logo: Horizontal lockup -->
      <a href="/" aria-label="SafeTrekr home" class="flex-shrink-0">
        <svg height="32" viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="hidden lg:block" aria-hidden="true">
          <path d="M16 1L3 8v10c0 7.2 5.5 13.9 13 15.9 7.5-2 13-8.7 13-15.9V8L16 1z" fill="none" stroke="#123646" stroke-width="2" stroke-linejoin="round"/>
          <path d="M10 14l4 4 8-8" stroke="#3f885b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="40" y="22" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-weight="700" font-size="18" fill="#123646">SafeTrekr</text>
        </svg>
        <svg height="28" viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="lg:hidden" aria-hidden="true">
          <path d="M16 1L3 8v10c0 7.2 5.5 13.9 13 15.9 7.5-2 13-8.7 13-15.9V8L16 1z" fill="none" stroke="#123646" stroke-width="2" stroke-linejoin="round"/>
          <path d="M10 14l4 4 8-8" stroke="#3f885b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="40" y="22" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-weight="700" font-size="18" fill="#123646">SafeTrekr</text>
        </svg>
      </a>

      <!-- Desktop Nav -->
      <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-8">
        <a href="/platform" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Platform
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="/solutions" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Solutions
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="/how-it-works" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150" style="font-family: var(--font-body);">How It Works</a>
        <a href="/pricing" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150" style="font-family: var(--font-body);">Pricing</a>
        <a href="/resources" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Resources
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </nav>

      <!-- Desktop CTAs -->
      <div class="hidden lg:flex items-center gap-4">
        <a href="https://app.safetrekr.com" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold transition-colors duration-150 hover:text-foreground" style="font-family: var(--font-heading); color: var(--color-muted-foreground);">Sign In</a>
        <a href="/demo" class="inline-flex items-center justify-center font-semibold rounded-md transition-all duration-150 text-white" style="font-family: var(--font-heading); background: var(--color-primary-600); padding: 10px 20px; font-size: 15px; border-radius: var(--radius-md); text-decoration: none;">Get a Demo</a>
      </div>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-foreground" aria-label="Open navigation menu" aria-expanded="false">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-overlay" class="mobile-menu-overlay" aria-hidden="true"></div>
  <div id="mobile-panel" class="mobile-menu-panel" role="dialog" aria-modal="true" aria-label="Main navigation">
    <div class="flex justify-between items-center mb-8">
      <span class="font-display font-bold text-lg text-foreground">Menu</span>
      <button id="mobile-close-btn" class="p-2 text-foreground" aria-label="Close navigation menu">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <nav class="flex flex-col gap-2">
      <a href="/platform" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Platform</a>
      <a href="/solutions" aria-current="page" class="py-3 px-4 rounded-md text-base font-semibold text-foreground" style="font-family: var(--font-body); background: var(--color-primary-50);">Solutions</a>
      <a href="/how-it-works" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">How It Works</a>
      <a href="/pricing" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Pricing</a>
      <a href="/resources" class="py-3 px-4 rounded-md text-base font-medium text-foreground hover:bg-primary-50 transition-colors" style="font-family: var(--font-body);">Resources</a>
      <div class="border-t mt-4 pt-4" style="border-color: var(--color-border);">
        <a href="/demo" class="block w-full text-center py-3 rounded-md text-base font-semibold text-white" style="background: var(--color-primary-600); font-family: var(--font-heading);">Get a Demo</a>
      </div>
    </nav>
  </div>

  <!-- ================================================================
       MAIN CONTENT
       ================================================================ -->
  <main id="main-content">

    <!-- ================================================================
         SECTION 2: HERO
         ================================================================ -->
    <section aria-labelledby="hero-heading" class="relative overflow-hidden" style="background: var(--color-background); padding-top: 160px; padding-bottom: 80px;">
      <!-- Dot grid -->
      <div class="hero-dot-grid"></div>

      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 relative z-10">
        <div class="text-center max-w-3xl mx-auto">
          <!-- Eyebrow -->
          <span class="animate-fade-in text-eyebrow inline-flex items-center justify-center gap-2" style="color: var(--color-primary-700);">
            <!-- Building2 icon -->
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary-700);">
              <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/>
              <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/>
              <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/>
              <path d="M10 6h4"/>
              <path d="M10 10h4"/>
              <path d="M10 14h4"/>
              <path d="M10 18h4"/>
            </svg>
            SOLUTIONS BY ORGANIZATION TYPE
          </span>

          <!-- Headline -->
          <h1 id="hero-heading" class="text-display-lg text-foreground mt-4 animate-fade-up" style="max-width: 28ch; margin-left: auto; margin-right: auto; animation-delay: 100ms;">
            One platform. Every type of trip. Every organization protected.
          </h1>

          <!-- Subtext -->
          <p class="text-body-lg mt-6 animate-fade-up" style="color: var(--color-muted-foreground); max-width: 55ch; margin-left: auto; margin-right: auto; animation-delay: 250ms;">
            Schools, universities, churches, and businesses trust SafeTrekr to professionally review every trip, score every risk, and document every safety decision.
          </p>

          <!-- CTA -->
          <div class="mt-8 animate-fade-up" style="animation-delay: 400ms;">
            <a href="#segment-cards" class="btn btn-ghost btn-md inline-flex items-center gap-2" style="font-family: var(--font-heading); font-weight: 600; color: var(--color-muted-foreground);">
              Find Your Solution
              <!-- ChevronDown icon -->
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================
         SECTION 3: SEGMENT CARDS
         ================================================================ -->
    <section id="segment-cards" aria-labelledby="segment-cards-heading" style="background: var(--color-card); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); padding: 96px 0;">
      <h2 id="segment-cards-heading" class="sr-only">Solutions by organization type</h2>

      <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12">
        <div class="grid md:grid-cols-2 gap-4 md:gap-6 lg:gap-8">

          <!-- Card 1: K-12 Schools and Districts -->
          <a href="/solutions/k12" aria-label="Learn more about SafeTrekr solutions for K-12 schools and districts" class="segment-card block bg-white rounded-2xl border p-6 lg:p-10 animate-card-reveal focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 focus:rounded-2xl" style="border-color: var(--color-border); box-shadow: var(--shadow-sm); min-height: 320px; text-decoration: none; animation-delay: 0ms;">
            <!-- Icon -->
            <div class="h-14 w-14 rounded-xl flex items-center justify-center" style="background: var(--color-primary-50);">
              <!-- GraduationCap icon -->
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary-700);">
                <path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/>
                <path d="M22 10v6"/>
                <path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/>
              </svg>
            </div>
            <!-- Title -->
            <h3 class="segment-card-title text-heading-lg mt-5 transition-colors duration-200" style="color: var(--color-foreground);">K-12 Schools and Districts</h3>
            <!-- Badges -->
            <div class="flex flex-wrap gap-2 mt-3">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border" style="background: var(--color-card); color: var(--color-foreground); border-color: var(--color-border);">FERPA</span>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border" style="background: var(--color-card); color: var(--color-foreground); border-color: var(--color-border);">COPPA</span>
            </div>
            <!-- Description -->
            <p class="text-body-md mt-4" style="color: var(--color-muted-foreground); max-width: 45ch;">
              Every field trip deserves the same safety rigor as a commercial flight. SafeTrekr gives your district a professional analyst review of every destination, government-sourced risk intelligence, and board-ready documentation that proves due diligence -- starting at $15 per student.
            </p>
            <!-- CTA Link -->
            <span class="inline-flex items-center gap-1.5 mt-6 text-body-md font-semibold" style="color: var(--color-primary-700);">
              Learn More
              <svg class="w-4 h-4 segment-card-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </span>
          </a>

          <!-- Card 2: Higher Education -->
          <a href="/solutions/higher-education" aria-label="Learn more about SafeTrekr solutions for higher education institutions" class="segment-card block bg-white rounded-2xl border p-6 lg:p-10 animate-card-reveal focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 focus:rounded-2xl" style="border-color: var(--color-border); box-shadow: var(--shadow-sm); min-height: 320px; text-decoration: none; animation-delay: 100ms;">
            <!-- Icon -->
            <div class="h-14 w-14 rounded-xl flex items-center justify-center" style="background: var(--color-primary-50);">
              <!-- Building2 icon -->
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary-700);">
                <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/>
                <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/>
                <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/>
                <path d="M10 6h4"/>
                <path d="M10 10h4"/>
                <path d="M10 14h4"/>
                <path d="M10 18h4"/>
              </svg>
            </div>
            <!-- Title -->
            <h3 class="segment-card-title text-heading-lg mt-5 transition-colors duration-200" style="color: var(--color-foreground);">Higher Education</h3>
            <!-- Badges -->
            <div class="flex flex-wrap gap-2 mt-3">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border" style="background: var(--color-card); color: var(--color-foreground); border-color: var(--color-border);">CLERY ACT</span>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border" style="background: var(--color-card); color: var(--color-foreground); border-color: var(--color-border);">FERPA</span>
            </div>
            <!-- Description -->
            <p class="text-body-md mt-4" style="color: var(--color-muted-foreground); max-width: 45ch;">
              Study abroad and international program safety backed by institutional-grade risk assessment. SafeTrekr provides your risk management office and general counsel with professionally reviewed, tamper-evident documentation for every program trip -- from spring break service trips to semester-long study abroad.
            </p>
            <!-- CTA Link -->
            <span class="inline-flex items-center gap-1.5 mt-6 text-body-md font-semibold" style="color: var(--color-primary-700);">
