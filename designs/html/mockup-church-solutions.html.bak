              </div>
              <!-- Front page -->
              <div class="binder-page binder-page-front" style="width: calc(100% - 40px);">
                <!-- SafeTrekr mark -->
                <div class="flex items-center gap-2 mb-1">
                  <svg width="20" height="20" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                    <rect width="32" height="32" rx="6" fill="#3f885b"/>
                    <path d="M16 6l8 4v6c0 5.33-3.33 10.33-8 12-4.67-1.67-8-6.67-8-12v-6l8-4z" fill="white" fill-opacity="0.9"/>
                  </svg>
                  <span class="text-xs font-medium uppercase tracking-wider" style="color: var(--color-primary-700);">International Mission Trip</span>
                </div>
                <div class="font-heading text-xl font-bold mt-2" style="color: var(--color-foreground);">Safety Binder</div>
                <div class="text-sm mt-1" style="color: var(--color-muted-foreground);">Guatemala City -- Antigua -- Lake Atitlan</div>
                <div class="text-xs mt-1" style="color: var(--color-muted-foreground);">June 15-22, 2026</div>
                <div class="mt-3">
                  <span class="badge badge-brand text-xs">17 Sections Reviewed</span>
                </div>
                <!-- Map thumbnail -->
