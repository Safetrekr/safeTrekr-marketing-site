  <!-- ============================================================
       JAVASCRIPT
       ============================================================ -->
  <script>
    // ── Pricing Calculator ──
    (function() {
      const studentsSlider = document.getElementById('students-slider');
      const tripsSlider = document.getElementById('trips-slider');
      const studentsValue = document.getElementById('students-value');
      const tripsValue = document.getElementById('trips-value');
      const resultAnnual = document.getElementById('result-annual');
      const resultPerTrip = document.getElementById('result-per-trip');
      const compareSafetrekr = document.getElementById('compare-safetrekr');
      const compareStaff = document.getElementById('compare-staff');
      const compareTripsCount = document.getElementById('compare-trips-count');

      function formatCurrency(n) {
        return '$' + n.toLocaleString('en-US');
      }

      function updateCalculator() {
        var students = parseInt(studentsSlider.value);
        var trips = parseInt(tripsSlider.value);
        var annual = students * 15 * trips;
        var perTrip = students * 15;
        var staffLow = trips * 700;
        var staffHigh = trips * 1400;

        studentsValue.textContent = students;
        tripsValue.textContent = trips;

        resultAnnual.textContent = formatCurrency(annual);
        resultAnnual.setAttribute('aria-label', 'Annual SafeTrekr cost: ' + formatCurrency(annual));

        resultPerTrip.textContent = formatCurrency(perTrip);
        resultPerTrip.setAttribute('aria-label', 'Cost per trip: ' + formatCurrency(perTrip));

        compareSafetrekr.textContent = formatCurrency(annual) + '/year';
        compareStaff.textContent = formatCurrency(staffLow) + ' - ' + formatCurrency(staffHigh) + '/year';
        compareTripsCount.textContent = trips;

        studentsSlider.setAttribute('aria-valuenow', students);
        studentsSlider.setAttribute('aria-valuetext', students + ' students per trip');
        tripsSlider.setAttribute('aria-valuenow', trips);
        tripsSlider.setAttribute('aria-valuetext', trips + ' trips per year');
      }

      studentsSlider.addEventListener('input', updateCalculator);
      tripsSlider.addEventListener('input', updateCalculator);
    })();

    // ── Sticky Anchor Nav ──
    (function() {
      var anchorNav = document.getElementById('anchor-nav');
      var hero = document.getElementById('hero');
      var sections = ['challenge', 'solutions', 'binder-preview', 'pricing', 'compliance', 'faq'];
      var navLinks = anchorNav.querySelectorAll('a');

      // Show/hide anchor nav based on hero scroll position
      var heroObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            anchorNav.classList.remove('visible');
          } else {
            anchorNav.classList.add('visible');
          }
        });
      }, { threshold: 0, rootMargin: '-72px 0px 0px 0px' });

      heroObserver.observe(hero);

      // Active section tracking
      var sectionObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var id = entry.target.id;
            navLinks.forEach(function(link) {
              if (link.getAttribute('href') === '#' + id) {
                link.classList.add('active');
              } else {
                link.classList.remove('active');
              }
            });
            // Auto-scroll active item into view on mobile
            var activeLink = anchorNav.querySelector('a.active');
            if (activeLink) {
              activeLink.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
            }
          }
        });
      }, { threshold: 0.15, rootMargin: '-140px 0px -50% 0px' });

      sections.forEach(function(id) {
        var el = document.getElementById(id);
        if (el) sectionObserver.observe(el);
      });
    })();
  </script>

  <!-- ── Responsive Grid Adjustments via Tailwind + inline media queries ── -->
  <style>
    /* Hero grid: 2-column on lg */
    @media (min-width: 1024px) {
      #hero-grid { grid-template-columns: 1fr 1fr; }
    }

    /* Proof strip: responsive columns */
    @media (min-width: 768px) {
      #proof-grid { grid-template-columns: repeat(3, 1fr); }
      #proof-grid > :nth-child(4),
      #proof-grid > :nth-child(5) {
        grid-column: auto;
      }
      #proof-grid > :last-child { grid-column: auto; }
    }
    @media (min-width: 1024px) {
      #proof-grid { grid-template-columns: repeat(5, 1fr); }
      #proof-grid > :last-child { grid-column: auto; }
    }

    /* Pain cards: 3-column on md+ */
    @media (min-width: 768px) {
      #pain-grid { grid-template-columns: repeat(3, 1fr); }
    }

    /* Liability grid: 2-column on md+ */
    @media (min-width: 768px) {
      #liability-grid { grid-template-columns: 1fr 1fr; }
    }

    /* Feature cards: 2-column on sm+ */
    @media (min-width: 640px) {
      #features-grid { grid-template-columns: repeat(2, 1fr); }
    }

    /* Binder grid: 2-column on lg */
    @media (min-width: 1024px) {
      #binder-grid { grid-template-columns: 7fr 5fr; }
    }

    /* Comparison grid: 3-column on md+ */
    @media (min-width: 768px) {
      #comparison-grid { grid-template-columns: repeat(3, 1fr); }
    }

    /* Compliance grid: 2-column on lg */
    @media (min-width: 1024px) {
      #compliance-grid { grid-template-columns: 5fr 7fr; }
    }

    /* Badges grid: 2-column on sm+ */
    @media (min-width: 640px) {
      #badges-grid { grid-template-columns: repeat(2, 1fr); }
    }

    /* Footer grid: responsive columns */
    @media (min-width: 640px) {
      #footer-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (min-width: 1024px) {
      #footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; }
    }

    /* Hero section responsive padding */
    @media (min-width: 640px) {
      #hero { padding-top: 48px !important; padding-bottom: 64px !important; }
    }
    @media (min-width: 768px) {
      #hero { padding-top: 64px !important; padding-bottom: 80px !important; }
    }
    @media (min-width: 1024px) {
      #hero { padding-top: 80px !important; padding-bottom: 96px !important; }
    }
    @media (min-width: 1280px) {
      #hero { padding-top: 96px !important; padding-bottom: 128px !important; }
    }

    /* Footer link hover */
    footer a:hover { color: #f7f8f8 !important; }
  </style>

</body>
</html>