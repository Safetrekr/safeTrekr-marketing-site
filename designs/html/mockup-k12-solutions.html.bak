<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trip Safety for K-12 Schools &amp; Districts &mdash; SafeTrekr</title>
  <meta name="description" content="Every field trip reviewed by a safety analyst. Per-student pricing starting at $15. Board-ready documentation that proves your district took every reasonable precaution.">
  <link rel="canonical" href="https://safetrekr.com/solutions/k12">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Trip Safety for K-12 Schools &amp; Districts &mdash; SafeTrekr">
  <meta property="og:description" content="Every field trip reviewed by a safety analyst. Per-student pricing starting at $15. Board-ready documentation that proves your district took every reasonable precaution.">
  <meta property="og:url" content="https://safetrekr.com/solutions/k12">

  <link rel="stylesheet" href="design-tokens.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            heading: ['Plus Jakarta Sans', 'system-ui', '-apple-system', 'sans-serif'],
            body: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
            mono: ['JetBrains Mono', 'ui-monospace', 'monospace'],
          },
          colors: {
            'st-primary': {
              50: '#f1f9f4', 100: '#e0f1e6', 200: '#c0e2cd', 300: '#96cfac',
              400: '#6cbc8b', 500: '#4ca46e', 600: '#3f885b', 700: '#33704b',
              800: '#2a5b3d', 900: '#20462f', 950: '#132a1c',
              DEFAULT: '#3f885b',
            },
            'st-secondary': {
              DEFAULT: '#123646', light: '#1a4a5e', muted: '#b8c3c7',
              foreground: '#f7f8f8',
            },
            'st-bg': '#e7ecee',
            'st-card': '#f7f8f8',
            'st-foreground': '#061a23',
            'st-border': '#b8c3c7',
            'st-muted': '#4d5153',
            'st-ring': '#365462',
            'st-destructive': '#c1253e',
          }
        }
      }
    }
  </script>

  <!-- Breadcrumb JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://safetrekr.com/" },
      { "@type": "ListItem", "position": 2, "name": "Solutions", "item": "https://safetrekr.com/solutions" },
      { "@type": "ListItem", "position": 3, "name": "K-12 Schools & Districts" }
    ]
  }
  </script>

  <!-- FAQPage JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is SafeTrekr FERPA compliant?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "SafeTrekr is designed with FERPA requirements in mind. Our data handling practices follow FERPA guidelines for student education records, including access controls, data minimization, and secure storage. We are currently pursuing formal FERPA certification. We believe in transparency -- we will never claim a certification we have not earned."
        }
      },
      {
        "@type": "Question",
        "name": "What happens to student data after the trip?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Student data is retained only for the documentation period required by your district's records retention policy. After that period, data is purged with a verifiable deletion record. You control the retention timeline. We provide cryptographic proof of deletion upon request."
        }
      },
      {
        "@type": "Question",
        "name": "Can our school district use SafeTrekr for all field trips?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. SafeTrekr handles field trips of every type -- from a single-day museum visit to a multi-day out-of-state educational trip. Every trip gets the same 17-section professional safety review, regardless of distance or duration. Volume pricing is available for districts with 25 or more trips per year."
        }
      },
      {
        "@type": "Question",
        "name": "How does SafeTrekr handle parent consent?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "SafeTrekr includes a Parent/Guardian Portal where parents can view trip safety details you choose to share. This is separate from your district's existing permission slip process. SafeTrekr provides the professional safety documentation; your district maintains its consent workflow. Parents see safety information -- not raw risk data."
        }
      },
      {
        "@type": "Question",
        "name": "What if a field trip destination changes at the last minute?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Submit the new destination and our team will expedite a review. For minor changes (same city, different venue), we can often turn around an updated review within 24-48 hours. The original binder is versioned, not replaced -- you maintain a complete audit trail of all destination changes."
        }
      },
      {
        "@type": "Question",
        "name": "How does per-student pricing work for large groups?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Pricing is $15 per student per trip. A field trip with 30 students costs $450. A field trip with 100 students costs $1,500. Volume discounts apply for districts committing to 25 or more trips per year. Contact us for district-wide pricing that covers all schools in your system."
        }
      },
      {
        "@type": "Question",
        "name": "Can board members access the safety binder directly?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. You can generate a read-only link for board members to review any safety binder. The binder includes the full 17-section review, risk intelligence summary, emergency response plan, and SHA-256 evidence chain verification. Board members see exactly what you see."
        }
      },
      {
        "@type": "Question",
        "name": "Does SafeTrekr replace our existing field trip approval process?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. SafeTrekr supplements your existing process with professional safety analysis and documentation. Your district keeps its approval workflow, permission slip procedures, and chain of command. SafeTrekr adds the evidence layer that proves your district took every reasonable precaution."
        }
      },
      {
        "@type": "Question",
        "name": "How quickly do we receive the safety binder?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Standard turnaround is 3-5 business days from trip submission. For field trips within the continental United States to well-documented destinations, turnaround is often faster. Rush processing is available for time-sensitive trips."
        }
      },
      {
        "@type": "Question",
        "name": "What government data sources does SafeTrekr use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our Risk Intelligence Engine aggregates data from 5 government sources: NOAA (weather and natural hazards), USGS (seismic and geological data), CDC (health advisories and disease surveillance), GDACS (global disaster alerts), and ReliefWeb (humanitarian situation reports). This data is scored using Monte Carlo simulation to produce a quantified risk profile for every destination."
        }
      }
    ]
  }
  </script>

  <style>
    /* ── Page-specific overrides ── */

    /* Sticky in-page nav */
    .anchor-nav {
      position: fixed;
      top: 72px;
      left: 0;
      right: 0;
      z-index: 20;
      background: rgba(247,248,248,0.95);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--color-border);
      box-shadow: var(--shadow-sm);
      transform: translateY(-100%);
      opacity: 0;
      transition: transform 0.25s ease, opacity 0.25s ease;
      pointer-events: none;
    }
    .anchor-nav.visible {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }
    .anchor-nav a {
      white-space: nowrap;
      padding: 8px 16px;
      border-radius: 9999px;
      font-size: 14px;
      font-weight: 500;
      color: var(--color-muted-foreground);
      transition: all 0.15s ease;
      text-decoration: none;
    }
    .anchor-nav a:hover {
      color: var(--color-foreground);
      background: rgba(6,26,35,0.04);
    }
    .anchor-nav a.active {
      color: var(--color-primary-700);
      font-weight: 600;
      background: var(--color-primary-50);
    }
    .anchor-nav-scroll {
      display: flex;
      gap: 4px;
      overflow-x: auto;
      -ms-overflow-style: none;
      scrollbar-width: none;
      padding: 8px 0;
    }
    .anchor-nav-scroll::-webkit-scrollbar { display: none; }

    /* Scroll offset for sticky header + anchor bar */
    [id] { scroll-margin-top: 140px; }

    /* Document preview component */
    .doc-preview {
      position: relative;
      width: 100%;
      max-width: 400px;
      margin: 0 auto;
    }
    .doc-page {
      background: white;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: 20px;
      box-shadow: var(--shadow-md);
      position: relative;
    }
    .doc-stack {
      position: relative;
    }
    .doc-stack::before,
    .doc-stack::after {
      content: '';
      position: absolute;
      background: white;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
    }
    .doc-stack::before {
      top: 6px; right: -6px; bottom: -6px; left: 6px;
      z-index: -1;
    }
    .doc-stack::after {
      top: 12px; right: -12px; bottom: -12px; left: 12px;
      z-index: -2;
    }

    /* Binder fan thumbnails */
    .binder-fan {
      display: flex;
      justify-content: center;
      gap: 0;
      position: relative;
      padding: 20px 0 40px;
    }
    .binder-thumb {
      width: 140px;
      height: 182px;
      background: white;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-md);
      padding: 12px;
      flex-shrink: 0;
      transition: transform 0.3s ease;
      position: relative;
    }
    .binder-thumb:nth-child(1) { transform: rotate(-3deg) translateX(20px); z-index: 4; }
    .binder-thumb:nth-child(2) { transform: rotate(-1deg) translateX(8px); z-index: 3; }
    .binder-thumb:nth-child(3) { transform: rotate(1deg) translateX(-8px); z-index: 2; }
    .binder-thumb:nth-child(4) { transform: rotate(3deg) translateX(-20px); z-index: 1; }

    @media (max-width: 639px) {
      .binder-fan {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        padding: 0;
      }
      .binder-thumb {
        width: 100%;
        height: auto;
        aspect-ratio: 3/4;
        transform: none !important;
      }
    }

    /* Pricing slider custom style */
    input[type="range"] {
      -webkit-appearance: none;
      appearance: none;
      width: 100%;
      height: 8px;
      border-radius: 9999px;
      background: var(--color-border);
      outline: none;
      cursor: pointer;
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--color-primary-600);
      border: 2px solid white;
      box-shadow: var(--shadow-md);
      cursor: pointer;
      transition: background 0.15s ease, transform 0.15s ease;
    }
    input[type="range"]::-moz-range-thumb {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--color-primary-600);
      border: 2px solid white;
      box-shadow: var(--shadow-md);
      cursor: pointer;
      transition: background 0.15s ease, transform 0.15s ease;
    }
    input[type="range"]:hover::-webkit-slider-thumb {
      background: var(--color-primary-700);
      transform: scale(1.1);
    }
    input[type="range"]:hover::-moz-range-thumb {
      background: var(--color-primary-700);
      transform: scale(1.1);
    }
    input[type="range"]:focus-visible::-webkit-slider-thumb {
      outline: 2px solid var(--color-ring);
      outline-offset: 2px;
    }
    input[type="range"]:focus-visible::-moz-range-thumb {
      outline: 2px solid var(--color-ring);
      outline-offset: 2px;
    }

    /* FAQ accordion via details/summary */
    .faq-item {
      border-bottom: 1px solid var(--color-border);
    }
    .faq-item summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 20px 0;
      cursor: pointer;
      list-style: none;
      font-family: var(--font-heading);
      font-size: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);
      font-weight: 600;
      line-height: 1.3;
      color: var(--color-foreground);
      transition: color 0.15s ease;
    }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::marker { display: none; content: ''; }
    .faq-item summary:hover { color: var(--color-primary-700); }
    .faq-item summary .chevron {
      flex-shrink: 0;
      width: 20px;
      height: 20px;
      transition: transform 0.2s ease;
      color: var(--color-muted-foreground);
    }
    .faq-item[open] summary .chevron {
      transform: rotate(180deg);
    }
    .faq-item .faq-answer {
      padding: 0 0 20px;
      font-size: 1rem;
      line-height: 1.6;
      color: var(--color-muted-foreground);
      max-width: 65ch;
    }

    /* Dark section surfaces */
    .dark-surface {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
    }

    /* Checklist check icon */
    .check-icon {
      flex-shrink: 0;
      width: 20px;
      height: 20px;
      color: var(--color-primary-500);
      margin-top: 2px;
    }

    /* Card hover */
    .feature-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .feature-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    /* Mobile header */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 30;
      background: rgba(247,248,248,0.95);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--color-border);
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .feature-card:hover { transform: none; }
      .binder-thumb { transition: none; }
      input[type="range"]:hover::-webkit-slider-thumb { transform: none; }
      input[type="range"]:hover::-moz-range-thumb { transform: none; }
      .faq-item summary .chevron { transition: none; }
      .anchor-nav { transition: none; }
    }
  </style>
<script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>
</head>
<body>
  <!-- Skip Navigation -->
  <a href="#main-content" class="sr-only" style="position:absolute;top:0;left:0;z-index:100;padding:12px 24px;background:var(--color-primary);color:white;font-weight:600;border-radius:0 0 var(--radius-md) 0;" onfocus="this.style.position='fixed';this.style.clip='auto';this.style.width='auto';this.style.height='auto';this.style.overflow='visible'" onblur="this.style.position='absolute';this.style.clip='rect(0,0,0,0)';this.style.width='1px';this.style.height='1px';this.style.overflow='hidden'">Skip to main content</a>

  <!-- ============================================================
       SITE HEADER
       ============================================================ -->
  <header id="site-header" class="fixed top-0 left-0 right-0 z-30 transition-all duration-300" style="height: 80px;">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-8 lg:px-12 h-full flex items-center justify-between">
      <!-- Logo: Horizontal lockup -->
      <a href="/" aria-label="SafeTrekr home" class="flex-shrink-0">
        <svg height="32" viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="hidden lg:block" aria-hidden="true">
          <path d="M16 1L3 8v10c0 7.2 5.5 13.9 13 15.9 7.5-2 13-8.7 13-15.9V8L16 1z" fill="none" stroke="#123646" stroke-width="2" stroke-linejoin="round"/>
          <path d="M10 14l4 4 8-8" stroke="#3f885b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="40" y="22" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-weight="700" font-size="18" fill="#123646">SafeTrekr</text>
        </svg>
        <svg height="28" viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="lg:hidden" aria-hidden="true">
          <path d="M16 1L3 8v10c0 7.2 5.5 13.9 13 15.9 7.5-2 13-8.7 13-15.9V8L16 1z" fill="none" stroke="#123646" stroke-width="2" stroke-linejoin="round"/>
          <path d="M10 14l4 4 8-8" stroke="#3f885b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="40" y="22" font-family="Plus Jakarta Sans, system-ui, sans-serif" font-weight="700" font-size="18" fill="#123646">SafeTrekr</text>
        </svg>
      </a>

      <!-- Desktop Nav -->
      <nav aria-label="Main navigation" class="hidden lg:flex items-center gap-8">
        <a href="/platform" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Platform
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="/solutions" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Solutions
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="/how-it-works" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150" style="font-family: var(--font-body);">How It Works</a>
        <a href="/pricing" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150" style="font-family: var(--font-body);">Pricing</a>
        <a href="/resources" class="text-base font-medium text-foreground/70 hover:text-foreground transition-colors duration-150 flex items-center gap-1" style="font-family: var(--font-body);">
          Resources
          <svg class="w-4 h-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </nav>

      <!-- Desktop CTAs -->
      <div class="hidden lg:flex items-center gap-4">
        <a href="https://app.safetrekr.com" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold transition-colors duration-150 hover:text-foreground" style="font-family: var(--font-heading); color: var(--color-muted-foreground);">Sign In</a>
        <a href="/demo" class="inline-flex items-center justify-center font-semibold rounded-md transition-all duration-150 text-white" style="font-family: var(--font-heading); background: var(--color-primary-600); padding: 10px 20px; font-size: 15px; border-radius: var(--radius-md); text-decoration: none;">Get a Demo</a>
      </div>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-foreground" aria-label="Open navigation menu" aria-expanded="false">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- ============================================================
       STICKY IN-PAGE NAVIGATION
       ============================================================ -->
  <nav class="anchor-nav" id="anchor-nav" aria-label="Page sections">
    <div class="container">
      <div class="anchor-nav-scroll">
        <a href="#challenge">The Problem</a>
        <a href="#solutions">How It Works</a>
        <a href="#binder-preview">Sample Binder</a>
        <a href="#pricing">Pricing</a>
        <a href="#compliance">Compliance</a>
        <a href="#faq">FAQ</a>
      </div>
    </div>
  </nav>

  <main id="main-content">

    <!-- ============================================================
         SECTION 1: HERO
         ============================================================ -->
    <section id="hero" style="background:var(--color-background);padding-top:32px;padding-bottom:48px;" class="sm:py-12 md:py-16 lg:py-20 xl:py-24">
      <div class="container">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" style="margin-bottom:24px;">
          <ol class="flex items-center gap-2" style="list-style:none;font-size:14px;line-height:1.5;color:var(--color-muted-foreground);">
            <li><a href="/" style="color:var(--color-muted-foreground);text-decoration:none;">Home</a></li>
            <li aria-hidden="true" style="color:var(--color-border);">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
            </li>
            <li><a href="/solutions" style="color:var(--color-muted-foreground);text-decoration:none;">Solutions</a></li>
            <li aria-hidden="true" style="color:var(--color-border);">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
            </li>
            <li><span aria-current="page" style="color:var(--color-foreground);font-weight:500;">K-12 Schools &amp; Districts</span></li>
          </ol>
        </nav>

        <!-- Hero Grid -->
        <div class="grid gap-12 lg:gap-20 items-center" style="grid-template-columns:1fr;" id="hero-grid">
          <!-- Visual Column (shows first on mobile) -->
          <div class="lg:order-2" aria-hidden="true" style="display:flex;justify-content:center;">
            <div class="doc-stack doc-preview">
              <div class="doc-page">
                <!-- Document Header -->
                <div class="flex items-center gap-2" style="margin-bottom:16px;">
                  <svg width="16" height="16" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                    <rect width="32" height="32" rx="8" fill="#3f885b"/>
                    <path d="M16 6L22 12V22C22 23.1 21.1 24 20 24H12C10.9 24 10 23.1 10 22V12L16 6Z" fill="white" opacity="0.9"/>
                  </svg>
                  <span style="font-family:var(--font-heading);font-size:clamp(1.125rem, 1rem + 0.5vw, 1.375rem);font-weight:600;color:var(--color-foreground);">Field Trip Safety Binder</span>
                </div>

                <!-- Destination badge -->
                <span class="badge badge-brand" style="margin-bottom:16px;">Springfield Science Museum</span>

                <!-- Review summary strip -->
                <div class="grid" style="grid-template-columns:repeat(3,1fr);gap:8px;margin:16px 0;padding:12px 0;border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);">
                  <div style="text-align:center;">
                    <div style="font-family:var(--font-heading);font-size:16px;font-weight:700;color:var(--color-primary-700);">17</div>
                    <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-muted-foreground);">Sections</div>
                  </div>
                  <div style="text-align:center;border-left:1px solid var(--color-border);border-right:1px solid var(--color-border);">
                    <div style="font-family:var(--font-heading);font-size:16px;font-weight:700;color:#22c55e;">Low</div>
                    <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-muted-foreground);">Risk Score</div>
                  </div>
