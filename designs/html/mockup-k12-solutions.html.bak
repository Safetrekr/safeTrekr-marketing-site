    <section id="pricing" aria-labelledby="pricing-heading" class="section" style="background:var(--color-background);">
      <div class="container">
        <!-- Header -->
        <div style="text-align:center;max-width:768px;margin:0 auto;">
          <p class="eyebrow" style="color:var(--color-primary-700);">PRICING</p>
          <h2 id="pricing-heading" class="text-display-md" style="color:var(--color-foreground);margin-top:12px;">$15 Per Student. Do the Math.</h2>
          <p class="text-body-lg" style="color:var(--color-muted-foreground);max-width:65ch;margin:16px auto 0;">Professional safety analysis costs less than a permission slip printing budget. Compare to what your district risks without it.</p>
        </div>

        <!-- Calculator Card -->
        <div style="max-width:672px;margin:48px auto 0;">
          <div style="background:var(--color-card);border:2px solid var(--color-border);border-radius:var(--radius-2xl);padding:32px;box-shadow:var(--shadow-lg);" class="lg:p-10">
            <h3 class="text-heading-sm" style="color:var(--color-foreground);margin-bottom:32px;">Calculate Your District&rsquo;s Cost</h3>

            <!-- Slider: Students Per Trip -->
            <div style="margin-bottom:28px;">
              <div class="flex items-center justify-between" style="margin-bottom:12px;">
                <label for="students-slider" class="text-eyebrow" style="color:var(--color-muted-foreground);">STUDENTS PER TRIP</label>
                <span id="students-value" class="text-heading-md" style="color:var(--color-foreground);font-family:var(--font-heading);font-variant-numeric:tabular-nums;">30</span>
              </div>
              <input type="range" id="students-slider" min="10" max="200" step="5" value="30"
                aria-valuemin="10" aria-valuemax="200" aria-valuenow="30"
                aria-valuetext="30 students per trip"
                style="width:100%;">
              <div class="flex justify-between" style="margin-top:4px;">
                <span style="font-size:12px;color:var(--color-muted-foreground);">10</span>
                <span style="font-size:12px;color:var(--color-muted-foreground);">200</span>
              </div>
            </div>

            <!-- Slider: Trips Per Year -->
            <div style="margin-bottom:28px;">
              <div class="flex items-center justify-between" style="margin-bottom:12px;">
                <label for="trips-slider" class="text-eyebrow" style="color:var(--color-muted-foreground);">TRIPS PER YEAR</label>
                <span id="trips-value" class="text-heading-md" style="color:var(--color-foreground);font-family:var(--font-heading);font-variant-numeric:tabular-nums;">20</span>
              </div>
              <input type="range" id="trips-slider" min="1" max="100" step="1" value="20"
                aria-valuemin="1" aria-valuemax="100" aria-valuenow="20"
                aria-valuetext="20 trips per year"
                style="width:100%;">
              <div class="flex justify-between" style="margin-top:4px;">
                <span style="font-size:12px;color:var(--color-muted-foreground);">1</span>
                <span style="font-size:12px;color:var(--color-muted-foreground);">100</span>
              </div>
            </div>

            <!-- Divider -->
            <div style="height:1px;background:var(--color-border);margin:28px 0;"></div>

            <!-- Results Grid -->
            <div class="grid gap-6" style="grid-template-columns:repeat(3,1fr);text-align:center;">
              <div>
                <output id="result-annual" class="text-display-md" style="display:block;color:var(--color-foreground);font-family:var(--font-heading);font-variant-numeric:tabular-nums;font-weight:700;" aria-live="polite" aria-label="Annual SafeTrekr cost: $9,000">$9,000</output>
                <span class="text-eyebrow" style="color:var(--color-muted-foreground);margin-top:4px;display:block;">ANNUAL COST</span>
              </div>
              <div>
                <output class="text-body-lg" style="display:block;color:var(--color-primary-700);font-weight:600;font-variant-numeric:tabular-nums;" aria-label="Per student cost: $15">$15</output>
                <span class="text-eyebrow" style="color:var(--color-muted-foreground);margin-top:4px;display:block;">PER STUDENT</span>
              </div>
              <div>
                <output id="result-per-trip" class="text-body-lg" style="display:block;color:var(--color-foreground);font-weight:600;font-variant-numeric:tabular-nums;" aria-live="polite" aria-label="Cost per trip: $450">$450</output>
                <span class="text-eyebrow" style="color:var(--color-muted-foreground);margin-top:4px;display:block;">PER TRIP</span>
              </div>
            </div>

            <!-- Comparison Strip -->
            <div style="background:var(--color-primary-50);border-radius:var(--radius-lg);padding:20px;margin-top:32px;" role="group" aria-label="Cost comparison: SafeTrekr versus status quo">
              <div class="grid gap-4" style="grid-template-columns:1fr;" id="comparison-grid">
                <!-- SafeTrekr -->
                <div style="text-align:center;">
                  <p style="font-size:13px;font-weight:600;color:var(--color-foreground);text-transform:uppercase;letter-spacing:0.04em;">SafeTrekr</p>
                  <p id="compare-safetrekr" style="font-family:var(--font-heading);font-size:20px;font-weight:700;color:var(--color-primary-700);margin-top:4px;font-variant-numeric:tabular-nums;">$9,000/year</p>
                  <p style="font-size:13px;color:var(--color-muted-foreground);margin-top:2px;">Professional analyst review</p>
                </div>
                <!-- Staff Time -->
                <div style="text-align:center;">
                  <p style="font-size:13px;font-weight:600;color:var(--color-foreground);text-transform:uppercase;letter-spacing:0.04em;">Staff Time Without SafeTrekr</p>
                  <p id="compare-staff" style="font-family:var(--font-heading);font-size:20px;font-weight:700;color:var(--color-muted-foreground);margin-top:4px;font-variant-numeric:tabular-nums;">$14,000 - $28,000/year</p>
                  <p style="font-size:13px;color:var(--color-muted-foreground);margin-top:2px;"><span id="compare-trips-count">20</span> trips &times; $700-$1,400 per trip</p>
                </div>
                <!-- Lawsuit Risk -->
                <div style="text-align:center;">
                  <p style="font-size:13px;font-weight:600;color:var(--color-foreground);text-transform:uppercase;letter-spacing:0.04em;">Lawsuit Exposure</p>
                  <p style="font-family:var(--font-heading);font-size:20px;font-weight:700;color:var(--color-destructive);margin-top:4px;">$500K - $2M</p>
                  <p style="font-size:13px;color:var(--color-muted-foreground);margin-top:2px;">Average settlement for trip-related incidents</p>
                </div>
              </div>
            </div>

            <!-- Footer link -->
            <p style="text-align:center;margin-top:24px;font-size:14px;color:var(--color-muted-foreground);">
              See full pricing details including volume discounts for large districts.
              <a href="/pricing" class="flex items-center gap-1 justify-center" style="font-size:14px;font-weight:500;color:var(--color-primary-700);margin-top:4px;display:inline-flex;">
                View Full Pricing
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              </a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 7: COMPLIANCE & TRUST
         ============================================================ -->
    <section id="compliance" aria-labelledby="compliance-heading" class="section" style="background:var(--color-card);border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);">
      <div class="container">
        <div class="grid gap-12 lg:gap-20 items-start" style="grid-template-columns:1fr;" id="compliance-grid">
          <!-- Text Column -->
          <div>
            <p class="eyebrow" style="color:var(--color-primary-700);">COMPLIANCE &amp; TRUST</p>
            <h2 id="compliance-heading" class="text-display-md" style="color:var(--color-foreground);margin-top:12px;">Designed with FERPA Requirements in Mind</h2>
            <p class="text-body-lg" style="color:var(--color-muted-foreground);margin-top:16px;">Student data is sensitive. We built SafeTrekr knowing that. Our data handling practices follow FERPA guidelines for student education records. Certification is in progress.</p>
            <p class="text-body-lg" style="color:var(--color-foreground);font-weight:500;margin-top:16px;">We do not overclaim. We do not cut corners. We document everything.</p>

            <div style="margin-top:24px;display:flex;flex-direction:column;gap:12px;">
              <a href="/security" class="flex items-center gap-1" style="font-size:14px;font-weight:500;color:var(--color-primary-700);">
                View our security practices
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              </a>
              <a href="/procurement" class="flex items-center gap-1" style="font-size:14px;font-weight:500;color:var(--color-primary-700);">
                Procurement resources
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Badge Cards -->
          <div>
            <div class="grid gap-6" style="grid-template-columns:1fr;" id="badges-grid">
              <!-- FERPA -->
              <div style="background:var(--color-background);border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:24px;box-shadow:var(--shadow-sm);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-700)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                <h3 class="text-heading-sm" style="color:var(--color-foreground);margin-top:12px;">FERPA</h3>
                <p class="text-body-sm" style="color:var(--color-muted-foreground);margin-top:8px;">Designed with FERPA requirements in mind. Student data handling follows FERPA guidelines. Certification in progress.</p>
              </div>

              <!-- AES-256 -->
              <div style="background:var(--color-background);border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:24px;box-shadow:var(--shadow-sm);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-700)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
                </svg>
                <h3 class="text-heading-sm" style="color:var(--color-foreground);margin-top:12px;">AES-256 Encryption</h3>
                <p class="text-body-sm" style="color:var(--color-muted-foreground);margin-top:8px;">All student data encrypted at rest and in transit using AES-256 standard.</p>
              </div>

              <!-- SOC 2 -->
              <div style="background:var(--color-background);border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:24px;box-shadow:var(--shadow-sm);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-700)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M14.5 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15l2 2 4-4"/>
                </svg>
                <h3 class="text-heading-sm" style="color:var(--color-foreground);margin-top:12px;">SOC 2 Type II</h3>
                <p class="text-body-sm" style="color:var(--color-muted-foreground);margin-top:8px;">Type II audit in progress. Security controls documented and verified by independent auditors.</p>
              </div>

              <!-- SHA-256 -->
              <div style="background:var(--color-background);border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:24px;box-shadow:var(--shadow-sm);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-700)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/>
                </svg>
                <h3 class="text-heading-sm" style="color:var(--color-foreground);margin-top:12px;">SHA-256 Evidence Chain</h3>
                <p class="text-body-sm" style="color:var(--color-muted-foreground);margin-top:8px;">Tamper-evident evidence chain. Every document in every safety binder is hash-verified and immutable.</p>
              </div>
            </div>

            <!-- COPPA Note -->
            <p class="text-body-sm" style="color:var(--color-muted-foreground);margin-top:32px;max-width:65ch;">SafeTrekr does not collect data directly from students under 13. All student information is provided by authorized school administrators in accordance with COPPA guidelines.</p>
          </div>
        </div>
