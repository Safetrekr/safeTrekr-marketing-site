# ===========================================================================
# SafeTrekr Marketing -- Environment Variables
# ===========================================================================
#
# ST-812: REQ-029 -- Environment Management
#
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# Next.js loads `.env.local` automatically. Variables prefixed with
# NEXT_PUBLIC_ are exposed to the browser bundle; all others are
# server-side only.
#
# In Kubernetes, non-secret values are managed via ConfigMap
# (infrastructure/k8s/overlays/<env>/kustomization.yaml) and secrets
# via Sealed Secrets or CI-injected kubectl create secret.
#
# NEVER commit real credentials to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Node / Next.js Runtime
# ---------------------------------------------------------------------------

# Node environment: "development" | "production" | "test"
NODE_ENV=development

# Disable Next.js anonymous telemetry (1 = disabled)
NEXT_TELEMETRY_DISABLED=1

# ---------------------------------------------------------------------------
# Supabase (Database + Auth)
# ---------------------------------------------------------------------------

# PUBLIC: Supabase project URL -- embedded in the client bundle.
# Staging:    https://your-staging-project.supabase.co
# Production: https://your-production-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# SECRET: Supabase service role key -- server-side only.
# This key bypasses Row Level Security. Never expose to the client.
# Obtain from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---------------------------------------------------------------------------
# Cloudflare Turnstile (Bot Protection)
# ---------------------------------------------------------------------------

# PUBLIC: Turnstile site key -- embedded in the client bundle.
# Test keys (always pass): 1x00000000000000000000AA
# Test keys (always fail): 2x00000000000000000000AB
# Obtain production key from: Cloudflare Dashboard > Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# SECRET: Turnstile secret key -- server-side only.
# Used by src/lib/security/turnstile.ts to verify tokens with Cloudflare.
# Test keys (always pass): 1x0000000000000000000000000000000AA
# Test keys (always fail): 2x0000000000000000000000000000000AA
# Obtain production key from: Cloudflare Dashboard > Turnstile > Settings
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ---------------------------------------------------------------------------
# SendGrid (Transactional Email)
# ---------------------------------------------------------------------------

# SECRET: SendGrid API key for sending emails (waitlist confirmation, etc.)
# Obtain from: SendGrid Dashboard > Settings > API Keys
SENDGRID_API_KEY=your-sendgrid-api-key

# ---------------------------------------------------------------------------
# Site URL (used for canonical URLs, OG meta, sitemap generation)
# ---------------------------------------------------------------------------

# PUBLIC: The canonical URL of the site for the current environment.
# Local:      http://localhost:3000
# Staging:    https://staging.safetrekr.com
# Production: https://safetrekr.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# MapTiler (Map Tiles for Hero Map)
# ---------------------------------------------------------------------------

# PUBLIC: MapTiler API key for map tile rendering in the hero section.
# The hero map uses MapTiler's "dataviz-light" style for a clean, muted basemap.
# Free tier: 100K tile requests/month.
# Obtain from: https://cloud.maptiler.com/account/keys/
# Without this key, the map falls back to desaturated OpenStreetMap raster tiles.
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-api-key

# ---------------------------------------------------------------------------
# Plausible Analytics (ST-910)
# ---------------------------------------------------------------------------

# PUBLIC: Domain registered in your Plausible dashboard.
# When set, the Plausible script is loaded on all marketing pages.
# When empty/unset, no Plausible script is loaded.
# Obtain from: https://plausible.io/sites
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ---------------------------------------------------------------------------
# Google Analytics 4 (ST-911 -- Consent-Gated)
# ---------------------------------------------------------------------------

# PUBLIC: GA4 Measurement ID (e.g., "G-XXXXXXXXXX").
# The GA4 script is ONLY loaded after explicit user consent
# (localStorage key 'analytics-consent' = 'granted').
# When empty/unset, GA4 is completely disabled.
# Obtain from: Google Analytics > Admin > Data Streams
NEXT_PUBLIC_GA4_ID=
